      if adderScope then
        adderScope:doCleanup()
        adderScope = nil

        return
      end

      local scope = scope:innerScope()

      adderScope = scope

      if ctx.current_focused then
        ctx.current_focused:set(false)
      end

      ctx.focused_before_priority = ctx.current_focused
      ctx.current_focused = nil

      ctx.current_priority:set(math.huge)

      table.insert(scope, function()
        ctx.current_focused = ctx.focused_before_priority

        if ctx.current_focused then
          ctx.current_focused:set(true)
        end

        ctx.current_priority:set(0)
      end)

      Adder(scope, {
        parent = alwaysOnTopGUI,
        cleanup = function()
          adderScope:doCleanup()
          adderScope = nil
        end,
      })

      scope:New "ImageButton" {
        Parent = alwaysOnTopGUI,

