      button_icon = "rbxassetid://133554839488189",

      position = Vector2.new(-(257 + 140 + 130 + 8 * 4), 8),
      anchor = Vector2.new(1, 0),

      size = Vector2.new(120, 0),

      automatic_height = true,
      resize_axes = Vector2.xAxis,

      global_enabled = guiEnabled,

      child = Retime(scope, {
        effects = selectedEffects,
