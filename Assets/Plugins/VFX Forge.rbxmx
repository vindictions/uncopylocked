					</Item>
					<Item class="ModuleScript" referent="RBX6D2E282D4E5D47C19D4750A945B10F9B">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  -- when we getting tuple types?
  buttons: { string | (name: string) -> () },
}

local function NamePrompt(scope: ui_types.scope, value: string, props: props)
  local inputValue: Fusion.Value<TextBox?> = scope:Value(nil)

  local child = scope:New "Frame" {
    BackgroundTransparency = 1,

    Size = scope:Computed(function(use)
      return UDim2.fromOffset(
        200,
        use(ui_conf.text_sizes.mini) * 2 + use(ui_conf.padding.side) * 3 + use(ui_conf.padding.base) * 4
      )
    end),

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:Hover "Frame" {
        BackgroundColor3 = ui_conf.colors.surface,

        Size = scope:Computed(function(use)
          return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2)
        end),

        [Children] = {
          scope:Round(ui_conf.rounding.mini),

          inputValue:set(scope:New "TextBox" {
            BackgroundTransparency = 1,

            AnchorPoint = Vector2.new(0.5, 0),
            Position = UDim2.fromScale(0.5, 0),

            Size = scope:Computed(function(use)
              return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
            end),

            FontFace = ui_conf.font,

            Text = value,
            PlaceholderText = "name",

            TextColor3 = ui_conf.colors.text,
            PlaceholderColor3 = ui_conf.colors.muted,

            TextSize = ui_conf.text_sizes.mini,

            ClipsDescendants = true,

            [OnEvent "FocusLost"] = function(enter)
              if enter then
                local bar = peek(inputValue)

                if not bar or bar.Text == "" then
                  return
                end

                if #props.buttons == 1 then
                  props.buttons[1][2](bar.Text)
                  scope:doCleanup()
                end
              end
            end,
          } :: TextBox),
        },
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,

        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 0),

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:ForValues(props.buttons, function(_, _, btn)
            return scope:Hover "TextButton" {
              AutomaticSize = Enum.AutomaticSize.Y,

              AnchorPoint = Vector2.new(1, 0),
              Position = UDim2.fromScale(1, 0),

              Size = UDim2.fromScale(1, 0),

              Text = btn[1],

              BackgroundColor3 = ui_conf.colors.primary,
              TextColor3 = ui_conf.colors.surface,

              FontFace = ui_conf.font,
              TextSize = ui_conf.text_sizes.mini,

              [OnEvent "MouseButton1Click"] = function()
                local bar = peek(inputValue)

                if not bar or bar.Text == "" then
                  return
                end

                btn[2](bar.Text)

                scope:doCleanup()
              end,

              [Children] = {
                scope:Round(ui_conf.rounding.mini),
                scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
              },
            }
          end),
        },
      },
    },
  }

  local bar = peek(inputValue)

  if bar then
    task.defer(function()
      bar:CaptureFocus()

      bar.CursorPosition = #bar.Text + 1
      bar.SelectionStart = 0
    end)
  end

  return child
end

return NamePrompt
]]></ProtectedString>
							<string name="ScriptGuid">{19C98E59-715A-4743-B373-BBDE1AA64512}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">NamePrompt</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBXEFF3DAD7031B4E64BC7E9DD8A5BC2752">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../../../.conf")
local types = require("../types")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local lerp = require("../../../lib/lerp")
local logger = require("../../../lib/logger")
local utility = require("../../../lib/utility")

local TangentPoint = require("./TangentPoint")

local Attribute = require("../../attributes/cmp/Attribute")
local NumberInput = require("../../attributes/cmp/NumberInput")
local VectorInput = require("../../attributes/cmp/VectorInput")

type props = types.point_props

local function Point(scope: ui_types.scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot curve point because the ctx contextual is not set for current thread")
  end

  local pos = scope:Value(props.ctrlp.Position)

  local function TangentLine(tpos: Fusion.Value<UDim2>)
    local originCtrlP = Path2DControlPoint.new(props.ctrlp.Position)
    local tangentCtrlP = Path2DControlPoint.new(props.ctrlp.Position + peek(tpos))

    local tangentLinePath = scope:New "Path2D" {
      Parent = props.parent,

      Thickness = 2,

      Color3 = ui_conf.colors.primary,
    } :: Path2D

    tangentLinePath:SetControlPoints({
      originCtrlP,
      tangentCtrlP,
    })

    local function updateTangentPt()
      if tangentLinePath.Parent == nil then
        tangentLinePath.AncestryChanged:Wait()
      end

      -- roblox can't fix their stuff smh
      pcall(function()
        originCtrlP.Position = peek(pos)
        tangentCtrlP.Position = props.ctrlp.Position + peek(tpos)

        tangentLinePath:UpdateControlPoint(1, originCtrlP)
        tangentLinePath:UpdateControlPoint(2, tangentCtrlP)
      end)
    end

    props.umap[props.ctrlp] = updateTangentPt

    scope:Observer(pos):onChange(updateTangentPt)
    scope:Observer(tpos):onChange(updateTangentPt)

    return tangentLinePath
  end

  local function setPosition(p: UDim2)
    local pts = props.points
    local prevIndex = table.find(pts, props.ctrlp)

    props.ctrlp.Position = p

    table.sort(pts, function(a, b)
      return a.Position.X.Scale < b.Position.X.Scale
    end)

    pos:set(p)

    local index = table.find(pts, props.ctrlp)

    local before = pts[index - 1]
    local after = pts[index + 1]

    props.update_tangents(before, false, true)
    props.update_tangents(after, true, false)

    props.update_tangents(props.ctrlp, true, true)

    local path = peek(props.path)

    if path then
      if index == prevIndex then
        pcall(function()
          path:UpdateControlPoint(index, props.ctrlp)
        end)
      else
        path:SetControlPoints(pts)
      end
    end
  end

  local ctxMenuLast = 0
  local recording: string?

  local hovered = scope:Value(false)
  local holding = scope:Value(false)

  local btnValue: Fusion.Value<ImageButton?> = scope:Value(nil)

  local tpos1 = scope:Value(if props.last or not props.side then props.ctrlp.LeftTangent else props.ctrlp.RightTangent)
  local tpos2 = if not props.side then scope:Value(props.ctrlp.RightTangent) else nil

  local mirrored = scope:Value(not props.side and peek(tpos1) == -peek(tpos2))

  local time = scope:Value(0)
  local value = scope:Value(0)

  do
    local consumePos = false
    local consumeTime = false
    local consumeValue = false

    scope:Observer(pos):onBind(function()
      if consumePos then
        consumePos = false
        return
      end

      local p = peek(pos)

      consumeTime = true
      consumeValue = true

      time:set(p.X.Scale)
      value:set(1 - p.Y.Scale)

      consumeTime = false
      consumeValue = false
    end)

    local function updatePosFromTimeValue()
      local p = UDim2.fromScale(peek(time), 1 - peek(value))

      consumePos = true
      setPosition(p)
      consumePos = false

      if not recording then
        props.on_change()
      end
    end

    scope:Observer(time):onChange(function()
      if consumeTime then
        consumeTime = false
        return
      end

      updatePosFromTimeValue()
    end)

    scope:Observer(value):onChange(function()
      if consumeValue then
        consumeValue = false
        return
      end

      updatePosFromTimeValue()
    end)
  end

  local ltg = if props.last or not props.side then tpos1 else nil
  local rtg = if props.side and not props.last then tpos1 else if props.side then nil else tpos2

  local function onTangentChange(isleft: boolean, o: Fusion.Value<UDim2>?, value: Fusion.Value<vector>?)
    if not value or not o then
      return
    end

    scope:Observer(value):onChange(function()
      local v = peek(value)
      local udim = UDim2.fromScale(v.x, v.y)

      if peek(o) == udim then
        return
      end

      local idx = isleft and 1 or 2
      props.map[props.ctrlp][idx](udim)

      mirrored:set(not props.side and peek(tpos1) == -peek(tpos2))

      props.on_change()
    end)
  end

  local function makeVectorValue(value: Fusion.Value<UDim2>?)
    if not value then
      return nil
    end

    local v = scope:Value(vector.zero)

    scope:Observer(value):onBind(function()
      local p = peek(value)
      v:set(vector.create(p.X.Scale, p.Y.Scale))
    end)

    return v
  end

  local function makeConvertedValue(istime: boolean, value: Fusion.Value<number>)
    local v = scope:Value(0)

    local ignoreA, ignoreB = false, false

    scope:Observer(v):onChange(function()
      if ignoreA then
        ignoreA = false
        return
      end

      local _, tmax, vmin, vmax, _, v2, _, v4, startIsRange, stopIsRange = props.get_time_value()

      local p = peek(v)

      ignoreB = true

      if istime then
        local t = math.clamp(p / (tmax ~= 0 and tmax or 1), 0, 1)

        value:set(t)

        ignoreA = true

        task.defer(function()
          v:set(t * tmax)
          ignoreA = false
        end)
      else
        local a, b

        if startIsRange and stopIsRange then
          a, b = v2, v4
        elseif startIsRange then
          a, b = v2, vmax
        elseif stopIsRange then
          a, b = vmin, v4
        else
          a, b = vmin, vmax
        end

        local max = b - a

        value:set((p - a) / (max ~= 0 and max or 1))
      end

      ignoreB = false
    end)

    local function update()
      if ignoreB then
        ignoreB = false
        return
      end

      local _, tmax, vmin, vmax, _, v2, _, v4, startIsRange, stopIsRange = props.get_time_value()

      local p = peek(value)

      if istime then
        task.defer(function()
          v:set(tmax * p)
        end)
      else
        local b

        if startIsRange or stopIsRange then
          if startIsRange and stopIsRange then
            b = lerp.linear(v2, v4, p)
          elseif startIsRange then
            b = lerp.linear(v2, vmax, p)
          else
            b = lerp.linear(vmin, v4, p)
          end
        else
          b = lerp.linear(vmin, vmax, p)
        end

        ignoreA = true

        task.defer(function()
          v:set(b)
          ignoreA = false
        end)
      end
    end

    scope:Observer(value):onBind(update)

    return v, update
  end

  local left = makeVectorValue(ltg)
  local right = makeVectorValue(rtg)

  onTangentChange(true, ltg, left)
  onTangentChange(false, rtg, right)

  local vpos = makeVectorValue(pos)

  scope:Observer(vpos):onChange(function()
    local p = peek(vpos)

    setPosition(UDim2.fromScale(p.x, p.y))

    if not recording then
      props.on_change()
    end
  end)

  local ct, syncTime = makeConvertedValue(true, time)
  local cv, syncValue = makeConvertedValue(false, value)

  local properties = {
    {
      "Time",
      ct,
      0,
      math.huge,
    },
    {
      "Value",
      cv,
      props.side and 0 or -math.huge,
      props.side and 1 or math.huge,
    },
    { "Position", vpos },
    { "LeftTangent", left },
    { "RightTangent", right },
  }

  local movePos = scope:Value(peek(pos))

  local tooltipScope = scope:innerScope()

  scope:Observer(holding):onChange(function()
    movePos:set(peek(pos))

    if peek(holding) and peek(props.effect) ~= nil and not recording then
      recording = utility.initRecording("forge_writeCurve")
    elseif recording then
      utility.stopRecording(recording, true)
      recording = nil
    end

    if not peek(holding) then
      tooltipScope:doCleanup()
      tooltipScope = scope:innerScope()
    end
  end)

  scope:Observer(hovered):onChange(function()
    if peek(holding) then
      return
    end

    if peek(hovered) then
      conf.ctx:is(ctx):during(function()
        tooltipScope:Tooltip({
          near_padding = 14,
          text = tooltipScope:Computed(props.tooltip_text(tooltipScope, pos)),
        })
      end)
    else
      tooltipScope:doCleanup()
      tooltipScope = scope:innerScope()
    end
  end)

  return {
    btnValue:set(scope:Hover("ImageButton", nil, hovered) {
      Parent = props.parent,
      BackgroundColor3 = ui_conf.colors.primary,

      AnchorPoint = Vector2.new(0.5, 0.5),

      Size = scope:Computed(function(use)
        local state = use(hovered)
        return UDim2.fromOffset(state and 14 or 10, state and 14 or 10)
      end),

      Position = pos,

      [OnEvent "MouseButton1Down"] = function()
        ctxMenuLast = os.clock()
      end,

      [OnEvent "MouseButton1Up"] = function()
        local delta = os.clock() - ctxMenuLast

        if delta > 0.15 then
          return
        end

        tooltipScope:doCleanup()
        tooltipScope = scope:innerScope()

        conf.ctx:is(ctx):during(function()
          scope:Options({
            near_element = peek(btnValue),
            near_padding = ui_conf.padding.side,

            float = Vector2.new(0, 1),

            options = {
              if not props.side and (peek(tpos1) == UDim2.new() or peek(tpos2) == UDim2.new())
                then {
                  name = (peek(tpos1) == UDim2.new() and peek(tpos2) == UDim2.new()) and "Add Handles" or "Add Handle",
                  on_click = function()
                    local list = props.map[props.ctrlp]

                    list[1](UDim2.fromScale(-0.25, 0))
                    list[2](UDim2.fromScale(0.25, 0))
                  end,
                }
                else nil,
              if not props.side and (peek(tpos1) ~= UDim2.new() or peek(tpos2) ~= UDim2.new())
                then {
                  name = peek(mirrored) and "Break Handles" or "Mirror Handles",
                  on_click = function()
                    mirrored:set(not peek(mirrored))
                  end,
                }
                else nil,
              {
                name = "Properties",
                on_click = function()
                  syncTime()
                  syncValue()

                  scope:Prompt({
                    title = `Point #{table.find(props.points, props.ctrlp)}`,

                    float = Vector2.new(0, 1),
                    near_element = peek(btnValue),

                    child = function(scope)
                      return scope:New "Frame" {
                        AutomaticSize = Enum.AutomaticSize.Y,

                        BackgroundTransparency = 1,
                        Size = UDim2.fromOffset(200, 0),

                        [Children] = {
                          scope:New "UIListLayout" {
                            SortOrder = Enum.SortOrder.LayoutOrder,
                          },

                          scope:ForPairs(properties, function(_, scope, i, prop)
                            local value = prop[2]

                            local pos = peek(value)
                            local isvec = typeof(pos) == "Vector3"
                            local ispos = prop[1] == "Position"
                            local isSidePos = props.side and ispos

                            local readonly = pos == nil or (not isvec and props.side and prop[1] == "Time")

                            local cmp, updateText

                            if isvec then
                              cmp, updateText = VectorInput(scope, {
                                readonly = readonly,
                                value = value or scope:Value(vector.create(0, 0)),

                                min = isvec
                                    and vector.create(
                                      if isSidePos then props.last and 1 or 0 else 1,
                                      props.side and 1 or math.huge
                                    )
                                  or nil,

                                max = isvec
                                    and vector.create(
                                      if isSidePos then props.last and 1 or 0 else ispos and 0 or -1,
                                      props.side and 0 or -math.huge
                                    )
                                  or nil,
                              })
                            else
                              cmp, updateText = NumberInput(scope, {
                                readonly = readonly,
                                value = value or scope:Value(0),

                                min = prop[3],
                                max = prop[4],
                              })
                            end

                            if value then
                              scope:Observer(value):onChange(function()
                                local v = peek(value)

                                if isvec then
                                  -- think smarter, not harder
                                  local pos = props.ctrlp[prop[1]]
                                  local vec = vector.create(pos.X.Scale, pos.Y.Scale)

                                  updateText(vec)
                                else
                                  updateText(v)
                                end
                              end)
                            end

                            return i,
                              Attribute(scope, {
                                index = i,
                                depth = 1,

                                readonly = readonly,
                                is_last = i == #properties,

                                name = prop[1],
                                background = ui_conf.colors.base,

                                component = cmp,
                              })
                          end),
                        },
                      }
                    end,
                  })
                end,
              },
              if not props.side
                then {
                  name = "Delete",
                  on_click = function()
                    local index = table.find(props.points, props.ctrlp)

                    if index then
                      table.remove(props.points, index)
                    end

                    props.map[props.ctrlp] = nil
                    props.path:RemoveControlPoint(index)

                    scope:doCleanup()
                  end,
                }
                else nil,
            },
          })
        end)
      end,

      [Children] = {
        scope:Round(0, 0.5),

        scope:OnHold(holding, function(_, mouseDelta)
          local size = props.parent.AbsoluteSize
          local origin = peek(movePos)

          local scaledUnclamped = (Vector2.new(origin.X.Scale, origin.Y.Scale) - mouseDelta / size)
          local scaled = scaledUnclamped
            :Min(Vector2.new(1, props.side and 1 or math.huge))
            :Max(Vector2.new(0, props.side and 0 or -math.huge))

          local p2 = UDim2.fromScale(scaledUnclamped.X, scaledUnclamped.Y)
          local p = UDim2.fromScale(props.side and (props.last and 1 or 0) or scaled.X, scaled.Y)

          movePos:set(p2)
          setPosition(p)

          props.on_change(true)
        end, nil, nil, true),
      },
    } :: ImageButton),

    TangentLine(tpos1),

    if tpos2 then TangentLine(tpos2) else nil,

    if not tpos2
      then TangentPoint(scope, props.last, pos, tpos1, props)
      else {
        TangentPoint(scope, true, pos, tpos1, props, mirrored),
        TangentPoint(scope, false, pos, tpos2, props, mirrored),
      },
  }
end

return Point
]]></ProtectedString>
							<string name="ScriptGuid">{7D86193E-D9FD-4D41-9687-1ADCD4A22ABA}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
