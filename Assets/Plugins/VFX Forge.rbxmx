                    name = "SyncPosition",
                    component = CheckboxInput(scope, {
                      value = Writer(e.meshes, "SyncPosition", false),
                    }),
                  },
                  {
                    name = "Enabled",
                    component = CheckboxInput(scope, {
                      value = Writer(e.meshes, "Enabled", false),
                    }),
                  },
                  {
                    name = "Rate",
                    component = NumberInput(scope, {
                      value = Writer(e.meshes, "Rate", 5),
                    }),
                  },
                },
              },
              {
                title = "Random Rotation",
                value = {
                  {
                    name = "AroundOrigin",
                    component = CheckboxInput(scope, {
                      value = Writer(e.meshes, "RotAroundOrigin", false),
                    }),
                  },
                  {
                    name = "Min",
                    component = VectorInput(scope, {
                      value = Writer(e.meshes, "MinInitRot", vector.zero),
