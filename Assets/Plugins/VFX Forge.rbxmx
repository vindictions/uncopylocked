			</Item>
			<Item class="ModuleScript" referent="RBX934B40F59E2E4AF59DF5B86810B6F234">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[--!nocheck
local plugin = script:FindFirstAncestorOfClass("Plugin")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local peek = Fusion.peek

local logger = require("./logger")

local storage = {}

local objects = {}
local registered = {}

function storage.getRegistered()
  return registered
end

function storage.getRegisteredKeys(id: string)
  return registered[id] or {}
end

function storage.syncObjId(id: string)
  local obj = objects[id]

  if obj then
    obj:sync()
  end
end

function storage:__index(key)
  if typeof(key) ~= "string" then
    logger.error(`attempt to index storage with {typeof(key)}`)
  end

  if string.match(key, "^_") then
    return rawget(self, key)
  elseif storage[key] then
    return storage[key]
  else
    return self._values[key]
  end
end

function storage:__newindex(key, value)
  if typeof(key) ~= "string" then
    logger.error(`attempt to index storage with {typeof(key)}`)
  end

  if string.match(key, "^_") then
    rawset(self, key, value)
  else
    local val = self._values[key]

    if typeof(val) == "table" and val.set and val.scope then
      logger.error("attempt to replace a value in storage")
    end

    if val then
      self._values[key] = value
      self:write(key)
    end
  end
end

local function deepSync(ref, src)
  local layer = table.clone(src)

  for a, b in ref do
    local l1 = src[a]

    if typeof(l1) == "table" and typeof(b) == "table" then
      -- only sync dicts
      if typeof(next(l1)) ~= "number" then
        l1 = deepSync(b, l1)
      end

      if not b.scope then
        layer[a] = l1
      else
        b:set(l1)
        layer[a] = b
      end
    elseif typeof(b) == "table" and b.scope then
      b:set(if l1 ~= nil then l1 else peek(b))
      layer[a] = b
    else
      layer[a] = if l1 ~= nil then l1 else b
    end
  end

  return layer
end

local function deepPeek(t)
  local layer = {}

  for k, v in t do
    v = peek(v)

    if typeof(v) == "table" then
      layer[k] = deepPeek(v)
    else
      layer[k] = v
    end
  end

  return layer
end

export type storage<T> = typeof(setmetatable({} :: T & typeof(storage), {}))

function storage.new<T>(scope: Fusion.Scope, id: string, values: T): storage<T>
  local self = setmetatable({}, storage)

  self._id = id
  self._reg = {}
  self._scope = scope
  self._values = values

  self._init_image = deepPeek(values)

  objects[id] = self
  registered[id] = self._reg

  self:sync()

  table.insert(scope, function()
    objects[self] = nil

    table.clear(self._values)
    table.freeze(self)

    self = nil
  end)

  return self
end

function storage:sync()
  if self._temp_scope then
    self._temp_scope:doCleanup()
  end

  table.clear(self._reg)

  local scope = self._scope:innerScope()

  self._temp_scope = scope

  for k, v in self._values do
    local name = `FORGE_{self._id}_{k}`
    local loaded = plugin:GetSetting(name)

    table.insert(self._reg, name)

    if loaded ~= nil then
      local data = loaded

      if typeof(loaded) == "table" then
        data = deepSync(peek(v), loaded)
      end

      if typeof(v) == "table" and v.scope then
        v:set(data)
      else
        self._values[k] = data
      end
    else
      local thing = self._init_image[k]

      if typeof(thing) == "table" then
        thing = deepSync(peek(v), thing)
      end

      if typeof(v) == "table" and v.scope then
        v:set(thing)
      else
        self._values[k] = thing
      end
    end

    local function descend(d)
      if typeof(d) == "table" and not d.scope then
        for _, v in d do
          descend(v)
        end
      elseif typeof(d) == "table" and d.scope then
        scope:Observer(d):onChange(function()
          self:write(k)
        end)
      end
    end

    descend(v)
  end
end

function storage:write(key: string)
  local v = self._values[key]

  if not v then
    logger.error("attempt to write to a non-existent key")
  end

  local function descend(t)
    if typeof(t) == "table" then
      if t.scope then
        return descend(peek(t))
      else
        local rel = {}

        for k, d in t do
          rel[k] = descend(d)
        end

        return rel
      end
    else
      return peek(t)
    end
  end

  local name = `FORGE_{self._id}_{key}`

  if not table.find(self._reg, name) then
    table.insert(self._reg, name)
  end

  plugin:SetSetting(name, descend(v))
end

return storage
]]></ProtectedString>
					<string name="ScriptGuid">{2BCC652F-A0C9-4478-BDF0-058FCFF37AEA}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">storage</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXE90A86AA772E4760AB9A3B001185A57A">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local plugin = script:FindFirstAncestorOfClass("Plugin")

local HttpService = game:GetService("HttpService")
local ChangeHistoryService = game:GetService("ChangeHistoryService")

local conf = require("../.conf")
local logger = require("./logger")
local symbols = require("../.symbols")
local emit_utility = require("./emit/mod/utility")

local utility = {}

function utility.restart()
  plugin:SetAttribute("GuiEnabled", false)

  game:GetService("RunService").Heartbeat:Once(function()
    plugin:SetAttribute("GuiEnabled", true)
  end)
end

function utility.getVerNum(ver: string)
  local n = string.split(ver, ".")

  local major = tonumber(n[1]) or 0
  local minor = tonumber(n[2]) or 0
  local patch = tonumber(n[3]) or 0

  return major * 1000 + minor * 100 + patch
end

function utility.try<R, A>(msg: string, func: (...A) -> ...R, ...: A): (boolean, ...R)
  local res = { xpcall(func, function(err)
    logger.warn(string.format(msg, err))
  end, ...) }

  return res[1], table.unpack(res, 2)
end

function utility.scaleAttribute(obj: Instance, factor: number, attr: string)
  local value = obj:GetAttribute(attr)

  if value ~= nil then
    if typeof(value) == "number" or typeof(value) == "Vector3" then
      obj:SetAttribute(attr, value * factor)
    elseif typeof(value) == "NumberRange" then
      obj:SetAttribute(attr, NumberRange.new(value.Min * factor, value.Max * factor))
    end
  end
end

function utility.findFirstClassWithTag(obj: Instance?, class: string, tag: string)
  if not obj or obj.Parent == game then
    return
  end

  if obj.ClassName == class and obj:HasTag(tag) then
    return obj
  else
    return utility.findFirstClassWithTag(obj.Parent, class, tag)
  end
end

function utility.getTimeAgo(diff: number)
  local denominators = {
    { "second", 1 },
    { "minute", 60 },
    { "hour", 60 },
    { "day", 24 },
    { "week", 7 },
    { "month", 4.348214 },
    { "year", 12 },
  }

  local prev = diff

  for i, d in denominators do
    local num = prev // d[2]

    if i ~= #denominators and num >= denominators[i + 1][2] then
      prev = num
      continue
    else
      return `{num} {d[1]}{num ~= 1 and "s" or ""} ago`
    end
  end
end

function utility.formatTime(seconds: number)
  seconds = math.floor(seconds)

  local minutes = seconds // 60
  local hours = minutes // 60
  local days = hours // 24

  -- it works
  return (if days > 0 then `{days}d ` else "")
    .. (if hours > 0 then `{hours % 24}h ` else "")
    .. (if minutes > 0 then `{minutes % 60}m ` else "")
    .. (if seconds > 0 then `{seconds % 60}s ` else "")
end

local remPrefixes = { "Left", "Right" }

local repPats = {
  ["Control"] = "Ctrl",
  ["Scroll"] = "Scr",
  ["Page"] = "Pg",
}

local repKeyMap = {
  -- keypad
  [266] = ".",
  [267] = "/",
  [268] = "*",
  [269] = "-",
  [270] = "+",

  -- short forms
  [32] = "Spc",
  [27] = "Esc",
  [127] = "Del",
}

function utility.getDisplayKey(key: string)
  local id = Enum.KeyCode[key].Value

  -- ascii characters
  if id >= 34 and id <= 126 then
    return string.char(id):upper()
    -- keypad number characters
  elseif id >= 256 and id < 265 then
    return string.char(id - 208)
  end

  local sub = repKeyMap[id]

  if sub then
    key = sub
  end

  for _, prefix in remPrefixes do
    if string.match(key, `^{prefix}.+`) then
      key = string.gsub(key, `^{prefix}`, "")
    end
  end

  for pat, rep in repPats do
    key = string.gsub(key, pat, rep)
  end

  return key
end

function utility.collectAttributeFromMany<T>(
  objs: { Instance },
  attribute: string,
  t: string,
  prop: boolean?,
  default: T?
): (T | boolean)?
  local value: T?
  local hasValidValue = false

  for _, obj in objs do
    local v = if prop then obj[attribute] else obj:GetAttribute(attribute)

    if typeof(v) ~= t then
      v = default
    end

    if not hasValidValue then
      value = v
      hasValidValue = true
    elseif v ~= value then
      return symbols.nil_symbol
    end
  end

  return value
end

function utility.collectTagFromMany<T>(objs: { Instance }, tag: string): (T | boolean)?
  if #objs == 0 then
    return false
  end

  for _, obj in objs do
    if not obj:HasTag(tag) then
      return false
    end
  end

  return true
end

function utility.collectMinMaxValuesFromMany(objs: { Instance }, key: string, attr: boolean?): (number?, number?)
  local min, max = math.huge, -math.huge

  for _, obj in objs do
    local v = if attr then obj:GetAttribute(key) else obj[key]
    local isRange = typeof(v) == "NumberRange"

    if typeof(v) ~= "number" and not isRange then
      continue
    end

    local a, b = v, v

    if isRange then
      a, b = v.Min, v.Max
    end

    if a < min then
      min = a
    end

    if b > max then
      max = b
    end
  end

  if min == math.huge then
    min = 1
  end

  if max == -math.huge then
    max = 1
  end

  return min, max
end

function utility.getEffects(from: { Instance })
  local beams = {}
  local trails = {}
  local beziers = {}
  local spin_models = {}

  local particles = {}
  local selectedParticleAncestors = {}

  local meshes = {}
  local mesh_decals = {}

  local shockwaves = {}
  local shockwave_rings = {}
  local shockwave_lines = {}
  local shockwave_debris = {}

  local screen_shakes = {}
  local screen_effects = {}

  local tween_properties = {}

  local firstSelectedParticle

  local function insert(t, obj)
    if table.find(t, obj) then
      return
    end

    table.insert(t, obj)
  end

  local function add(obj: Instance, desc: boolean?)
    if obj:IsDescendantOf(workspace.Terrain) then
      return
    end

    local aa = utility.findFirstClassWithTag(obj, "Attachment", emit_utility.BEZIER_TAG)
    local aa_added = table.find(beziers, aa)

    local bpts = aa and not aa_added and aa:FindFirstChild("Points")
    local bep = bpts and aa:FindFirstChildOfClass("Part")

    local sa = utility.findFirstClassWithTag(obj, "Attachment", emit_utility.SHOCKWAVE_TAG)

    if bpts and bpts:IsA("Attachment") and bep and not obj:IsDescendantOf(bep) and obj ~= bep then
      bep.CFrame = aa.WorldCFrame
      insert(beziers, aa)
      return true
    elseif sa and sa:IsA("Attachment") then
      if obj:IsA("Part") then
        obj.CFrame = sa.WorldCFrame

        local name = obj.Parent.Name

        if name == "Rings" then
          insert(shockwave_rings, obj)
        elseif name == "Lines" then
          insert(shockwave_lines, obj)
        elseif name == "Debris" then
          insert(shockwave_debris, obj)
        end
      elseif obj == sa then
        insert(shockwaves, obj)
      end
    elseif
      obj:IsA("BasePart")
      and not table.find(screen_effects, obj)
      and not table.find(meshes, obj.Parent)
      and not aa
    then
      local anc = obj:FindFirstAncestorOfClass("Model")

      if
        not anc
        or (
          anc:GetAttribute("SpinRotation") == vector.zero
          and anc:GetAttribute("Scale_Start") == 1
          and anc:GetAttribute("Scale_End") == 1
        )
      then
        insert(screen_effects, obj)
      end
    end

    if obj:IsA("ParticleEmitter") then
      if not desc and not firstSelectedParticle then
        firstSelectedParticle = obj
      end

      insert(particles, obj)
    elseif obj:IsA("Trail") then
      insert(trails, obj)
    elseif emit_utility.isMeshVFX(obj) then
      if obj.Parent:IsA("Attachment") then
        if obj.PrimaryPart == nil then
          obj.WorldPivot = obj.Parent.WorldCFrame
        else
          obj.PrimaryPart.PivotOffset = obj.PrimaryPart.CFrame:ToObjectSpace(obj.Parent.WorldCFrame)
        end
      end

      insert(meshes, obj)
    elseif obj:IsA("Model") then
      insert(spin_models, obj)
    elseif obj.Parent and obj:IsA("RayValue") and not obj.Parent:IsA("RayValue") then
      if obj:HasTag(emit_utility.SCREENSHAKE_TAG) then
        insert(screen_shakes, obj)
      elseif obj.Parent.Parent ~= game then
        insert(tween_properties, obj)
      end
    elseif obj:IsA("Decal") then
      local mesh = obj:FindFirstAncestorOfClass("Model")

      local function valid(i: Instance, name: string)
        local d = i:FindFirstChild(name)
        return if d and d:IsA("Decal") then d else nil
      end

      if emit_utility.isMeshVFX(mesh) then
        local decal = if obj.Parent.Name == "Start"
          then valid(mesh.End, obj.Name) and obj
          else obj.Parent.Name == "End" and valid(mesh.Start, obj.Name)

        if decal then
          insert(mesh_decals, decal)
        end
      end
    elseif obj:IsA("Beam") then
      insert(beams, obj)
    end

    return false
  end

  local function traverse(children: { Instance })
    for _, sel in children do
      if sel.Parent == game then
        continue
      end

      local root = children == from

      local prev = #particles
      local ignore = add(sel, not root)

      if not ignore then
        traverse(sel:GetChildren())
      end

      -- so you don't have useless descendant added/removed connections in studio <3
      if root and #particles ~= prev then
        table.insert(selectedParticleAncestors, sel)
      end
    end
  end

  traverse(from)

  local res = {
    beams = beams,
    trails = trails,
    meshes = meshes,
    beziers = beziers,
    particles = particles,
    mesh_decals = mesh_decals,
    spin_models = spin_models,
    screen_shakes = screen_shakes,
    screen_effects = screen_effects,
    tween_properties = tween_properties,

    shockwaves = shockwaves,
    shockwave_rings = shockwave_rings,
    shockwave_lines = shockwave_lines,
    shockwave_debris = shockwave_debris,
  }

  return res, firstSelectedParticle, selectedParticleAncestors
end

local ignoreProperties = { "Deprecated", "Hidden", "ReadOnly", "NotScriptable" }

do
  local class_map = {}

  local fetched = false
  local finished = false
  local fetching = false

  local prompting = false

  local threads = {}

  local function fetch(scope: any?)
    if fetched then
      return class_map
    end

    if not finished and fetching then
      table.insert(threads, coroutine.running())
      return coroutine.yield()
    end

    fetching = true

    local ok, raw_dump = pcall(function()
      local ver = HttpService:GetAsync("https://setup.rbxcdn.com/versionQTStudio")
      local dump = HttpService:GetAsync(`https://setup.rbxcdn.com/{ver}-API-Dump.json`)

      return dump
    end)

    if ok then
      local ok, dump = pcall(function()
        return HttpService:JSONDecode(raw_dump)
      end)

      if ok then
        local ignoreTags = { "Service", "Deprecated" }

        for _, class in dump.Classes do
          local valid = true

          if class.Tags then
            for _, tag in ignoreTags do
              if table.find(class.Tags, tag) then
                valid = false
                break
              end
            end
          end

          if valid then
            class_map[class.Name] = class

            fetched = true
            finished = true
          end
        end
      else
        logger.warn(`failed to decode api dump. property list for tween properties won't be available. error: {dump}`)
      end
    else
      if scope and conf.current_ctx and raw_dump:match("permission denied") then
        if not prompting then
          prompting = true

          conf.ctx:is(conf.current_ctx):during(function()
            scope:ErrorPrompt({
              text = "You need to allow HTTP requests for the 'setup.rbxcdn.com' domain in the 'Manage Plugins' window so the plugin can fetch API Dump data from an official Roblox domain and provide a dropdown with all tweenable properties.",

              anchor = Vector2.one * 0.5,
              position = Vector2.zero,

              precompute_height = true,

              on_close = function()
                prompting = false
              end,
            })
          end)
        end
      else
        logger.warn(`failed to fetch api dump. error: {raw_dump}`)
      end
    end

    finished = true
    fetching = false

    for _, thread in threads do
      task.spawn(thread, class_map)
    end

    table.clear(threads)

    return class_map
  end

  function utility.getProperties(obj: Instance, scope: any?)
    local map = fetch(scope)
    local class = map[obj.ClassName]

    if not class then
      return {}
    end

    local props = {}

    while class do
      for _, member in class.Members do
        if member.MemberType == "Property" and member.Name ~= "Parent" then
          local valid = true

          if member.Tags then
            for _, tag in ignoreProperties do
              if table.find(member.Tags, tag) then
                valid = false
                break
              end
            end
          end

          if valid then
            table.insert(props, member.Name)
          end
        end
      end

      if class.Superclass == "<<<ROOT>>>" then
        break
      end

      class = map[class.Superclass]
    end

    return props
  end
end

function utility.deepCopy(t: {})
  local res = {}

  for k, v in t do
    res[k] = typeof(v) == "table" and utility.deepCopy(v) or v
  end

  return res
end

function utility.cubicToTangent(a1: number, a2: number, b1: number, b2: number)
  return a1, -a2, -(1 - b1), 1 - b2
end

local function udim2num(t: { number }, u: UDim2)
  table.insert(t, u.X.Scale)
  table.insert(t, u.Y.Scale)
end

local function num2pt(t: { number }, o: number)
  return Path2DControlPoint.new(
    UDim2.fromScale(t[o + 2], t[o + 3]),
    UDim2.fromScale(t[o], t[o + 1]),
    UDim2.fromScale(t[o + 4], t[o + 5])
  )
end

function utility.pathToArray(points: { Path2DControlPoint })
  local array = {}

  for _, pt in points do
    udim2num(array, pt.LeftTangent)
    udim2num(array, pt.Position)
    udim2num(array, pt.RightTangent)
  end

  return array
end

function utility.arrayToPath(data: { number })
  local points = {}

  for i = 1, #data / 6 do
    table.insert(points, num2pt(data, 1 + (i - 1) * 6))
  end

  return points
end

function utility.pointsToArray(points: { vector })
  local array = { 0, 0 }

  local pts = math.ceil(#points / 3)

  for i = 1, pts do
    local offset = 1 + (i - 1) * 3

    local p1 = points[offset]

    table.insert(array, p1.x)
    table.insert(array, p1.y)

    if i ~= pts then
      local p2 = points[1 + i * 3]

      local t1 = points[offset + 1] - p1
      local t2 = points[offset + 2] - p2

      table.insert(array, t1.x)
      table.insert(array, t1.y)

      table.insert(array, t2.x)
      table.insert(array, t2.y)
    end
  end

  table.insert(array, 0)
  table.insert(array, 0)

  return array
end

local lastRecording
local lastRecordingType

function utility.initRecording(name: string, t: Enum.FinishRecordingOperation?, try: number?)
  if not try then
    try = 1
  end

  local recording = ChangeHistoryService:TryBeginRecording(name)

  if not recording then
    if lastRecording then
      ChangeHistoryService:FinishRecording(lastRecording, lastRecordingType or Enum.FinishRecordingOperation.Commit)
    end

    if try <= 5 then
      utility.initRecording(name, t, try + 1)
    else
      logger.warn("failed to begin a history recording after 5 tries")
    end

    return
  end

  lastRecording = recording
  lastRecordingType = t

  return recording
end

function utility.stopRecording(recording: string, ok: boolean)
  if ok and lastRecording == recording then
    ChangeHistoryService:FinishRecording(recording, lastRecordingType or Enum.FinishRecordingOperation.Commit)
  else
    ChangeHistoryService:FinishRecording(recording, Enum.FinishRecordingOperation.Cancel)
  end

  lastRecording = nil
end

function utility.record(name: string, func: () -> (), t: Enum.FinishRecordingOperation?, onFail: (() -> ())?)
  local rec = utility.initRecording(name)

  local ok = xpcall(func, function(err)
    logger.warn("recording function failed with error: " .. err)

    if onFail then
      task.spawn(onFail)
    end
  end)

  utility.stopRecording(rec, ok)
end

return utility
