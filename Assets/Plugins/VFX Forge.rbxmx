							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  text: Fusion.UsedAs<string>,
  first: boolean?,
  on_click: () -> (),
}

local function ButtonInput(scope: ui_types.scope, props: props)
  return scope:New "Frame" {
    BackgroundTransparency = 1,

    Size = scope:Computed(function(use)
      return UDim2.new(
        1,
        0,
        0,
        use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop) * 2 + (props.first and use(ui_conf.padding.prop) or 0)
      )
    end),

    [Children] = {
      scope:Padding(ui_conf.padding.prop, 0, ui_conf.padding.prop, ui_conf.padding.prop),

      scope:Hover "TextButton" {
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.fromScale(0, 1),

        Size = scope:Computed(function(use)
          return UDim2.new(1, 0, 1, -(props.first and use(ui_conf.padding.prop) or 0))
        end),

        Text = props.text,

        BackgroundColor3 = ui_conf.colors.primary,
        TextColor3 = ui_conf.colors.surface,

        FontFace = ui_conf.font,
        TextSize = ui_conf.text_sizes.mini,

        TextTruncate = Enum.TextTruncate.SplitWord,

        [OnEvent "MouseButton1Click"] = props.on_click,

        [Children] = {
          scope:Round(ui_conf.rounding.mini),
          scope:Padding(ui_conf.padding.side, 0),
        },
      },
    },
  }
end

return ButtonInput
]]></ProtectedString>
							<string name="ScriptGuid">{42FAEEE3-B764-4023-B962-98C80C1FC953}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
