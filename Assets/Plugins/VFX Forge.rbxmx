					<Item class="ModuleScript" referent="RBXA528D28E4D8542CAA36C58980BCE0324">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local peek = Fusion.peek

local ui_types = require("../../ui_types")

local Container = require("./Container")
local Attribute = require("./Attribute")

type property = {
  name: string,
  component: (scope: ui_types.scope) -> (),
}

type category = {
  title: string,
  value: { category } | { property },
}

type min = Fusion.Value<boolean>

export type tree = { category }

local function getCategoryMap(scope: ui_types.scope, tree: tree)
  local catMap: { [category]: { any } } = {}

  local function traverse(tree: tree, branch: { category }?)
    for i, v in tree do
      if v.value == nil then
        continue
      end

      catMap[v] = {
        branch and i == #branch or false,
      }

      traverse(v.value, v)
    end

    return catMap
  end

  return traverse(tree)
end

local function Categorize(
  _mainScope: ui_types.scope?,
  _tempScope: Fusion.Value<ui_types.scope>,
  tree: Fusion.UsedAs<tree | { property }>,
  wasLast: boolean?,
  depth: number?,
  catMap: { [category]: { any } }?
)
  if not depth then
    depth = 0
  end

  local minMapScope

  return (_mainScope and _mainScope or peek(_tempScope)):ForPairs(tree, function(_, _, i, entry)
    if depth == 0 and minMapScope ~= peek(_tempScope) then
      minMapScope = peek(_tempScope)
      catMap = getCategoryMap(peek(_tempScope), peek(tree))
    end

    local scope = peek(_tempScope)

    if entry.value ~= nil then
      if not catMap then
        error("category map is nil")
      end

      local cat = catMap[entry]

      local c = Container(scope, {
        index = i,
        depth = depth,
        title = entry.title,
        inner = _mainScope == nil,

        is_last = i == #tree,

        child = Categorize(nil, _tempScope, entry.value, i == #tree, depth + 1, catMap),

        above_samedepth_is_last = cat[3],
      })

      return i, c
    else
      local res = if entry.name
        then Attribute(scope, {
          index = i,
          depth = depth,
          name = entry.name,
          component = entry.component,
          is_last = depth == 2 and wasLast and i == #tree,
        })
        else entry.component

      return i, res
    end
  end)
end

return Categorize
]]></ProtectedString>
							<string name="ScriptGuid">{D57C7EDB-CBE4-4D2B-8ADC-E27009C9A9C2}</string>
