							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Children = Fusion.Children

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  title: string,
  depth: number,
  index: number,
  inner: boolean,

  is_last: boolean,

  child: Fusion.Child,

  above_samedepth_is_last: boolean?,
}

local function Container(scope: ui_types.scope, props: props)
  return scope:New "Frame" {
    BackgroundTransparency = 1,
    AutomaticSize = Enum.AutomaticSize.Y,

    Size = UDim2.fromScale(1, 0),

    ZIndex = props.inner and 0 or 10,

    [Children] = {
      if not props.inner
        then {
          scope:Round(ui_conf.rounding.base),
          scope:Stroke({
            size = 1,
            color = ui_conf.colors.overlay,
          }),
        }
        else nil,

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 0),

        ZIndex = 10,

        [Children] = {
          if props.inner
            then scope:New "Frame" {
              BackgroundColor3 = ui_conf.colors.highlight,

              AnchorPoint = Vector2.new(0.5, 0),
              Position = UDim2.fromScale(0.5, 0),

              Size = UDim2.new(1, 2, 0, 1),

              Visible = scope:Computed(function(use)
                return props.above_samedepth_is_last or (props.index == 1 and props.depth ~= 0)
              end),

              ZIndex = 10,
            }
            else nil,

          scope:New "Frame" {
            BackgroundColor3 = ui_conf.colors.overlay,

            AnchorPoint = Vector2.new(0, 1),
            Position = UDim2.fromScale(0, 1),

            Size = scope:Computed(function(use)
              return UDim2.new(1, 0, 0, use(ui_conf.rounding.base))
            end),
          },

          scope:New "Frame" {
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = ui_conf.colors.overlay,

            Size = scope:Computed(function(use)
              return UDim2.fromScale(1, 0)
            end),

            [Children] = {
              if not props.inner
                then scope:Round(ui_conf.rounding.base)
                else scope:New "UICorner" {
                  CornerRadius = scope:Computed(function(use)
                    return UDim.new(0, props.is_last or false and use(ui_conf.rounding.base) or 0)
                  end),
                },

              scope:Padding(
                scope:Computed(function(use)
                  local p = use(ui_conf.padding.prop)
                  return p + p * (math.max(props.depth, 1) - 1)
                end),
                ui_conf.padding.base,
                ui_conf.padding.side,
                ui_conf.padding.base
              ),

              scope:New "TextLabel" {
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,

                Size = UDim2.fromScale(1, 0),

                FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

                Text = props.title,

                TextTruncate = Enum.TextTruncate.SplitWord,
                TextXAlignment = Enum.TextXAlignment.Left,

                TextColor3 = ui_conf.colors.text,

                TextSize = scope:Computed(function(use)
                  return use(ui_conf.text_sizes.title_bar)
                    - props.depth * math.round(use(ui_conf.text_sizes.title_bar) * 0.1)
                end),
              },
            },
          },
        },
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 0),

        [Children] = {
          scope:New "Frame" {
            BackgroundColor3 = ui_conf.colors.surface,

            Size = scope:Computed(function(use)
              return UDim2.new(1, 0, 0, use(ui_conf.rounding.base))
            end),
          },

          scope:New "Frame" {
            AutomaticSize = Enum.AutomaticSize.Y,

            BackgroundColor3 = ui_conf.colors.surface,

            Size = UDim2.fromScale(1, 0),

            [Children] = {
              scope:Round(ui_conf.rounding.base),

              scope:New "UIListLayout" {
                SortOrder = Enum.SortOrder.LayoutOrder,
              },

              props.child,
            },
          },
        },
      },
    },
  }
end

return Container
]]></ProtectedString>
