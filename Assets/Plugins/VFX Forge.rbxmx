							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")
local AssetService = game:GetService("AssetService")

local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../../../.conf")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local logger = require("../../../lib/logger")

type props = {
  title: Fusion.UsedAs<string>,
  items: Fusion.UsedAs<{}>,

  apply: (flipbook: {}) -> (),
  delete: (flipbook: {}) -> (),

  query: Fusion.Value<string>,
}

local function List(scope: ui_types.scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create flipbook list because the ctx contextual is not set for current thread")
  end

  return scope:New "Frame" {
    AutomaticSize = Enum.AutomaticSize.Y,
    BackgroundTransparency = 1,

    Size = UDim2.fromScale(1, 0),

    Visible = scope:Computed(function(use)
      return #use(props.items) ~= 0
    end),

    [Children] = {
      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:New "TextLabel" {
        AutomaticSize = Enum.AutomaticSize.Y,

        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 0),

        Text = props.title,
        TextSize = ui_conf.text_sizes.title,

        FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

        TextTruncate = Enum.TextTruncate.SplitWord,
        TextXAlignment = Enum.TextXAlignment.Left,

        TextColor3 = ui_conf.colors.text,
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 0),

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            Wraps = true,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:ForPairs(props.items, function(_, scope, i, item)
            item.name = scope:Value(peek(item.name))
            item.duration = scope:Value(peek(item.duration))

            local playbackScope

            local hovered = scope:Value(false)
            local moreHovered = scope:Value(false)

            local currentImage = scope:Value(item.images[1])

            local moreButton: Fusion.Value<ImageButton?> = scope:Value(nil)

            scope:Observer(moreHovered):onChange(function()
              hovered:set(not peek(moreHovered))
            end)

            scope:Observer(hovered):onChange(function()
              if playbackScope then
                playbackScope:doCleanup()
                playbackScope = nil
              end

              if peek(hovered) then
                playbackScope = scope:innerScope()

                conf.ctx:is(ctx):during(function()
                  playbackScope:Tooltip({
                    near_padding = 14,

                    text = `{peek(item.name)} · {`{string
                      .format("%.2f", #item.images / peek(item.duration))
                      :gsub("0*$", "")
                      :gsub("%.$", "")} FPS`}`,
                  })
                end)

                local elapsed = 0

                table.insert(
                  playbackScope,
                  RunService.RenderStepped:Connect(function(deltaTime)
                    local alpha = math.clamp(elapsed / peek(item.duration), 0, 1)
                    local index = math.max(math.round(#item.images * alpha), 1)

                    currentImage:set(item.images[index])

                    if alpha ~= 1 then
                      elapsed += deltaTime
                    else
                      elapsed = 0
                    end
                  end)
                )
              else
                currentImage:set(item.images[1])
              end
            end)

            local size = 75

            return i,
              scope:Hover("ImageButton", nil, hovered) {
                BackgroundColor3 = ui_conf.colors.surface,

                Size = UDim2.fromOffset(size, size),

                [OnEvent "MouseButton1Click"] = function()
                  props.apply(item)
                end,

                LayoutOrder = scope:Computed(function(use)
                  local start, stop = string.find(use(item.name):lower(), use(props.query):lower(), 1, true)
                  return ((start and stop ~= 0) and start ^ 2 or 1000 + i)
                end),

                [Children] = {
                  scope:Round(ui_conf.rounding.base),
                  scope:Padding(ui_conf.padding.base),

                  scope:New "ImageLabel" {
                    BackgroundTransparency = 1,
                    Size = UDim2.fromScale(1, 1),

                    Image = scope:Computed(function(use)
                      return `{item._id and "rbxtemp://" or "rbxassetid://"}{use(currentImage)}`
                    end),

                    [Children] = {
                      scope:Round(ui_conf.rounding.base),
                      scope:Padding(ui_conf.padding.base),
                    },
                  },

                  moreButton:set(scope:Hover("ImageButton", nil, moreHovered) {
                    BackgroundTransparency = scope:Spring(
                      scope:Computed(function(use)
                        return (use(hovered) or use(moreHovered)) and 0 or 1
                      end),
                      30,
                      1
                    ),

                    BackgroundColor3 = ui_conf.colors.highlight,

                    Position = scope:Computed(function(use)
                      local pad = use(ui_conf.padding.base)
                      return UDim2.fromOffset(pad, pad)
                    end),

                    Size = scope:Computed(function(use)
                      local pad = use(ui_conf.padding.base) * 2
                      return UDim2.fromOffset(10 + pad, 10 + pad)
                    end),

                    [OnEvent "MouseButton1Click"] = function()
                      conf.ctx:is(ctx):during(function()
                        scope:Options({
                          float = Vector2.new(0, 1),

                          near_padding = ui_conf.padding.side,
                          near_element = peek(moreButton),

                          options = {
                            if item.upload
                              then {
                                name = "Upload",
                                on_click = function()
                                  local _, res = pcall(function()
                                    AssetService:CreateAssetAsync(RunService, 1)
                                  end)

                                  if typeof(res) == "string" and res:match("not available") then
                                    scope:ErrorPrompt({
                                      near_element = peek(moreButton),

                                      float = Vector2.new(0, 1),
                                      size = Vector2.new(350, 0),

                                      text = "CreateAssetAsync API is unavailable. It currently only works for plugins installed locally and when you have the 'CreateAssetAsync Lua API' beta feature enabled.",
                                    })
                                  else
                                    item.upload()
                                  end
                                end,
                              }
                              else nil,
                            {
                              name = "Properties",
                              on_click = function()
                                scope:Prompt({
                                  title = "Properties",

                                  float = Vector2.new(0, 1),

                                  near_padding = ui_conf.padding.side,
                                  near_element = peek(moreButton),

                                  size = Vector2.new(
                                    200,
                                    peek(ui_conf.text_sizes.mini) * 2
                                      + peek(ui_conf.padding.base) * 4
                                      + peek(ui_conf.padding.side) * 3
                                  ),

                                  child = function(scope)
                                    local nameValue: Fusion.Value<TextBox?> = scope:Value(nil)

                                    local fps = scope:Value(0)
                                    local ca, cb = false, false

                                    scope:Observer(item.duration):onBind(function()
                                      if ca then
                                        ca = false
                                        return
                                      end

                                      cb = true
                                      fps:set(#item.images / peek(item.duration))
                                      cb = false
                                    end)

                                    scope:Observer(fps):onChange(function()
                                      if cb then
                                        cb = false
                                        return
                                      end

                                      ca = true
                                      item.duration:set(1 / peek(fps) * #item.images)
                                      ca = false
                                    end)

                                    return scope:New "Frame" {
                                      BackgroundTransparency = 1,

                                      [Children] = {
                                        scope:Padding(ui_conf.padding.side),

                                        scope:New "UIListLayout" {
                                          SortOrder = Enum.SortOrder.LayoutOrder,

                                          Padding = scope:Computed(function(use)
                                            return UDim.new(0, use(ui_conf.padding.side))
                                          end),
                                        },

                                        scope:Hover "Frame" {
                                          BackgroundColor3 = ui_conf.colors.surface,

                                          Size = scope:Computed(function(use)
                                            return UDim2.new(
                                              1,
                                              0,
                                              0,
                                              use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
                                            )
                                          end),

                                          [Children] = {
                                            scope:Round(ui_conf.rounding.mini),

                                            nameValue:set(scope:New "TextBox" {
                                              BackgroundTransparency = 1,

                                              AnchorPoint = Vector2.new(0.5, 0),
                                              Position = UDim2.fromScale(0.5, 0),

                                              Size = scope:Computed(function(use)
                                                return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
                                              end),

                                              FontFace = ui_conf.font,

                                              Text = peek(item.name),
                                              PlaceholderText = "name",

                                              TextColor3 = ui_conf.colors.text,
                                              PlaceholderColor3 = ui_conf.colors.muted,

                                              TextSize = ui_conf.text_sizes.mini,

                                              ClipsDescendants = true,

                                              [OnEvent "Focused"] = function()
                                                local input = peek(nameValue)

                                                if input then
                                                  input.CursorPosition = #input.Text + 1
                                                  input.SelectionStart = 0
                                                end
                                              end,

                                              [OnEvent "FocusLost"] = function(enter)
                                                if enter then
                                                  local bar = peek(nameValue)

                                                  if not bar or bar.Text == "" then
                                                    return
                                                  end

                                                  item.name:set(bar.Text)
                                                end
                                              end,
                                            } :: TextBox),
                                          },
                                        },

                                        scope:New "Frame" {
                                          BackgroundTransparency = 1,

                                          Size = scope:Computed(function(use)
                                            return UDim2.new(
                                              1,
                                              0,
                                              0,
                                              use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
                                            )
                                          end),

                                          [Children] = {
                                            scope:New "UIListLayout" {
                                              SortOrder = Enum.SortOrder.LayoutOrder,
                                              FillDirection = Enum.FillDirection.Horizontal,

                                              HorizontalFlex = Enum.UIFlexAlignment.Fill,

                                              Padding = scope:Computed(function(use)
                                                return UDim.new(0, use(ui_conf.padding.side))
                                              end),
                                            },

                                            scope:NumberField({
                                              value = item.duration,

                                              min = 0.001,
                                              max = math.huge,

                                              suffix = "s",
                                            }),

                                            scope:NumberField({
                                              value = fps,

                                              min = 0.001,
                                              max = math.huge,

                                              suffix = " FPS",
                                            }),
                                          },
                                        },
                                      },
                                    }
                                  end,
                                })
                              end,
                            },
                            {
                              name = "Delete",
                              on_click = function()
                                props.delete(item)
                              end,
                            },
                          },
                        })
                      end)
                    end,

                    [Children] = {
                      scope:Round(ui_conf.rounding.nano),

                      scope:New "ImageLabel" {
                        BackgroundTransparency = 1,

                        AnchorPoint = Vector2.one * 0.5,
                        Position = UDim2.fromScale(0.5, 0.5),

                        Size = UDim2.fromOffset(10, 2),

                        Image = "rbxassetid://108937556176877",
                        ImageColor3 = ui_conf.colors.subtle,

                        ImageTransparency = scope:Spring(
                          scope:Computed(function(use)
                            return (use(hovered) or use(moreHovered)) and 0 or 1
                          end),
                          30,
                          1
                        ),
                      },
                    },
                  } :: ImageButton),
                },
              }
          end),
        },
      },
    },
  }
end

return List
]]></ProtectedString>
