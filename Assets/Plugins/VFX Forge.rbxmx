						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX44FC8EADFF55477EBA4A07CCBC9EC284">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local utility = require("../../lib/utility")

-- stylua: ignore
local presets = {
  { "Line",         0, 0, 1, 1 },

  { "Linear",       0.250, 0.250, 0.750, 0.750 },
  { "Ease",         0.250, 0.100, 0.250, 1.000 },
  { "Ease In",      0.420, 0.000, 1.000, 1.000 },
  { "Ease Out",     0.000, 0.000, 0.580, 1.000 },
  { "Ease In Out",  0.420, 0.000, 0.580, 1.000 },

  { "Out Quad",     0.250, 0.460, 0.450, 0.940 },
  { "Out Cubic",    0.215, 0.610, 0.355, 1.000 },
  { "Out Quart",    0.165, 0.840, 0.440, 1.000 },
  { "Out Quint",    0.230, 1.000, 0.320, 1.000 },
  { "Out Sine",     0.390, 0.575, 0.565, 1.000 },
  { "Out Expo",     0.190, 1.000, 0.220, 1.000 },
  { "Out Circ",     0.075, 0.820, 0.165, 1.000 },

  { "In Quad",      0.550, 0.085, 0.680, 0.530 },
  { "In Cubic",     0.550, 0.055, 0.675, 0.190 },
  { "In Quart",     0.895, 0.030, 0.685, 0.220 },
  { "In Quint",     0.755, 0.050, 0.855, 0.060 },
  { "In Sine",      0.470, 0.000, 0.745, 0.715 },
  { "In Expo",      0.950, 0.050, 0.795, 0.035 },
  { "In Circ",      0.600, 0.040, 0.980, 0.335 },

  { "InOut Quad",   0.455, 0.030, 0.515, 0.955 },
  { "InOut Cubic",  0.645, 0.045, 0.355, 1.000 },
  { "InOut Quart",  0.770, 0.000, 0.175, 1.000 },
  { "InOut Quint",  0.860, 0.000, 0.070, 1.000 },
  { "InOut Sine",   0.445, 0.050, 0.550, 0.950 },
  { "InOut Expo",   1.000, 0.000, 0.000, 1.000 },
  { "InOut Circ",   0.785, 0.135, 0.150, 0.860 },
}

for i, set in presets do
  local x1, y1, x2, y2 = utility.cubicToTangent(set[2], set[3], set[4], set[5])
  presets[i] = { set[1], { 0, 0, 0, 1, x1, y1, x2, y2, 1, 0, 0, 0 } }
end

return presets
]]></ProtectedString>
						<string name="ScriptGuid">{483AF3C7-AF71-4662-BBDF-07750564AB01}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">presets</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBXB4F2EE703F0C489181428D5A6EEC882D">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local ui_types = require(script.Parent.Parent.ui_types)

export type point_props = {
  side: boolean?,
  last: boolean?,

  path: Path2D,
  parent: GuiObject,

  ctrlp: Path2DControlPoint,
  points: { Path2DControlPoint },

  map: { [Path2DControlPoint]: { (offset: UDim2?) -> () } },
  umap: { [Path2DControlPoint]: (offset: UDim2?) -> () },

  on_change: () -> (),
  get_time_value: () -> (),
  update_tangents: (point: Path2DControlPoint?, left: boolean, right: boolean) -> (),

  effect: Fusion.Value<string?>,
  tooltip_text: (scope: ui_types.scope, pos: Fusion.Value<UDim2>) -> (Fusion.Use) -> string,
}

export type input = {
  {
    name: string,
    value: Fusion.Value<number>,

    min: number,
    max: number,

    int: boolean?,
  }
}

return nil
]]></ProtectedString>
