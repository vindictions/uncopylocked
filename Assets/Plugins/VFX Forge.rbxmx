				<Item class="ModuleScript" referent="RBX3C38D9D930F541A788BD50E31E1302E1">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local handlers = require("./handlers")
local symbols = require("../../.symbols")
local utility = require("../../lib/utility")

return {
  particles = {
    {
      name = "Transparency",
      inputs = {
        {
          name = "Start",
          default = 0,

          min = 0,
          max = 1,
        },
        {
          name = "End",
          default = 1,

          min = 0,
          max = 1,
        },
        {
          name = "Envelope",
          default = 0,

          min = 0,
          max = math.huge,
        },
        {
          name = "Smoothness",
          default = 1,

          min = 0,
          max = 1,
        },
      },

      handle_inputs = true,

      handler = handlers.NumberSequence("Transparency", 0, 1),
    },
    {
      name = "Size",
      inputs = {
        {
          name = "Start",
          default = 0,

          min = 0,
          max = math.huge,
        },
        {
          name = "End",
          default = 1,

          min = 0,
          max = math.huge,
        },
        {
          name = "Envelope",
          default = 0,

          min = 0,
          max = math.huge,
        },
        {
          name = "Smoothness",
          default = 1,

          min = 0,
          max = 1,
        },
      },

      handle_inputs = true,

      handler = handlers.NumberSequence("Size", 0, math.huge),
    },
    {
      name = "Squash",
      inputs = {
        {
          name = "Start",
          default = 0,

          min = -math.huge,
          max = math.huge,
        },
        {
          name = "End",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
        {
          name = "Envelope",
          default = 0,

          min = 0,
          max = math.huge,
        },
        {
          name = "Smoothness",
          default = 1,

          min = 0,
          max = 1,
        },
      },

      handle_inputs = true,

      handler = handlers.NumberSequence("Squash", -math.huge, math.huge),
    },
    {
      name = "TimeScale",
      inputs = {
        {
          name = "Duration",
          default = 0.1,

          min = 0,
          max = math.huge,
        },
        {
          name = "Start",
          default = function(objs)
            return utility.collectAttributeFromMany(objs, "TimeScale", "number", true) or 1
          end,

          min = 0,
          max = 1,
        },
        {
          name = "End",
          default = function(objs)
            return utility.collectAttributeFromMany(objs, "TimeScale", "number", true) or 1
          end,

          min = 0,
          max = 1,
        },
      },

      handler = handlers.Attribute("TimeScale_Curve"),
    },
  },

  beams = {
    {
      name = "Transparency",
      expand = {
        {
          name = "Base",
          inputs = {
            {
              name = "Start",
              default = 0,

              min = 0,
              max = 1,
            },
            {
              name = "End",
              default = 1,

              min = 0,
              max = 1,
            },
            {
              name = "Envelope",
              default = 0,

              min = 0,
              max = math.huge,
            },
            {
              name = "Smoothness",
              default = 1,

              min = 0,
              max = 1,
            },
          },

          handle_inputs = true,

          handler = handlers.NumberSequence("Transparency", 0, 1, "Transparency_Base"),
        },
        {
          name = "Scale",
          inputs = {
            {
              name = "Start",
              default = 1,

              min = 0,
              max = math.huge,
            },
            {
              name = "End",
              default = 1,

              min = 0,
              max = math.huge,
            },
          },

          handler = handlers.Attribute("Transparency_Scale_Curve"),
        },
      },
    },
    {
      name = "Width0",
      inputs = {
        {
          name = "Start",
          default = function(objs)
            return utility.collectAttributeFromMany(objs, "Width0", "number", true) or 0
          end,

          min = 0,
          max = math.huge,
        },
        {
          name = "End",
          default = function(objs)
            return utility.collectAttributeFromMany(objs, "Width0", "number", true) or 0
          end,

          min = 0,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("Width0_Curve"),
    },
    {
      name = "Width1",
      inputs = {
        {
          name = "Start",
          default = function(objs)
            return utility.collectAttributeFromMany(objs, "Width1", "number", true) or 0
          end,

          min = 0,
          max = math.huge,
        },
        {
          name = "End",
          default = function(objs)
            return utility.collectAttributeFromMany(objs, "Width1", "number", true) or 0
          end,

          min = 0,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("Width1_Curve"),
    },
    {
      name = "Speed",
      inputs = {
        {
          name = "Duration",
          default = 0.1,

          min = 0,
          max = math.huge,
        },
        {
          name = "Start",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
        {
          name = "End",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("Speed_Curve"),
    },
  },

  meshes = coroutine.wrap(function()
    local function getPartTp(objs: { Instance })
      local partDefaultTp = 0

      do
        local hadNoDecal = false

        for _, m in objs do
          local start = m:FindFirstChild("Start")
          local decal = start and start:FindFirstChildOfClass("Decal")

          if decal and not hadNoDecal then
            partDefaultTp = 1
          elseif partDefaultTp == 1 or hadNoDecal then
            partDefaultTp = symbols.nil_symbol
            break
          else
            hadNoDecal = true
          end
        end
      end

      return partDefaultTp
    end

    return {
      {
        name = "Part",
        expand = {
          {
            name = "CFrame",
            inputs = nil,

            handler = handlers.Attribute("Part_CFrame_Curve"),
          },
          {
            name = "Transparency",
            inputs = {
              {
                name = "Start",
                default = getPartTp,

                min = 0,
                max = 1,
              },
              {
                name = "End",
                default = getPartTp,

                min = 0,
                max = 1,
              },
            },

            handler = handlers.Attribute("Part_Transparency_Curve"),
          },
          {
            name = "Size",
            inputs = nil,

            handler = handlers.Attribute("Part_Size_Curve"),
          },
          {
            name = "RotSpeed",
            inputs = {
              {
                name = "Start",
                default = NumberRange.new(0, 0),
              },
              {
                name = "End",
                default = NumberRange.new(0, 0),
              },
            },

            handler = handlers.Attribute("RotSpeed_Curve"),
          },
        },
      },
      {
        name = "Mesh",
        expand = {
          {
            name = "Scale",
            inputs = nil,

            handler = handlers.Attribute("Mesh_Scale_Curve"),
          },
        },
      },
      {
        name = "Speed",
        inputs = {
          {
            name = "Duration",
            default = 0.1,

            min = 0,
            max = math.huge,
          },
          {
            name = "Start",
            default = 1,

            min = -math.huge,
            max = math.huge,
          },
          {
            name = "End",
            default = 1,

            min = -math.huge,
            max = math.huge,
          },
        },

        handler = handlers.Attribute("Speed_Curve"),
      },
    }
  end)(),

  mesh_decals = {
    {
      name = "Transparency",
      inputs = {
        {
          name = "Start",
          default = 0,

          min = 0,
          max = 1,
        },
        {
          name = "End",
          default = 1,

          min = 0,
          max = 1,
        },
      },

      handler = handlers.Attribute("Transparency_Curve"),
    },
    {
      name = "Color",
      inputs = nil,

      handler = handlers.Attribute("Color_Curve"),
    },
    function(objs)
      local hasFlipbook = false

      for _, obj in objs do
        if obj:GetAttribute("FlipbookEnabled") then
          hasFlipbook = true
          break
        end
      end

      return if hasFlipbook
        then {
          name = "Flipbook",
          expand = {
            {
              name = "Change",
              inputs = {
                {
                  name = "Duration",
                  default = 1,

                  min = 0,
                  max = math.huge,
                },
              },

              handler = handlers.Attribute("Flipbook_Change_Curve"),
            },
          },
        }
        else nil
    end,
  },

  spin_models = {
    {
      name = "Scale",
      inputs = {
        {
          name = "Start",
          default = 1,

          min = 0.001,
          max = math.huge,
        },
        {
          name = "End",
          default = 1,

          min = 0.001,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("Scale_Curve"),
    },
    {
      name = "SpinSpeed",
      inputs = {
        {
          name = "Duration",
          default = 0.1,

          min = 0,
          max = math.huge,
        },
        {
          name = "Start",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
        {
          name = "End",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("SpinSpeed_Curve"),
    },
  },

  beziers = {
    {
      name = "Easing",
      inputs = nil,

      handler = handlers.Attribute("Easing_Curve"),
    },
    {
      name = "RotSpeed",
      inputs = {
        {
          name = "Start",
          default = NumberRange.new(0, 0),
        },
        {
          name = "End",
          default = NumberRange.new(0, 0),
        },
      },

      handler = handlers.Attribute("RotSpeed_Curve"),
    },
    {
      name = "Speed",
      inputs = {
        {
          name = "Duration",
          default = 0.1,

          min = 0,
          max = math.huge,
        },
        {
          name = "Start",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
        {
          name = "End",
          default = 1,

          min = -math.huge,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("Speed_Curve"),
    },
  },

  shockwave_debris = {
    {
      name = "Size",
      inputs = {
        {
          name = "Duration",
          default = 0.5,

          min = 0,
          max = math.huge,
        },
      },

      handler = handlers.Attribute("Size_Curve"),
    },
    {
      name = "Transparency",
      inputs = {
        {
          name = "Duration",
          default = 0.5,

          min = 0,
          max = math.huge,
        },
        {
          name = "Start",
          default = 0,

          min = 0,
          max = 1,
        },
        {
          name = "End",
