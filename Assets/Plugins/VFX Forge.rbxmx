							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  text: Fusion.UsedAs<string>,

  size: Fusion.UsedAs<number>,
  weight: Fusion.UsedAs<Enum.FontWeight>?,
}

local function Title(scope: ui_types.scope, props: props)
  return scope:New "TextLabel" {
    AutomaticSize = Enum.AutomaticSize.Y,

    BackgroundTransparency = 1,
    Size = UDim2.fromScale(1, 0),

    Text = props.text,
    TextSize = props.size,

    FontFace = scope:Font(ui_conf.font, props.weight or Enum.FontWeight.SemiBold),

    TextTruncate = Enum.TextTruncate.SplitWord,
    TextXAlignment = Enum.TextXAlignment.Left,

    TextColor3 = ui_conf.colors.text,
  }
end

return Title
]]></ProtectedString>
