			<Item class="ModuleScript" referent="RBX161C683B438940058961E8284EB1EB7B">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local ui_theme = require("./ui_theme")

local conf = {}

conf.colors = {} :: ui_theme.values

conf.scale = 1
conf.hover_scale = 1

conf.font = Font.fromId(16658221428)

conf.display_order = 1000

conf.text_sizes = {
  nano = 15,
  mini = 16,
  base = 18,

  title_bar = 18,
  title = 20,

  special = 24,
}

conf.rounding = {
  base = 8,
  mini = 6,
  nano = 4,
}

conf.padding = {
  resize = 4,

  base = 4,
  prop = 6,
  side = 8,
}

function conf.setup(scope: Fusion.Scope)
  ui_theme.setup(scope, conf)

  table.insert(scope, function()
    table.clear(conf.colors)
  end)
end

return conf
]]></ProtectedString>
