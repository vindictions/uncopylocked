type props = {}

type banner_props = {
  id: string,
  text: string,
}

local function UpdateLog(scope: ui_types.scope, props: props)
  local boxSize = scope:Value(Vector2.zero)
  local scaledContentSize = scope:Value(Vector2.zero)

  local contentSize = scope:Computed(function(use)
    return use(scaledContentSize) / use(ui_conf.scale)
  end)

  local bounds = scope:Computed(function(use, scope)
    local size = use(boxSize)

    local params = scope:New "GetTextBoundsParams" {
      Text = LICENSE,
      Font = use(ui_conf.font),
      Size = use(ui_conf.text_sizes.base),
      Width = size.X - use(ui_conf.padding.side) * 2,
    }

    return TextService:GetTextBoundsAsync(params)
  end)

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UISizeConstraint" {
        MaxSize = scope:Computed(function(use)
          return Vector2.new(math.huge, use(contentSize).Y + use(ui_conf.padding.side) * 2)
        end),
      },

      scope:Hover "TextButton" {
        AutomaticSize = Enum.AutomaticSize.Y,

        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.fromScale(0, 1),

        Size = UDim2.fromScale(1, 0),

        Text = "I agree to these Terms and Conditions",

        BackgroundColor3 = ui_conf.colors.primary,
        TextColor3 = ui_conf.colors.base,

        FontFace = ui_conf.font,
        TextSize = ui_conf.text_sizes.mini,

        TextTruncate = Enum.TextTruncate.SplitWord,

        [OnEvent "MouseButton1Click"] = function()
          local function add()
            local module = plugin.VFX.lib.emit:Clone()
            module.Name = "EmitModule"
            module.Parent = ReplicatedStorage

            Selection:Set({ module })
          end

          utility.record("import emit module", add, nil, function()
            utility.record("import emit module", add)
          end)

          scope:doCleanup()
        end,

        [Children] = {
          scope:Round(ui_conf.rounding.mini),
          scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(
            1,
            0,
            1,
            -(use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2 + use(ui_conf.padding.side))
          )
        end),

        [Children] = {
          scope:Scrollable({
            content_size = contentSize,

            padding = 1,

            children = {
              scope:New "UIListLayout" {
                SortOrder = Enum.SortOrder.LayoutOrder,

                Padding = scope:Computed(function(use)
                  return UDim.new(0, use(ui_conf.padding.side))
                end),

                [Out "AbsoluteContentSize"] = scaledContentSize,
              },

              scope:Hover "TextBox" {
                BackgroundColor3 = ui_conf.colors.surface,

                Size = scope:Computed(function(use)
                  return UDim2.new(1, 0, 0, use(bounds).Y)
                end),

                FontFace = ui_conf.font,
                TextSize = ui_conf.text_sizes.base,

                Text = LICENSE,
                TextColor3 = ui_conf.colors.text,

                TextXAlignment = Enum.TextXAlignment.Left,

                TextWrapped = true,
                TextEditable = false,

                [Out "AbsoluteSize"] = boxSize,

                [Children] = {
                  scope:Round(ui_conf.rounding.base),
                  scope:Padding(ui_conf.padding.side),
                },
              },
            },
          }),
        },
      },
    },
  }
end

return UpdateLog
]]></ProtectedString>
