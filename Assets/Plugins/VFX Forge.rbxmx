						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX124A098238244447910DEEB4814D4A4C">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Children = Fusion.Children
local peek = Fusion.peek

local types = require("../types")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local utility = require("../../../lib/utility")

type props = types.point_props

local function relUDim2Clamp(p: UDim2, min: number, max: number)
  return UDim2.fromScale(math.clamp(p.X.Scale, min, max), p.Y.Scale)
end

local function TangentPoint(
  scope: ui_types.scope,
  isleft: boolean,
  origin: Fusion.Value<UDim2>,
  pos: Fusion.Value<UDim2>,
  props: props,
  mirrored: Fusion.Value<boolean>?
)
  local holding = scope:Value(false)
  local hovered = scope:Value(false)

  local function setTangent(offset: UDim2?)
    local points = props.points
    local index = table.find(points, props.ctrlp)

    if isleft then
      local prevPoint = points[index - 1]
      local delta = prevPoint and math.abs(prevPoint.Position.X.Scale - props.ctrlp.Position.X.Scale) or 1

      local new = relUDim2Clamp(offset or props.ctrlp.LeftTangent, -1 * delta, 0)

      if props.ctrlp.LeftTangent ~= new then
        task.defer(function()
          pos:set(new)
        end)

        props.ctrlp.LeftTangent = new
      end
    else
      local nextPoint = points[index + 1]
      local delta = nextPoint and math.abs(nextPoint.Position.X.Scale - props.ctrlp.Position.X.Scale) or 1

      local new = relUDim2Clamp(offset or props.ctrlp.RightTangent, 0, 1 * delta)

      if props.ctrlp.RightTangent ~= new then
        task.defer(function()
          pos:set(new)
        end)

        props.ctrlp.RightTangent = new
      end
    end

    pcall(function()
      props.path:UpdateControlPoint(index, props.ctrlp)
    end)
  end

  do
    local list = props.map[props.ctrlp]

    if not list then
      list = {}
      props.map[props.ctrlp] = list
    end

    list[isleft and 1 or 2] = setTangent
  end

  local movePos = scope:Value(peek(pos))
  local recording: string?

  scope:Observer(holding):onChange(function()
    movePos:set(peek(pos))

    if peek(holding) and peek(props.effect) ~= nil and not recording then
      recording = utility.initRecording("forge_writeCurve")
    elseif recording then
      utility.stopRecording(recording, true)
      recording = nil
    end
  end)

  return scope:Hover("ImageButton", nil, hovered) {
    Parent = props.parent,
    BackgroundColor3 = ui_conf.colors.primary,

    AnchorPoint = Vector2.new(0.5, 0.5),

    Rotation = 45,
    ZIndex = 10,

    Position = scope:Computed(function(use)
      return use(origin) + use(pos)
    end),

    Size = scope:Computed(function(use)
      local state = use(hovered)
      return UDim2.fromOffset(state and 14 or 10, state and 14 or 10)
    end),

    Visible = scope:Computed(function(use)
      return use(pos) ~= UDim2.new()
    end),

    [Children] = {
      scope:Round(0, 0.1),
      scope:OnHold(holding, function(_, mouseDelta)
        local size = props.parent.AbsoluteSize
        local origin = peek(movePos)

        local scaled = (Vector2.new(origin.X.Scale, origin.Y.Scale) - mouseDelta / size)
        local p = UDim2.fromScale(scaled.X, scaled.Y)

        movePos:set(p)
        setTangent(p)

        if peek(mirrored) then
          props.map[props.ctrlp][isleft and 2 or 1](-p)
        end

        props.on_change(true)
      end),
    },
  }
end

return TangentPoint
]]></ProtectedString>
							<string name="ScriptGuid">{024CD130-0FDC-43E9-9DB8-132C6CEA2363}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">TangentPoint</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
					</Item>
				</Item>
				<Item class="ModuleScript" referent="RBXFC5025F16F564599A93FF9B8D338C82D">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local lerp = require("../../lib/lerp")
local logger = require("../../lib/logger")
local emit_utility = require("../../lib/emit/mod/utility")

local handlers = {}

local function perpendicularDistance(v: vector, a: vector, b: vector)
  local ab = b - a
  local av = v - a

  local i = vector.dot(av, ab) / (ab.x ^ 2 + ab.y ^ 2)
  i = math.clamp(i, 0, 1)

  local p = a + i * ab

  return vector.magnitude(v - p)
end

local function rdp(points: { vector }, epsilon: number)
  local dmax = 0
  local index = 0

  local len = #points

  local first = points[1]
  local last = points[len]

  for i = 2, len - 1 do
    local d = perpendicularDistance(points[i], first, last)

    if d > dmax then
      index = i
      dmax = d
    end
  end

  if dmax > epsilon then
    local left = rdp({ table.unpack(points, 1, index) }, epsilon)
    local right = rdp({ table.unpack(points, index, len) }, epsilon)

    table.remove(right, 1)

    for _, pt in ipairs(right) do
      table.insert(left, pt)
    end

    return left
  else
    return { first, last }
  end
end

function handlers.NumberSequence(prop: string, min: number, max: number, prefix: string?)
  return function(obj: Instance, path: Path2D, inputs: { [string]: number }, seq: NumberSequence?)
    if not seq then
      local startSize = inputs.Start or 0
      local endSize = inputs.End or 1

      local smoothness = inputs.Smoothness or 1
      local envelope = inputs.Envelope or 0

      local samples = {}

      for i = 0, 19 do
        local pos = path:GetPositionOnCurveArcLength(i / 19)
        local alpha = if i == 0 then 0 else if i == 19 then 1 else nil

        -- stylua: ignore
        table.insert(
          samples,
          vector.create(alpha or pos.X.Scale, math.clamp(lerp.linear(startSize, endSize, 1 - pos.Y.Scale), min, max))
        )
      end

      local keypoints = {}

      for _, p in rdp(samples, lerp.linear(0.05, 0.001, math.clamp(smoothness, 0, 1))) do
        table.insert(keypoints, NumberSequenceKeypoint.new(p.x, p.y, envelope))
      end

      seq = NumberSequence.new(keypoints)
    end

    obj:SetAttribute(
      `{prefix and `{prefix}_` or ""}{prop}_Curve`,
      buffer.tostring(emit_utility.serializePath(path:GetControlPoints()))
    )

    local ok, res = pcall(function()
      obj[prop] = seq
    end)

    if not ok then
      logger.warn(`NumberSequence handler for '{prop}' failed to set property with error: {res}`)
    end

    return seq
  end
end

function handlers.Attribute(attr: string)
  return function(obj: Instance, path: Path2D, inputs: { [string]: number })
    obj:SetAttribute(attr, buffer.tostring(emit_utility.serializePath(path:GetControlPoints())))
  end
end

return handlers
]]></ProtectedString>
						<string name="ScriptGuid">{0DAC36C0-DA63-409E-9859-6CE6CCA2D4CD}</string>
