					<ProtectedString name="Source"><![CDATA[local lerp = {}

function lerp.linear(a: number, b: number, t: number)
  return a + (b - a) * t
end

return lerp
]]></ProtectedString>
					<string name="ScriptGuid">{2AC17E44-91E6-441A-9A4C-47FD5786222F}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">lerp</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX90CCAF0CE4C9438D946973EC60A148F5">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local function msg(...: string)
  return `[VFX Forge]: {table.concat({ ... }, " ")}`
end

local warned = {}

local logger = {}

function logger.error(...)
  error(msg(...))
end

function logger.warn(...)
  warn(msg(...))
  warn(msg(debug.traceback("stack trace:")))
end

function logger.warnOnce(uid: number, ...)
  if table.find(warned, uid) then
    return
  end

  table.insert(warned, uid)

  warn(msg(...))
end

function logger.info(...)
  print(msg(...))
end

return logger
]]></ProtectedString>
