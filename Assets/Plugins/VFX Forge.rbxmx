					<Item class="ModuleScript" referent="RBX6493E166B6C6478FB0E6BDD82D3FCEF1">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../../../.conf")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local utility = require("../../../lib/utility")

type props = {
  name: string,
  value: Fusion.Value<{ string }>,
}

local function Keybind(scope: ui_types.scope, props: props)
  local progress = scope:Value(0)
  local bounds = scope:Value(Vector2.zero)

  local dir = 1
  local size = 100
  local elapsed = 0

  local stop = false

  local recordScope

  local function hold()
    stop = true

    task.delay(1, function()
      stop = false
    end)
  end

  table.insert(
    scope,
    RunService.RenderStepped:Connect(function(deltaTime)
      local width = peek(bounds).X

      if stop or width <= size then
        return
      end

      local alpha = math.clamp(elapsed / width, 0, 1)

      if alpha == 0 then
        dir = 1
        hold()
      elseif alpha == 1 then
        dir = -1
        hold()
      end

      progress:set(alpha)

      elapsed += deltaTime * 100 * dir
    end)
  )

  return scope:New "Frame" {
    BackgroundColor3 = ui_conf.colors.surface,

    Size = scope:Computed(function(use)
      return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.base) + use(ui_conf.padding.base) * 3)
    end),

    [Children] = {
      scope:Round(ui_conf.rounding.mini),
      scope:Padding(ui_conf.padding.side, ui_conf.padding.base, ui_conf.padding.base, ui_conf.padding.base),

      scope:New "TextLabel" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(1, -size - use(ui_conf.padding.side), 1, 0)
        end),

        Text = props.name,
        TextSize = ui_conf.text_sizes.mini,

        FontFace = ui_conf.font,

        TextTruncate = Enum.TextTruncate.SplitWord,
        TextXAlignment = Enum.TextXAlignment.Left,

        TextColor3 = ui_conf.colors.text,
      },

      scope:Hover "ImageButton" {
        BackgroundColor3 = ui_conf.colors.overlay,

        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),

        Size = UDim2.new(0, size, 1, 0),

        [OnEvent "MouseButton1Click"] = function()
          if conf.input_locked then
            return
          end

          conf.input_locked = true

          if recordScope then
            recordScope:doCleanup()
          end

          recordScope = scope:innerScope()

          local prevPressed = peek(props.value)
          local pressed = {}

          props.value:set(pressed)

          table.insert(
            recordScope,
            UserInputService.InputBegan:Connect(function(input)
              if input.UserInputType ~= Enum.UserInputType.Keyboard then
                if #pressed == 0 then
                  props.value:set(prevPressed)
                end

                elapsed = 0
                progress:set(0)

                recordScope:doCleanup()
                recordScope = nil

                conf.input_locked = false

                return
              end

              local key = input.KeyCode.Name

              if table.find(pressed, key) then
                return
              end

              table.insert(pressed, key)

              elapsed = 0
              progress:set(0)

              props.value:set(pressed)
            end)
          )
        end,

        [Children] = {
          scope:Round(ui_conf.rounding.mini),
          scope:Padding(ui_conf.padding.base),

          scope:New "Frame" {
            BackgroundTransparency = 1,

            Size = UDim2.fromScale(1, 1),

            ClipsDescendants = true,

            [Children] = {
              scope:New "TextLabel" {
                BackgroundTransparency = 1,

                Position = scope:Computed(function(use)
                  local width = use(bounds).X
                  local small = #use(props.value) == 0 or width <= size

                  if small then
                    return UDim2.new()
                  end

                  return UDim2.fromOffset(-(width - (size - use(ui_conf.padding.base) * 2)) * use(progress), 0)
                end),

                Size = scope:Computed(function(use)
                  local width = use(bounds).X
                  local small = #use(props.value) == 0 or width <= size

                  return UDim2.new(small and 1 or 0, if not small then width ~= 0 and width or size else 0, 1, 0)
                end),

                Text = scope:Computed(function(use)
                  local keys = use(props.value)

                  if #keys == 0 then
                    return ". . ."
                  end

                  local t = table.clone(keys)

                  for i, v in t do
                    t[i] = utility.getDisplayKey(v)
                  end

                  return table.concat(t, " + ")
                end),

                FontFace = ui_conf.font,
                TextSize = ui_conf.text_sizes.nano,

                TextColor3 = ui_conf.colors.text,

                TextXAlignment = scope:Computed(function(use)
                  return use(bounds).X <= size and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
                end),

                [Out "TextBounds"] = bounds,
              },
            },
          },
        },
      },
    },
  }
end

return Keybind
]]></ProtectedString>
							<string name="ScriptGuid">{3BD85737-830C-43C7-B887-40D4EA48C06A}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">Keybind</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
