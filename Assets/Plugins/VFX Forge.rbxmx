					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Selection = game:GetService("Selection")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local presets = script:FindFirstAncestorOfClass("Model").assets.presets

type props = {
  parent: Instance,
  cleanup: () -> (),
}

-- stylua: ignore
local PRESETS = {
  { "Tween Property",    presets.TweenProperty },
  { "Particle",          presets.ParticleEmitter },
  { "Beam",              presets.beam },
  { "Decal Mesh",        presets.DecalMesh },
  { "Part Mesh",         presets.PartMesh },
  { "MeshPart Mesh",     presets.MeshPartMesh },
  { "Bezier",            presets.Bezier },
  { "Shared End Bezier", presets.SharedEndBezier },
  { "Spin Model",        presets.SpinModel },
  { "Screen Effect",     presets.ScreenEffect },
  { "Camera Shake",      presets.CameraShake },
  { "Shockwave Ring",    presets.Ring },
  { "Shockwave Line",    presets.Line },
  { "Shockwave Debris",  presets.Debris },
}

local function Adder(scope: ui_types.scope, props: props)
  local searchBarValue: Fusion.Value<TextBox?> = scope:Value(nil)

  local searchQuery = scope:Value("")

  local scaledListContentSize = scope:Value(Vector2.zero)

  local listContentSize = scope:Computed(function(use)
    return use(scaledListContentSize) / use(ui_conf.scale)
  end)

  local size = Vector2.new(170, 200)

  local res = scope:New "ImageButton" {
    Parent = props.parent,

    BackgroundColor3 = ui_conf.colors.base,

    Size = UDim2.fromOffset(size.X, size.Y),

    Position = coroutine.wrap(function()
      local scale = peek(ui_conf.scale)
      local pad = peek(ui_conf.padding.side)

      local pos = UserInputService:GetMouseLocation() / scale
      local viewport = workspace.CurrentCamera.ViewportSize / scale

      local max = viewport - size - Vector2.one * pad

      return UDim2.fromOffset(math.clamp(pos.X, pad, max.X), math.clamp(pos.Y, pad, max.Y))
    end)(),

    ZIndex = 1001,

    [Children] = {
      scope:Round(ui_conf.rounding.base),
      scope:Padding(ui_conf.padding.side),

      scope:New "UIStroke" {
        Color = ui_conf.colors.primary,
      },

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,

        VerticalFlex = Enum.UIFlexAlignment.Fill,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,

        BackgroundColor3 = ui_conf.colors.surface,

        Size = UDim2.fromScale(1, 0),

        [Children] = {
          scope:Round(ui_conf.rounding.mini),

          scope:New "UISizeConstraint" {
            MinSize = scope:Computed(function(use)
              return Vector2.new(0, use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2)
            end),
          },

          scope:Hover "Frame" {
            BackgroundColor3 = ui_conf.colors.surface,

            Size = scope:Computed(function(use)
              return UDim2.new(
                1,
                -(use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2 + use(ui_conf.padding.side)),
                0,
                use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
              )
            end),

            [Children] = {
              scope:Round(ui_conf.rounding.mini),

              searchBarValue:set(scope:New "TextBox" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.new(0.5, 0),
                Position = UDim2.fromScale(0.5, 0),

                Size = scope:Computed(function(use)
                  return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
                end),

                FontFace = ui_conf.font,
                PlaceholderText = "search",

                TextColor3 = ui_conf.colors.text,
                PlaceholderColor3 = ui_conf.colors.muted,

                TextSize = ui_conf.text_sizes.mini,

                ClipsDescendants = true,
                TextXAlignment = Enum.TextXAlignment.Left,

                [Out "Text"] = searchQuery,

                [OnEvent "Focused"] = function()
                  local bar = peek(searchBarValue)

                  if bar then
                    bar.CursorPosition = #bar.Text + 1
                    bar.SelectionStart = 0
                  end
                end,
              } :: TextBox),
            },
          },
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        [Children] = {
          scope:Scrollable({
            content_size = listContentSize,
            padding = 1,

            children = {
              scope:New "CanvasGroup" {
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,

                Size = UDim2.fromScale(1, 0),

                [Children] = {
                  scope:Round(ui_conf.rounding.base),

                  scope:New "UIListLayout" {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    [Out "AbsoluteContentSize"] = scaledListContentSize,
                  },

                  scope:ForPairs(PRESETS, function(_, scope, index, set)
                    return index,
                      scope:Hover "TextButton" {
                        AutomaticSize = Enum.AutomaticSize.Y,

                        Size = UDim2.fromScale(1, 0),

                        AnchorPoint = Vector2.new(1, 0),
                        Position = UDim2.fromScale(1, 0),

                        Text = set[1],

                        BackgroundColor3 = ui_conf.colors.surface,

                        TextColor3 = ui_conf.colors.text,

                        FontFace = ui_conf.font,
                        TextSize = ui_conf.text_sizes.mini,

                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextTruncate = Enum.TextTruncate.SplitWord,

                        LayoutOrder = scope:Computed(function(use)
                          local start, stop = string.find(set[1]:lower(), use(searchQuery):lower(), 1, true)
                          return ((start and stop ~= 0) and start ^ 2 or 1000 + index)
                        end),

                        [OnEvent "MouseButton1Click"] = function()
                          local clone = set[2]:Clone()
                          local parent = Selection:Get()[1] or workspace

                          local sel = {}

                          local function prepare(obj: Instance)
                            local cf = CFrame.new((workspace.CurrentCamera.CFrame * CFrame.new(0, 0, -5)).Position)

                            if obj:IsA("Attachment") then
                              if not parent:IsA("BasePart") then
                                obj.WorldCFrame = cf * obj.CFrame
                              end
                            elseif obj:IsA("Part") then
                              obj.CFrame = cf
                            elseif obj:IsA("Model") then
                              obj:PivotTo(cf)
                            end

                            obj.Parent = parent

                            table.insert(sel, obj)
                          end

                          if clone:IsA("Folder") then
                            for _, obj in clone:GetChildren() do
                              prepare(obj)
                            end

                            clone:Destroy()
                          else
                            prepare(clone)
                          end

                          Selection:Set(sel)

                          props.cleanup()
                        end,

                        [Children] = {
                          scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
                        },
                      }
                  end),
                },
              },
            },
          }),
        },
      },
    },
  }

  local bar = peek(searchBarValue)

  if bar then
    bar:CaptureFocus()

    RunService.Heartbeat:Once(function()
      bar.Text = ""
    end)
  end

  return res
end

return Adder
]]></ProtectedString>
