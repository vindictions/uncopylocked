        end),

        VerticalAlignment = scope:Computed(function(use)
          return Enum.VerticalAlignment[use(conf.settings.ui.buttons_vertical)]
        end),

        HorizontalAlignment = scope:Computed(function(use)
          return Enum.HorizontalAlignment[use(conf.settings.ui.buttons_horizontal)]
        end),
      },
    },
  }

  local guiHidden = scope:Value(false)

  local shouldBeVisible = scope:Computed(function(use)
    for _, list in use(selectedEffects) do
      if #list > 0 then
        return true
      end
    end

    return false
  end)

  local guiEnabled = scope:Computed(function(use)
    if use(guiHidden) then
      return false
    end

    return use(shouldBeVisible)
  end)

