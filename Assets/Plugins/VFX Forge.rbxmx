						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local Children = Fusion.Children

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local Categorize = require("./cmp/Categorize")

type props = {
  attr_scope: Fusion.Value<ui_types.scope>,
  attr: Fusion.UsedAs<Categorize.tree>,
}

local function Attributes(scope: ui_types.scope, props: props)
  local scaledContentSize = scope:Value(Vector2.zero)

  local contentSize = scope:Computed(function(use)
    return use(scaledContentSize) / use(ui_conf.scale)
  end)

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UISizeConstraint" {
        MaxSize = scope:Computed(function(use)
          return Vector2.new(math.huge, use(contentSize).Y + use(ui_conf.padding.side) * 2 + 2) -- 2 pixels to see the stroke
        end),
      },

      scope:Scrollable({
        content_size = contentSize,
        padding = 1,

        children = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),

            [Out "AbsoluteContentSize"] = scaledContentSize,
          },

          Categorize(scope, props.attr_scope, props.attr),
        },
      }),
    },
  }
end

return Attributes
]]></ProtectedString>
