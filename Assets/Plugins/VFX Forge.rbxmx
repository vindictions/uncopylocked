  conf.current_ctx = ctx

  table.insert(scope, Selection.SelectionChanged:Connect(checkSelection))

  checkSelection()

  scope:OnKeybind(
    "toggle_enabled",
    "Toggles currently selected effects",
    conf.settings.keybinds.toggle_enabled,
    function()
      local e = peek(selectedEffects)

      for _, p in e.particles do
        p.Enabled = not p.Enabled
      end

      for _, list in { e.meshes, e.beziers } do
        for _, obj in list do
          if obj:HasTag(emit_utility.ENABLED_VFX_TAG) then
            obj:SetAttribute("Enabled", false)
            obj:RemoveTag(emit_utility.ENABLED_VFX_TAG)
          else
            obj:SetAttribute("Enabled", true)
            obj:AddTag(emit_utility.ENABLED_VFX_TAG)
          end
        end
      end
    end
  )

  scope:OnKeybind(
    "toggle_paths",
    "Toggles path visualization for currently selected effects",
