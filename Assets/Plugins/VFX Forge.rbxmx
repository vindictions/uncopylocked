					</Item>
				</Item>
			</Item>
			<Item class="Folder" referent="RBXFE66816A4AAB4961A31E895BEFFCD8B5">
				<Properties>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">code</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
				<Item class="ModuleScript" referent="RBX5414A7739D0A48009713442DD32A4611">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../../.conf")
local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

type props = {
  selection: Fusion.Value<{ Instance }>,
}

local function EmitCode(scope: ui_types.scope, props: props)
  local focused = scope:Value(false)

  local textBoxValue: Fusion.Value<TextBox?> = scope:Value(nil)

  local settings = conf.settings.code

  local HIGHLIGHTS = {
    -- strings
    {
      { `".-"` },
      ui_conf.colors.code_string,
    },

    -- operators
    {
      { "[%(%)%[%]%{%}%.:,=]" },
      ui_conf.colors.code_operator,
    },

    -- keywords
    {
      {
        "local",
      },
      ui_conf.colors.code_keyword,
    },

    -- builtins
    {
      {
        "shared",
        "game",
        "workspace",
      },
      ui_conf.colors.code_builtin,
    },

    -- methods
    {
      {
        `:(%w+)%(.-%)`,
        `%.(%w+)%(.-%)`,
      },
      ui_conf.colors.code_method,
    },

    -- keys
    {
      { `%.([%w_]+)` },
      ui_conf.colors.code_key,
    },
  }

  local function getFullName(obj: Instance)
    local names = {}

    local function recurse(parent: Instance?)
      if parent and (parent ~= game or not peek(settings.import_services)) then
        local pp = parent.Parent
        local name = pp == game and parent.ClassName or parent == game and "game" or parent.Name

        if pp and pp[name] ~= parent then
          name = `_remove_:FindFirstChild("{name}")`
        end

        table.insert(names, name)

        recurse(parent.Parent)
      end
    end

    recurse(obj)

    return names
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:Hover "Frame" {
        BackgroundColor3 = ui_conf.colors.surface,

        Size = UDim2.fromScale(1, 1),

        [Children] = {
          scope:Round(ui_conf.rounding.base),
          scope:Padding(ui_conf.padding.side),

          textBoxValue:set(scope:New "TextBox" {
            BackgroundTransparency = 1,

            Size = UDim2.fromScale(1, 1),

            RichText = true,
            TextWrapped = true,
            TextEditable = false,
            ClipsDescendants = true,

            FontFace = Font.fromId(16658246179, Enum.FontWeight.SemiBold),

            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,

            PlaceholderText = "Code will show up here",

            TextColor3 = ui_conf.colors.text,
            PlaceholderColor3 = ui_conf.colors.muted,

            TextSize = ui_conf.text_sizes.mini,

            Text = scope:Computed(function(use, scope)
              local args = {}

              local imports = {}
              local aliasMap = {}

              for _, obj in use(props.selection) do
                if obj.Parent == nil then
                  continue
                end

                local names = getFullName(obj)
                local service = names[#names]

                if
                  settings.import_services
                  and not aliasMap[service]
                  and pcall(game.GetService, game, service)
                  and if service == "Workspace" then peek(settings.import_workspace) else true
                then
                  local alias = peek(settings.services_full_name) and service or string.char(97 + #imports):upper()

                  aliasMap[service] = alias

                  table.insert(imports, `local {alias} = game:GetService("{service}")`)
                elseif service == "Workspace" then
                  names[#names] = "workspace"
                end

                local alias = aliasMap[service]

                if alias then
                  names[#names] = alias
                end

                local final = {}
                local len = #names

                for i, member in names do
                  if string.match(member, "^_remove_") then
                    member = string.gsub(member, "^_remove_", "")
                    final[len - i + 1] = member
                  else
                    if string.match(member, "^%d") or string.match(member, "[^%w_]") then
                      final[len - i + 1] = `["{member}"]`
                    else
                      final[len - i + 1] = `{i ~= len and "." or ""}{member}`
                    end
                  end
                end

                table.insert(args, table.concat(final, ""))
              end

              table.sort(imports, function(a, b)
                return #a < #b
              end)

              local res = if #args > 0
                then `{table.concat(imports, "\n")}{#imports > 0 and "\n\n" or ""}shared.vfx.emit({table.concat(
                  args,
                  ", "
                )})`
                else ""

              local unstyledText = res

              if not use(focused) then
                local intervals = {}

                for _, hl in HIGHLIGHTS do
                  for _, pat in hl[1] do
                    local last = 1
                    local lastStyled = 1

                    for match in string.gmatch(unstyledText, pat) do
                      local start, stop = string.find(unstyledText, match, last, true)

                      local _, styledStop = string.find(res, match, lastStyled, true)

                      last = stop + 1
                      lastStyled = styledStop + 1

                      local outside = true

                      for _, s in intervals do
                        if start >= s.start and start < s.stop then
                          outside = false
                          break
                        end
                      end

                      if outside then
                        table.insert(intervals, {
                          start = start,
                          stop = stop,
                          color = hl[2],
                        })
                      end
                    end
                  end
                end

                table.sort(intervals, function(a, b)
                  return a.start > b.start
                end)

                for _, span in ipairs(intervals) do
                  local before = res:sub(1, span.start - 1)
                  local middle = res:sub(span.start, span.stop)
                  local after = res:sub(span.stop + 1)

                  local wrapped = string.format('<font color="#%s">%s</font>', use(span.color):ToHex(), middle)

                  res = before .. wrapped .. after
                end
              end

              return res
            end),

            [OnEvent "Focused"] = function()
              focused:set(true)

              local bar = peek(textBoxValue)

              if bar then
                bar.CursorPosition = #bar.Text + 1
                bar.SelectionStart = 0
              end
            end,

            [OnEvent "FocusLost"] = function()
              focused:set(false)
            end,
          } :: TextBox),
        },
      },
    },
  }
end

return EmitCode
]]></ProtectedString>
						<string name="ScriptGuid">{040DA503-33E9-47BF-8F22-E4BCF4F2E8AF}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">EmitCode</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
			</Item>
			<Item class="Folder" referent="RBXB13DBC66D2ED4EADBE8FFD3880710235">
				<Properties>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">color_picker</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
				<Item class="ModuleScript" referent="RBX3F3C1124C78F482395E9303D79934B4B">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Selection = game:GetService("Selection")
local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local conf = require("../../.conf")
local utility = require("../../lib/utility")

type props = {
  selection: { Instance },
}

local colorProps = {
  Single = {
    Color3 = {
      "Decal",
      "Texture",
    },

    Color = {
      "SurfaceAppearance",
    },
  },

  Sequence = {
    Color = {
      "ParticleEmitter",
      "Trail",
      "Beam",
    },
  },
}

local function ColorPicker(scope: ui_types.scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create color picker because the ctx contextual is not set for current thread")
  end

  local channels = {
    H = scope:Value(0.5),
    S = scope:Value(1),
    V = scope:Value(1),
  }

  local gradients = {
    H = scope:Computed(function(use)
      local pts = {}

      for i = 0, 6 do
        local t = i / 6
        table.insert(pts, ColorSequenceKeypoint.new(t, Color3.fromHSV(t, 1, 1)))
      end

      return ColorSequence.new(pts)
    end),

    S = scope:Computed(function(use)
      return ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromHSV(use(channels.H), 0, 1)),
        ColorSequenceKeypoint.new(1, Color3.fromHSV(use(channels.H), 1, 1)),
      })
    end),

    V = scope:Computed(function(use)
      return ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromHSV(use(channels.H), 1, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromHSV(use(channels.H), 1, 1)),
      })
    end),
  }

  local height = scope:Computed(function(use)
    return use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
  end)

  local currentColor = scope:Computed(function(use)
    return Color3.fromHSV(use(channels.H), use(channels.S), use(channels.V))
  end)

  local selectedColors = scope:Computed(function(use)
    local res = {}

    local function check(obj: Instance)
      for _, info in colorProps do
        for k, v in info do
          if not table.find(v, obj.ClassName) then
            continue
          end

          local c = obj[k]
          local isSeq = typeof(c) == "ColorSequence"

          if
            (typeof(c) == "Color3" or isSeq)
            and not table.find(res, c)
            and if isSeq
              then if c.Keypoints[1].Value == c.Keypoints[2].Value then not table.find(res, c.Keypoints[1]) else true
              else true
          then
            table.insert(res, c)
          end
        end
      end
    end

    for _, obj in use(props.selection) do
      check(obj)

      for _, desc in obj:GetDescendants() do
        check(desc)
      end
    end

    return res
  end)

  local hovered = scope:Value(false)
  local swapColors = scope:Value({})

  local hoverScope

  scope:Observer(hovered):onChange(function()
    if hoverScope then
      hoverScope:doCleanup()
      hoverScope = nil
    end

    if peek(hovered) then
      hoverScope = scope:innerScope()

      conf.ctx:is(ctx):during(function()
        hoverScope:Tooltip({
          near_padding = 14,
          text = scope:Computed(function(use)
            local colors = use(swapColors)

            local res = {}

            for _, c in colors do
              local v = typeof(c) == "Color3" and c or c.Keypoints[1].Value
              table.insert(res, `* {math.round(v.R * 255)}, {math.round(v.G * 255)}, {math.round(v.B * 255)}`)
            end

            return #colors == 0 and "replaces all colors" or `replaces colors\n{table.concat(res, "\n")}`
          end),
        })
      end)
    end
  end)

  local originalColors = {}

  local function setColor(obj: Instance, color: Color3, info: { [string]: { string } })
    for k, v in info do
      if not table.find(v, obj.ClassName) then
        continue
      end

      local map = originalColors[k]

      if not map then
        map = {}
        originalColors[k] = map
      end

      local c = obj[k]
      local allowed = peek(swapColors)

      if #allowed > 0 and not table.find(allowed, map[obj] or c) then
        continue
      end

      local valid = typeof(c) == "Color3" or typeof(c) == "ColorSequence"

      if not map[obj] and valid then
        map[obj] = c
      end

      if valid then
        obj[k] = color
      end
    end
  end

  local function reset(onexit: boolean?, keepSwap: boolean?, noSync: boolean?)
    if not noSync then
      local c = peek(selectedColors)[1] :: Color3 | ColorSequence

      if c then
        local used = typeof(c) == "Color3" and c or c.Keypoints[1].Value
        local h, s, v = used:ToHSV()

        channels.H:set(h)
        channels.S:set(s)
        channels.V:set(v)
      end
    end

    for k, map in originalColors do
      for obj, c in map do
        obj[k] = c
      end
    end

    table.clear(originalColors)

    if not keepSwap then
      local sw = peek(swapColors)
      table.clear(sw)

      swapColors:set(sw)
    end

    if not onexit then
      hovered:set(false)
    end
  end

  local function submit(preview: boolean, sel: { Instance })
    local function set()
      local color = peek(currentColor)

      local function check(obj: Instance)
        setColor(obj, color, colorProps.Single)
        setColor(obj, ColorSequence.new(color), colorProps.Sequence)
      end

      for _, obj in sel do
        check(obj)

        for _, desc in obj:GetDescendants() do
          check(desc)
        end
      end
    end

    if preview then
      set()
    else
      table.clear(originalColors)

      utility.record("apply color " .. tostring(color), set)

      reset(nil, nil, true)
      -- recompute selected colors
      props.selection:set(peek(props.selection), true)
    end
  end

  -- reset when plugin is turned off or smth
  table.insert(scope, function()
    reset(true)
  end)

  scope:Observer(props.selection):onChange(function()
    reset()
  end)

  for _, v in channels do
    scope:Observer(v):onChange(function()
      submit(true, peek(props.selection))
    end)
  end

  local colorFrame = scope:Value(nil :: Frame?)

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    AutomaticSize = Enum.AutomaticSize.X,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,

        HorizontalFlex = Enum.UIFlexAlignment.Fill,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.X,

        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(0, 0, 1, -(use(height) * 2 + use(ui_conf.padding.side) * 2))
        end),

        [Children] = {
          scope:Padding(ui_conf.padding.base, 0),

          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            VerticalFlex = Enum.UIFlexAlignment.Fill,
            HorizontalFlex = Enum.UIFlexAlignment.SpaceAround,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.prop) * 2)
            end),
          },

          scope:ForPairs(channels, function(_, scope, name, value)
            return name,
              scope:New "Frame" {
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 8, 1, 0),

                [Children] = {
                  scope:Slider({
                    value = value,

                    background = Color3.new(1, 1, 1),

                    no_bar = true,
                    vertical = true,

                    min = 0,
                    max = 1,

                    dot_size = UDim2.new(1.75, 0, 0, 6),

                    custom_dot = {
                      scope:New "Frame" {
                        BackgroundColor3 = ui_conf.colors.text,

                        Size = UDim2.fromScale(1, 1),

                        [Children] = {
                          scope:Round(0, 0.5),
                          scope:Stroke({
                            size = 2,
                            color = Color3.new(0, 0, 0),
                          }),
                        },
                      },
                    },

                    children = {
                      scope:New "UIGradient" {
                        Color = gradients[name],
                        Rotation = -90,
                      },
                    },
                  }),
                },
              }
          end),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(0, 0, 0, use(height))
        end),

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          colorFrame:set(scope:New "ImageButton" {
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(1, 1),

            [Children] = {
              scope:New "CanvasGroup" {
                BackgroundTransparency = 1,

                Size = UDim2.fromScale(1, 1),

                [Children] = {
                  scope:Round(ui_conf.rounding.mini),

                  scope:New "UIListLayout" {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    FillDirection = Enum.FillDirection.Horizontal,

                    HorizontalFlex = Enum.UIFlexAlignment.Fill,
                  },

                  scope:New "Frame" {
                    BackgroundColor3 = currentColor,
                    Size = UDim2.fromScale(1, 1),
                  },

                  scope:ForValues(swapColors, function(_, scope, color)
                    local isSeq = typeof(color) == "ColorSequence"

                    return scope:New "Frame" {
                      BackgroundColor3 = isSeq and Color3.new(1, 1, 1) or color,

                      Size = UDim2.fromScale(1, 1),

                      [Children] = {
                        if isSeq
                          then scope:New "UIGradient" {
                            Color = color,
                          }
                          else nil,
                      },
                    }
                  end),
                },
              },
            },

            [OnEvent "MouseButton1Click"] = function()
              conf.ctx:is(ctx):during(function()
                scope:Prompt({
                  title = "Swapper",

                  float = Vector2.new(0, 1),
                  near_element = peek(colorFrame),

                  automatic_width = true,

                  child = function(scope)
                    return scope:New "Frame" {
                      AutomaticSize = Enum.AutomaticSize.X,

                      BackgroundTransparency = 1,

                      Size = UDim2.fromOffset(120, 50),

                      [Children] = {
                        scope:Padding(ui_conf.padding.side),

                        scope:New "UIListLayout" {
                          SortOrder = Enum.SortOrder.LayoutOrder,
                          FillDirection = Enum.FillDirection.Horizontal,

                          Padding = scope:Computed(function(use)
                            return UDim.new(0, use(ui_conf.padding.side))
                          end),
                        },

                        scope:ForValues(selectedColors, function(_, scope, color)
                          local isSeq = typeof(color) == "ColorSequence"
                          local selected = scope:Value(table.find(peek(swapColors), color) ~= nil)

                          return scope:New "ImageButton" {
                            BackgroundColor3 = isSeq and Color3.new(1, 1, 1) or color,

                            Size = UDim2.fromScale(1, 1),
                            SizeConstraint = Enum.SizeConstraint.RelativeYY,

                            [OnEvent "MouseButton1Click"] = function()
                              selected:set(not peek(selected))

                              local colors = peek(swapColors)

                              if peek(selected) then
                                table.insert(colors, color)
                              else
                                local index = table.find(colors, color)

                                if index then
                                  table.remove(colors, index)
                                end
                              end

                              swapColors:set(colors)
                            end,

                            [Children] = {
                              scope:Round(ui_conf.rounding.mini),

                              scope:New "ImageLabel" {
                                BackgroundTransparency = scope:Spring(
                                  scope:Computed(function(use)
                                    return use(selected) and 0.5 or 1
                                  end),
                                  30,
                                  1
                                ),

                                BackgroundColor3 = Color3.new(0, 0, 0),

                                Size = UDim2.fromScale(1, 1),

                                Image = "rbxassetid://109331467628756",
                                ImageTransparency = scope:Spring(
                                  scope:Computed(function(use)
                                    return use(selected) and 0 or 1
                                  end),
                                  30,
                                  1
                                ),

                                [Children] = {
                                  scope:Round(ui_conf.rounding.mini),
                                },
                              },

                              if isSeq
                                then scope:New "UIGradient" {
                                  Color = color,
                                }
                                else nil,
                            },
                          }
                        end),
                      },
                    }
                  end,
                })
              end)
            end,

            [OnEvent "MouseEnter"] = function()
              hovered:set(true)
            end,

            [OnEvent "MouseLeave"] = function()
              hovered:set(false)
            end,
          }),

          scope:Hover "ImageButton" {
            BackgroundColor3 = ui_conf.colors.surface,

            [OnEvent "MouseButton1Click"] = function()
              reset(nil, true)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),

              scope:New "UISizeConstraint" {
                MinSize = scope:Computed(function(use)
                  return Vector2.new(use(height), use(height))
                end),
              },

              scope:New "ImageLabel" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.one * 0.5,
                Position = UDim2.fromScale(0.5, 0.5),

                Size = UDim2.fromOffset(14, 14),

                Image = "rbxassetid://116360941559301",
                ImageColor3 = ui_conf.colors.text,
              },
            },
          },
        },
      },

      scope:Hover "TextButton" {
        Size = scope:Computed(function(use)
          return UDim2.new(0, 0, 0, use(height))
        end),

        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),

        Text = "set",

        BackgroundColor3 = ui_conf.colors.primary,
        TextColor3 = ui_conf.colors.surface,

        FontFace = ui_conf.font,
        TextSize = ui_conf.text_sizes.mini,

        [OnEvent "MouseButton1Click"] = function()
          submit(false, peek(props.selection))
        end,

        [Children] = {
          scope:Round(ui_conf.rounding.mini),
          scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
        },
      },
    },
  }
end

return ColorPicker
]]></ProtectedString>
						<string name="ScriptGuid">{0BB97B08-59DE-4294-83A5-A47BC0EFBFD9}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">ColorPicker</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
			</Item>
			<Item class="Folder" referent="RBX09CA2FD4EE9E4C2EBA86DF0CEA924F4D">
				<Properties>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">copier</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
				<Item class="ModuleScript" referent="RBXDCD996FB6F0744B4A556031D98FAEB23">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local utility = require("../../lib/utility")
local handlers = require("./handlers")

type props = {
  effects: Fusion.Value<{
    particles: { ParticleEmitter },
    beams: { Beam },
    meshes: { Model },
    mesh_decals: { Decal },
    spin_models: { Model },
  }>,
}

local copylist = {
  {
    "tween_properties",
    {
      { "Easing_Curve", handlers.Attribute, "Easing" },
      { "Speed_Curve", handlers.Attribute, "Speed", { "TimeScale" } },
    },
  },

  {
    "particles",
    {
      { "Color", handlers.Property },
      { "Size", handlers.Property },
      { "Transparency", handlers.Property },
      { "Squash", handlers.Property },
      { "TimeScale_Curve", handlers.Attribute, "TimeScale", { "Speed" } },
      { "LightEmission", handlers.Property },
      { "LightInfluence", handlers.Property },
      { "Brightness", handlers.Property },
    },
  },

  {
    "beams",
    {
      { "Color", handlers.Property },
      { "Transparency", handlers.Property },
      { "Transparency_Scale_Curve", handlers.Attribute, "TpScale" },
      { "Width0_Curve", handlers.Attribute, "Width0" },
      { "Width1_Curve", handlers.Attribute, "Width1" },
      { "Speed_Curve", handlers.Attribute, "Speed", { "TimeScale" } },
      { "LightEmission", handlers.Property },
      { "LightInfluence", handlers.Property },
      { "Brightness", handlers.Property },
    },
  },

  {
    "trails",
    {
      { "Color", handlers.Property },
      { "Transparency", handlers.Property },
      { "WidthScale", handlers.Property },
    },
  },

  {
    "meshes",
    {
      { "Part_CFrame_Curve", handlers.Attribute, "CFrame" },
      { "Part_Transparency_Curve", handlers.Attribute, "Transparency" },
      { "Part_Size_Curve", handlers.Attribute, "Size" },
      { "Mesh_Scale_Curve", handlers.Attribute, "Scale" },
      { "Part_RotSpeed_Curve", handlers.Attribute, "RotSpeed" },
      { "Speed_Curve", handlers.Attribute, "Speed", { "TimeScale" } },
    },
  },

  {
    "beziers",
    {
      { "Easing_Curve", handlers.Attribute, "Easing" },
      { "RotSpeed_Curve", handlers.Attribute, "RotSpeed" },
      { "Speed_Curve", handlers.Attribute, "Speed", { "TimeScale" } },
    },
  },

  {
    "screen_shakes",
    {
      { "Speed_Curve", handlers.Attribute, "Speed", { "TimeScale" } },
    },
  },

  {
    "shockwave_rings",
    {
      { "Size_Curve", handlers.Attribute, "Size" },
      { "Transparency_Curve", handlers.Attribute, "Transparency" },
    },
  },

  {
    "shockwave_lines",
    {
      { "Size_Curve", handlers.Attribute, "Size" },
      { "Transparency_Curve", handlers.Attribute, "Transparency" },
      { "Scale_Curve", handlers.Attribute, "Scale" },
      { "Path_Curve", handlers.Attribute, "Path" },
      { "Rate_Curve", handlers.Attribute, "Rate" },
    },
  },

  {
    "shockwave_debris",
    {
      { "Size_Curve", handlers.Attribute, "Size" },
      { "Transparency_Curve", handlers.Attribute, "Transparency" },
    },
  },

  {
    "mesh_decals",
    {
      { "Transparency_Curve", handlers.Attribute, "Transparency" },
      { "Color3", handlers.Property, "Color" },
      { "Color_Curve", handlers.Attribute, "ColorCurve" },
    },
  },

  {
    "spin_models",
    {
      { "Scale_Curve", handlers.Attribute, "Scale" },
      { "SpinSpeed_Curve", handlers.Attribute, "Speed", { "TimeScale" } },
    },
  },
}

local function CurveCopier(scope: ui_types.scope, props: props)
  local selected = scope:Value({})
  local scaledListContentSize = scope:Value(Vector2.zero)

  local listContentSize = scope:Computed(function(use)
    return use(scaledListContentSize) / use(ui_conf.scale)
  end)

  local buttonHeight = scope:Computed(function(use)
    return use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
  end)

  local function getItem(name: string, key: string, reference: Instance?, handler, copyShare: { string }?)
    local sel = peek(selected)

    local entry = sel[handler]

    if not entry then
      entry = {}
      sel[handler] = entry
    end

    local item = entry[key]

    if item then
      -- save the new reference
      item.reference = reference
      return item
    end

    item = {
      selected = scope:Value(false),
    }

    entry[key] = item

    item.real_name = name
    item.reference = reference
    item.copy_share = copyShare

    return item
  end

  local flattened = scope:Computed(function(use)
    local effects = use(props.effects)

    local added = {}
    local flattened = {}

    for _, data in copylist do
      local objs = effects[data[1]]

      if #objs == 0 then
        continue
      end

      for _, info in data[2] do
        local name = info[1]
        local handler = info[2]
        local alias = info[3]

        local key = alias or name

        if table.find(added, key) then
          continue
        end

        table.insert(added, key)

        local item = getItem(name, key, objs[1], handler, info[4])

        table.insert(flattened, {
          name = key,
          item = item,
        })
      end
    end

    return flattened
  end)

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UISizeConstraint" {
        MaxSize = scope:Computed(function(use)
          return Vector2.new(
            math.huge,
            use(listContentSize).Y
              + use(buttonHeight)
              + use(ui_conf.padding.side) * (#use(flattened) == 0 and 2 or 3)
              + 1
          )
        end),
      },

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalFlex = Enum.UIFlexAlignment.Fill,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.fromScale(1, 1)
        end),

        [Children] = {
          scope:New "UISizeConstraint" {
            MinSize = scope:Computed(function(use)
              return Vector2.new(0, use(buttonHeight))
            end),

            MaxSize = scope:Computed(function(use)
              return Vector2.new(math.huge, use(buttonHeight))
            end),
          },

          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "copy",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.mini,

            [OnEvent "MouseButton1Click"] = function()
              for handler, entry in peek(selected) do
                for name, item in entry do
                  if not peek(item.selected) then
                    continue
                  end

                  local copyTo = {}

                  if item.copy_share then
                    for _, with in item.copy_share do
                      local im = entry[with]

                      if not im then
                        for i, v in copylist do
                          for _, info in v[2] do
                            if
                              (info[3] or info[1]) == with
                              and info[2] == handler
                              and (info[4] and table.find(info[4], name))
                            then
                              im = getItem(info[1], info[3] or info[1], nil, handler, info[4])
                              break
                            end
                          end

                          if im then
                            break
                          end
                        end
                      end

                      table.insert(copyTo, im)
                    end
                  end

                  local res = handler.copy(item.reference, item.real_name)

                  item.value = res

                  for _, im in copyTo do
                    im.value = res
                  end
                end
              end
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "paste",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.mini,

            [OnEvent "MouseButton1Click"] = function()
              utility.record("paste copied curves", function()
                for handler, entry in peek(selected) do
                  for name, item in entry do
                    if not peek(item.selected) then
                      continue
                    end

                    for key, effects in peek(props.effects) do
                      if #effects == 0 then
                        continue
                      end

                      for i, v in copylist do
                        if v[1] == key then
                          for _, data in v[2] do
                            if (data[1] == name or data[3] == name) and data[2] == handler then
                              for _, obj in effects do
                                handler.paste(obj, data[1], item.value)
                              end

                              break
                            end
                          end
                        end
                      end
                    end
                  end
                end
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 1),

        [Children] = {
          scope:Scrollable({
            content_size = listContentSize,

            children = {
              scope:New "CanvasGroup" {
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,

                Size = UDim2.fromScale(1, 0),

                [Children] = {
                  scope:Round(ui_conf.rounding.base),

                  scope:New "UIListLayout" {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    [Out "AbsoluteContentSize"] = scaledListContentSize,
                  },

                  scope:ForValues(flattened, function(_, scope, data)
                    return scope:Hover "TextButton" {
                      AutomaticSize = Enum.AutomaticSize.Y,

                      Size = UDim2.fromScale(1, 0),

                      AnchorPoint = Vector2.new(1, 0),
                      Position = UDim2.fromScale(1, 0),

                      Text = data.name,

                      BackgroundColor3 = scope:Switch(
                        data.item.selected,
                        scope:AlphaBlend(0.5, ui_conf.colors.surface, ui_conf.colors.primary),
                        ui_conf.colors.surface
                      ),

                      TextColor3 = ui_conf.colors.text,

                      FontFace = ui_conf.font,
                      TextSize = ui_conf.text_sizes.mini,

                      TextXAlignment = Enum.TextXAlignment.Left,
                      TextTruncate = Enum.TextTruncate.SplitWord,

                      [OnEvent "MouseButton1Click"] = function()
                        data.item.selected:set(not peek(data.item.selected))
                      end,

                      [Children] = {
                        scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
                      },
                    }
                  end),
                },
              },
            },
          }),
        },
      },
    },
  }
end

return CurveCopier
]]></ProtectedString>
						<string name="ScriptGuid">{7D13E5D4-2A9A-4A14-8E79-751B17101AB2}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">CurveCopier</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBXE538BCB4CEA54FDCA6667A1466239E49">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local logger = require("../../lib/logger")

local handlers = {}

handlers.Property = {
  copy = function(obj: Instance, name: string)
    local ok, v = pcall(function()
      return obj[name]
    end)

    if not ok then
      logger.warn(`failed to copy '{name}' from {obj:GetFullName()}: {v}`)
      return
    elseif typeof(v) == "Instance" then
      logger.warn(`failed to copy '{name}' from {obj:GetFullName()} because it has a child with the same name`)
      return
    end

    return v
  end,

  paste = function(obj: Instance, name: string, value: any)
    local ok, v = pcall(function()
      obj[name] = value
    end)

    if not ok then
      logger.warn(`failed to paste '{name}' to {obj:GetFullName()}: {v}`)
    end
  end,
}

handlers.Attribute = {
  copy = function(obj: Instance, name: string)
    local res = {
      name = name,
      curve = obj:GetAttribute(name),
      inputs = {},
    }

    local prefix = name:gsub("_Curve$", "")

    -- copy inputs
    for key, value in obj:GetAttributes() do
      if key:match(`^{prefix}_`) then
        res.inputs[key] = value
      end
    end

    return res
  end,

  paste = function(obj: Instance, name: string, value)
    local prefix = name:gsub("_Curve$", "")
    local value_prefix = value.name:gsub("_Curve$", "")

    for k, v in value.inputs do
      obj:SetAttribute(`{prefix}_{k:gsub(`^{value_prefix}_`, "")}`, v)
    end

    obj:SetAttribute(name, value.curve)
  end,
}

return handlers
]]></ProtectedString>
						<string name="ScriptGuid">{3D7F096F-65CA-42F5-9CFA-E86E3D2DA667}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">handlers</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
			</Item>
			<Item class="Folder" referent="RBX48E5B3EFB6A9455D981DF5F706B6B4C2">
				<Properties>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">curve</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
				<Item class="ModuleScript" referent="RBX0A18D3C766184E4CA8B12880E130BFE0">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local lerp = require("../../lib/lerp")
local logger = require("../../lib/logger")
local symbols = require("../../.symbols")
local utility = require("../../lib/utility")
local emit_utility = require("../../lib/emit/mod/utility")

local conf = require("../../.conf")
local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local EffectBehavior = require("./behavior")

local Point = require("./cmp/Point")
local TabBar = require("./cmp/TabBar")
local SideBar = require("./cmp/SideBar")
local BottomBar = require("./cmp/BottomBar")

local NIL = symbols.nil_symbol

local SELECTION_ORDER = {
  spin_models = {
    1,
    "Spin Model",
  },

  particles = {
    2,
    "Particle",
  },

  beams = {
    3,
    "Beam",
  },

  meshes = {
    4,
    "Mesh",
  },

  mesh_decals = {
    5,
    "Mesh Decal",
  },

  beziers = {
    6,
    "Bezier",
  },

  screen_shakes = {
    7,
    "Camera Shake",
  },

  trails = {
    8,
    "Trail",
  },

  tween_properties = {
    9,
    "Tween Property",
  },

  shockwave_rings = {
    10,
    "Shockwave Ring",
  },

  shockwave_lines = {
    11,
    "Shockwave Line",
  },

  shockwave_debris = {
    12,
    "Shockwave Debris",
  },
}

type props = {
  effects: Fusion.UsedAs<{
    particles: { ParticleEmitter },
    meshes: { Model },
    beams: { Beam },
    mesh_decals: { Decal },
    spin_models: { Model },
  }>,
}

local function getAttributeName(behavior, input, parent)
  return `{parent and (parent.name .. "_") or ""}{behavior.name}_{typeof(input) ~= "string" and input.name or input}`
end

local function CurveEditor(scope: ui_types.scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create curve editor because the ctx contextual is not set for current thread")
  end

  local indexStorage = {}

  local availableInputs = scope:Value({})

  local selectedTabIndex = scope:Value(1)
  local selectedExpandIndex = scope:Value(1)

  local selectedEffectType = scope:Value(nil)

  local hidden = scope:Value(false)
  local multiple = scope:Value(false)

  local holding = scope:Value(false)
  local position = scope:Value(UDim2.fromScale(0.5, 0.5))

  local pathValue: Fusion.Value<Path2D?> = scope:Value(nil)
  local overlayValue: Fusion.Value<Frame?> = scope:Value(nil)

  local zoom = scope:Value(0.75)

  local sidebarWidth = 86

  local bottomBarPadding = ui_conf.padding.side
  local bottomBarSize = scope:Value(Vector2.zero)

  local keyval = scope:Value(nil)

  local lastMousePos: Vector2?
  local currentEffectKey: string?
  local behaviorScope: ui_types.scope?

  local currentCtrlPts: { Path2DControlPoint } = {}

  local setTangentMap: { [Path2DControlPoint]: { (offset: UDim2?) -> () } } = {}
  local updateTangentLineMap: { [Path2DControlPoint]: (offset: UDim2?) -> () } = {}

  local currentOverlayScope = scope:innerScope()

  scope:Observer(selectedTabIndex):onChange(function()
    if not currentEffectKey then
      selectedExpandIndex:set(1)
      return
    end

    local list = indexStorage[currentEffectKey]

    if not list then
      list = {}
      indexStorage[currentEffectKey] = list
    end

    local i = peek(selectedTabIndex)

    list[1] = i

    selectedExpandIndex:set(list[i + 1] or 1)
  end)

  scope:Observer(selectedExpandIndex):onChange(function()
    if not currentEffectKey then
      return
    end

    local list = indexStorage[currentEffectKey]

    if not list then
      list = {}
      indexStorage[currentEffectKey] = list
    end

    list[peek(selectedTabIndex) + 1] = peek(selectedExpandIndex)
  end)

  scope:Observer(holding):onChange(function()
    if lastMousePos and not peek(holding) then
      lastMousePos = nil
    end
  end)

  local function getComputedBehaviorList(list: {}, get: (...any) -> ...any)
    if not list then
      return
    end

    local t = table.clone(list)
    local objs = get(props.effects)[currentEffectKey]

    for i, v in t do
      if typeof(v) ~= "function" then
        continue
      end

      t[i] = v(objs)
    end

    return t
  end

  local function getBehavior(get: (...any) -> ...any, key: string, noexpand: boolean?)
    local list = EffectBehavior[get(key)]

    if not list then
      return
    end

    local ref = list[get(selectedTabIndex)]

    local objs = get(props.effects)[currentEffectKey]

    if typeof(ref) == "function" then
      ref = ref(objs)
    end

    local parentRef

    if ref and ref.expand and not noexpand then
      parentRef = ref
      ref = ref.expand[get(selectedExpandIndex)]

      if typeof(ref) == "function" then
        ref = ref(objs)
      end
    end

    return ref, parentRef
  end

  local function updateTangents(point: Path2DControlPoint?, left: boolean, right: boolean)
    if not point then
      return
    end

    local set = setTangentMap[point]

    if not set then
      return
    end

    local setLeft = set[1]
    local setRight = set[2]

    if left and setLeft then
      setLeft()
    end

    if right and setRight then
      setRight()
    end
  end

  local function onChange(manual: boolean?)
    local path = peek(pathValue)
    local inputs = peek(availableInputs)

    if not inputs or not path then
      return
    end

    local objs = peek(props.effects)[currentEffectKey]

    local inputMap = {}

    for _, data in inputs do
      inputMap[data.input.name] = peek(data.value)
    end

    if not currentEffectKey then
      return
    end

    local function write()
      debug.profilebegin("forge_curve::write")

      local ref, parentRef = getBehavior(peek, currentEffectKey)
      local behavior = ref and utility.deepCopy(ref)

      local cache = {}

      for _, obj in objs do
        local t = table.clone(inputMap)

        for k, v in pairs(t) do
          if v ~= NIL then
            continue
          end

          local attr = getAttributeName(behavior, k, parentRef)

          local val = utility.collectAttributeFromMany(
            { obj },
            attr,
            typeof(v.default) == "function" and typeof(v.default(objs)) or typeof(v.default)
          )

          t[k] = val
        end

        cache = { behavior.handler(obj, path, t, table.unpack(cache)) }
      end

      debug.profileend()
    end

    if manual then
      write()
    else
      utility.record("write curve", write)
    end
  end

  local function insertControlPoint(
    index: number,
    point: Path2DControlPoint,
    ref: { Path2DControlPoint }?,
    manual: boolean?
  )
    local scope = currentOverlayScope:innerScope()
    local length = ref and #ref or #currentCtrlPts + 1

    -- prevent point sharing between presets and editor
    if manual then
      point = Path2DControlPoint.new(point.Position, point.LeftTangent, point.RightTangent)
    end

    scope = scope:innerScope()

    local function getTimeValue()
      local tmin, tmax = 1, 1
      local vmin, vmax = 0, 1

      local e = peek(selectedEffectType)
      local objs = peek(props.effects)[e]

      local inputs = {}
      local inputMap = {}

      for _, data in peek(availableInputs) do
        inputs[data.input.name] = peek(data.value)
        inputMap[data.input.name] = data.input
      end

      local start = inputs.Start
      local stop = inputs.End

      local ref, parentRef = getBehavior(peek, currentEffectKey)

      local v1, v2, v3, v4 = start, stop, start, stop
      local startIsRange, stopIsRange = false, false

      if typeof(start) == "NumberRange" then
        local attr = getAttributeName(ref, inputMap.Start, parentRef)
        v1, v2 = utility.collectMinMaxValuesFromMany(objs, attr, true)
        startIsRange = true
        -- Don't override start here - keep it as NumberRange for later use
      end

      if typeof(stop) == "NumberRange" then
        local attr = getAttributeName(ref, inputMap.End, parentRef)
        v3, v4 = utility.collectMinMaxValuesFromMany(objs, attr, true)
        stopIsRange = true
        -- Don't override stop here - keep it as NumberRange for later use
      end

      -- Set vmin/vmax based on actual values or ranges
      if startIsRange then
        vmin = v1 -- Use the collected min value
      elseif start then
        vmin = start
      end

      if stopIsRange then
        vmax = v4 -- Use the collected max value
      elseif stop then
        vmax = stop
      end

      -- Duration handling remains the same
      if e == "particles" then
        local duration = inputs.Duration

        if duration then
          tmin, tmax = duration, duration
        else
          tmin, tmax = utility.collectMinMaxValuesFromMany(objs, "Lifetime")
        end
      elseif e == "meshes" or e == "beams" then
        local duration = inputs.Duration

        if duration then
          tmin, tmax = duration, duration
        else
          tmin, tmax = utility.collectMinMaxValuesFromMany(objs, "EffectDuration", true)
        end
      elseif e == "beziers" then
        local duration = inputs.Duration

        if duration then
          tmin, tmax = duration, duration
        else
          tmin, tmax = utility.collectMinMaxValuesFromMany(objs, "Duration", true)
        end
      end

      return tmin, tmax, vmin, vmax, v1, v2, v3, v4, startIsRange, stopIsRange
    end

    table.insert(currentCtrlPts, index, point)

    conf.ctx:is(ctx):during(function()
      Point(scope, {
        side = index == 1 or index == length,
        last = index == length,

        path = peek(pathValue),
        parent = peek(overlayValue),

        ctrlp = point,
        points = currentCtrlPts,

        map = setTangentMap,
        umap = updateTangentLineMap,

        on_change = onChange,
        get_time_value = getTimeValue,
        update_tangents = updateTangents,

        effect = selectedEffectType,

        tooltip_text = function(scope, p)
          local tmin, tmax, vmin, vmax, v1, v2, v3, v4, startIsRange, stopIsRange = getTimeValue()

          local allowedDeltaKeys = {
            Enum.KeyCode.LeftShift,
            Enum.KeyCode.RightShift,
          }

          local showDeltas = scope:Value(false)

          for _, key in allowedDeltaKeys do
            if UserInputService:IsKeyDown(key) then
              showDeltas:set(true)
              break
            end
          end

          table.insert(
            scope,
            UserInputService.InputBegan:Connect(function(input)
              if not table.find(allowedDeltaKeys, input.KeyCode) then
                return
              end

              showDeltas:set(true)
            end)
          )

          table.insert(
            scope,
            UserInputService.InputEnded:Connect(function(input)
              if not table.find(allowedDeltaKeys, input.KeyCode) then
                return
              end

              showDeltas:set(false)
            end)
          )

          return function(use)
            local pos = use(p)
            pos = UDim2.fromScale(pos.X.Scale, 1 - pos.Y.Scale)

            local delta = use(showDeltas)
            local prev

            if delta then
              local index = table.find(currentCtrlPts, point)
              local before = currentCtrlPts[index - 1]

              if not before then
                before = point
              end

              prev = before.Position
              prev = UDim2.fromScale(prev.X.Scale, 1 - prev.Y.Scale)
            end

            local function fmt(isTime: boolean?)
              local x = if isTime then (if prev then pos.X.Scale - prev.X.Scale else pos.X.Scale) else pos.Y.Scale

              local a, b
              local isRangeType = false

              if isTime then
                a, b = tmin, tmax
              else
                -- For value, check if we're dealing with ranges
                if startIsRange or stopIsRange then
                  if startIsRange and stopIsRange then
                    -- Both are ranges - interpolate between the range bounds
                    a = lerp.linear(v1, v3, x) -- min values
                    b = lerp.linear(v2, v4, x) -- max values

                    isRangeType = true
                  elseif startIsRange then
                    -- Only start is range - interpolate from range to single value
                    a = lerp.linear(v1, vmax, x)
                    b = lerp.linear(v2, vmax, x)

                    isRangeType = a ~= b
                  else
                    -- Only stop is range - interpolate from single value to range
                    a = lerp.linear(vmin, v3, x)
                    b = lerp.linear(vmin, v4, x)

                    isRangeType = a ~= b
                  end
                else
                  -- Neither is range - standard behavior
                  a, b = vmin, vmax
                end
              end

              local char = delta and "Δ" or ""
              local at = typeof(a) == "number"
              local bt = typeof(b) == "number"

              -- Handle delta calculations
              if delta and prev and not isTime then
                local prevA, prevB

                if startIsRange or stopIsRange then
                  if startIsRange and stopIsRange then
                    prevA = lerp.linear(v1, v3, prev.Y.Scale)
                    prevB = lerp.linear(v2, v4, prev.Y.Scale)
                  elseif startIsRange then
                    prevA = lerp.linear(v1, vmax, prev.Y.Scale)
                    prevB = lerp.linear(v2, vmax, prev.Y.Scale)
                  else
                    prevA = lerp.linear(vmin, v3, prev.Y.Scale)
                    prevB = lerp.linear(vmin, v4, prev.Y.Scale)
                  end
                else
                  local original = vmin
                  prevA = lerp.linear(original, vmax, prev.Y.Scale)
                  prevB = prevA
                end

                if at then
                  a -= prevA
                end

                if bt then
                  b -= prevB
                end

                isRangeType = isRangeType and (a ~= b)
              end

              if not isTime and isRangeType then
                return (at and char .. string.format("%.2f", a) or "???")
                  .. `-`
                  .. ((b < 0 and "(" or "") .. (bt and string.format("%.2f", b) .. (b < 0 and ")" or "")) or "???")
              else
                -- Show as single value
                if not isTime or a == b then
                  if at and bt then
                    if not isTime and not isRangeType then
                      local original = vmin
                      local value = lerp.linear(original, vmax, x)

                      if prev then
                        value -= lerp.linear(original, vmax, prev.Y.Scale)
                      end

                      return char .. string.format("%.2f", value)
                    else
                      local value = isTime and (a * x) or a
                      return at and char .. string.format("%.2f", value) or char .. "???"
                    end
                  end

                  return at and char .. string.format("%.2f", a) or char .. "???"
                else
                  local res = b * x
                  local wrap = res < 0

                  return (at and char .. string.format("%.2f", res) or "???")
                    .. `-{char}`
                    .. (bt and ((wrap and "(" or "") .. string.format("%.2f", res) .. (wrap and ")" or "")) or "???")
                end
              end
            end

            return `time:  {fmt(true)}\nvalue: {fmt()}`
          end
        end,
      })
    end)

    table.insert(scope, function()
      setTangentMap[point] = nil
      updateTangentLineMap[point] = nil
    end)

    if not manual then
      local before = currentCtrlPts[index - 1]
      local after = currentCtrlPts[index + 1]

      updateTangents(before, false, true)
      updateTangents(after, true, false)

      local path = peek(pathValue)

      if not path then
        return
      end

      path:SetControlPoints(currentCtrlPts)

      onChange()
    end
  end

  local function replaceControlPoints(points: { Path2DControlPoint })
    currentOverlayScope:doCleanup()
    currentOverlayScope = scope:innerScope()

    table.clear(currentCtrlPts)

    for index, point in points do
      insertControlPoint(index, point, points, true)
    end

    local path = peek(pathValue)

    if path then
      path:SetControlPoints(points)
    end

    for pt, list in setTangentMap do
      if list[1] then
        list[1](pt.LeftTangent)
      end

      if list[2] then
        list[2](pt.RightTangent)
      end

      -- i dont even care at this point :sob:
      RunService.Heartbeat:Once(function()
        updateTangentLineMap[pt]()
      end)
    end
  end

  local function updateBehavior(key: string, effects: { Instance })
    -- prevent use() afer destroy down the chain
    availableInputs:set({})

    if behaviorScope then
      behaviorScope:doCleanup()
    end

    behaviorScope = scope:innerScope()

    local inputs = {}
    local values = {}

    local ref, parentRef = getBehavior(peek, currentEffectKey)
    local behavior = ref and utility.deepCopy(ref)

    if behavior and behavior.inputs then
      for _, input in behavior.inputs do
        local default = if typeof(input.default) == "function" then input.default(effects) else input.default

        local attr = getAttributeName(behavior, input, parentRef)
        local val = utility.collectAttributeFromMany(effects, attr, typeof(default), nil, default)

        if not behaviorScope then
          continue
        end

        local prev = values[input.name]

        if prev and (val == NIL or peek(prev) ~= val) then
          prev:set(NIL)
        elseif not prev then
          local state = behaviorScope:Value(val)

          input.value = state
          values[input.name] = state

          table.insert(inputs, {
            type = typeof(default),

            value = state,
            input = input,
          })

          local ignoreChange = false

          for _, obj in effects do
            table.insert(
              behaviorScope,
              obj:GetAttributeChangedSignal(attr):Connect(function()
                ignoreChange = true
                state:set(utility.collectAttributeFromMany(effects, attr, typeof(default), nil, default))
                ignoreChange = false
              end)
            )
          end

          behaviorScope:Observer(state):onChange(function()
            if ignoreChange then
              ignoreChange = false
              return
            end

            local newValue = peek(state)

            if newValue == NIL then
              return
            end

            utility.record("save inputs", function()
              for _, obj in effects do
                obj:SetAttribute(attr, newValue)
              end
            end)

            if behavior.handle_inputs then
              onChange()
            end
          end)
        end
      end
    end

    availableInputs:set(inputs)
    selectedEffectType:set(key)
  end

  local function onZoomInput(input: InputObject)
    if input.UserInputType ~= Enum.UserInputType.MouseWheel then
      return
    end

    local value = peek(zoom)
    local scale = lerp.linear(0, 1, math.clamp(value / 1, 0, 1))

    zoom:set(math.clamp(value + 0.1 * scale * input.Position.Z, 0.05, 2))
  end

  local tabBarSize = scope:Value(Vector2.zero)
  local tabBarPadding = scope:Computed(function(use)
    local pad = use(ui_conf.padding.side)
    return use(selectedEffectType) ~= nil and pad or 0
  end)

  local frame = scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:New "Frame" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        Visible = hidden,

        ZIndex = 10,

        [Children] = {
          scope:Padding(ui_conf.padding.side),

          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,

            Wraps = true,

            VerticalAlignment = Enum.VerticalAlignment.Center,
            HorizontalAlignment = Enum.HorizontalAlignment.Center,

            VerticalFlex = Enum.UIFlexAlignment.Fill,
            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:ForPairs(props.effects, function(_, scope, key, effects)
            if #effects == 0 then
              return
            end

            local order = SELECTION_ORDER[key]

            if not order then
              return
            end

            return order[1],
              scope:Hover "TextButton" {
                BackgroundColor3 = ui_conf.colors.surface,

                FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

                Text = order[2],
                Size = UDim2.fromOffset(75, 75),

                TextColor3 = ui_conf.colors.text,
                TextSize = ui_conf.text_sizes.mini,

                TextWrapped = true,

                [OnEvent "MouseButton1Click"] = function()
                  local list = indexStorage[key]

                  currentEffectKey = key
                  keyval:set(key)

                  hidden:set(false)
                  selectedTabIndex:set(list and list[1] or 1)

                  updateBehavior(key, effects)
                end,

                [Children] = {
                  scope:Round(ui_conf.rounding.base),
                  scope:Padding(ui_conf.padding.side),
                },
              }
          end),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        Visible = scope:Computed(function(use)
          return not use(hidden)
        end),

        [Children] = {
          scope:New "Frame" {
            BackgroundTransparency = 1,

            Size = UDim2.new(0, sidebarWidth, 1, 0),

            [Children] = {
              scope:Padding(ui_conf.padding.side),

              SideBar(scope, {
                path = pathValue,

                key = keyval,
                effects = props.effects,

                on_change = onChange,
                replace_points = replaceControlPoints,
              }),
            },
          },

          scope:New "Frame" {
            AutomaticSize = Enum.AutomaticSize.Y,

            BackgroundTransparency = 1,

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Size = UDim2.new(1, -sidebarWidth, 0, 0),

            [Out "AbsoluteSize"] = tabBarSize,

            [Children] = {
              scope:Padding(0, tabBarPadding, ui_conf.padding.side, ui_conf.padding.side),

              scope:New "UIListLayout" {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = scope:Computed(function(use)
                  return UDim.new(0, use(ui_conf.padding.prop))
                end),
              },

              TabBar(scope, {
                selected = selectedTabIndex,
                tabs = scope:Computed(function(use)
                  local list = getComputedBehaviorList(EffectBehavior[use(selectedEffectType)], use)

                  local tabs = {}

                  if list then
                    selectedTabIndex:set(math.min(peek(selectedTabIndex), #list))

                    for _, v in list do
                      table.insert(tabs, v.name)
                    end
                  end

                  return tabs
                end),
              }),

              TabBar(scope, {
                selected = selectedExpandIndex,
                tabs = scope:Computed(function(use)
                  local behavior = getBehavior(use, selectedEffectType, true)

                  if not behavior or not behavior.expand then
                    return {}
                  end

                  local tabs = {}

                  if behavior then
                    local list = getComputedBehaviorList(behavior.expand, use)

                    if list then
                      selectedExpandIndex:set(math.min(peek(selectedExpandIndex), #list))

                      for _, v in list do
                        table.insert(tabs, v.name)
                      end
                    end
                  end

                  return tabs
                end),
              }),
            },
          },

          scope:New "Frame" {
            BackgroundTransparency = 1,

            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.fromScale(1, 1),

            Size = scope:Computed(function(use)
              return UDim2.new(1, -sidebarWidth, 1, -use(tabBarSize).Y / use(ui_conf.scale))
            end),

            [OnEvent "InputBegan"] = onZoomInput,
            [OnEvent "InputChanged"] = onZoomInput,

            [Children] = {
              scope:New "ImageLabel" {
                BackgroundColor3 = ui_conf.colors.base,
                Image = "rbxassetid://108515364844894",

                Size = scope:Computed(function(use)
                  return UDim2.new(1, 0, 1, -(use(bottomBarSize).Y / use(ui_conf.scale) + use(bottomBarPadding)))
                end),

                ImageTransparency = 0.9,
                ImageColor3 = ui_conf.colors.text,

                ScaleType = Enum.ScaleType.Tile,
                TileSize = UDim2.fromOffset(42, 42),

                [Children] = {
                  scope:New "ImageLabel" {
                    BackgroundTransparency = 1,
                    Size = UDim2.fromScale(1, 1),

                    Image = "rbxassetid://140351922281694",
                    ImageColor3 = ui_conf.colors.base,
                  },
                },
              },

              scope:New "CanvasGroup" {
                BackgroundTransparency = 1,

                ZIndex = 10000,

                Size = scope:Computed(function(use)
                  return UDim2.new(1, 0, 1, -(use(bottomBarSize).Y / use(ui_conf.scale) + use(bottomBarPadding)))
                end),

                [Children] = {
                  overlayValue:set(scope:New "ImageButton" {
                    BackgroundTransparency = 1,

                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = scope:Spring(position, 30, 1),

                    Size = scope:Spring(
                      scope:Computed(function(use)
                        local size = 1 * use(zoom)
                        return UDim2.fromScale(size, size)
                      end),
                      30,
                      1
                    ),

                    [Children] = {
                      scope:New "ImageButton" {
                        BackgroundTransparency = 1,

                        AnchorPoint = Vector2.new(0.5, 0.5),

                        Size = scope:Computed(function(use)
                          return UDim2.fromScale(1 / use(zoom), 1 / use(zoom))
                        end),

                        Position = scope:Computed(function(use)
                          local pos = use(position)
                          return UDim2.new(0.5, -pos.X.Offset, 0.5, -pos.Y.Offset)
                        end),

                        ZIndex = -100,

                        [Children] = {
                          scope:OnHold(holding, function(mousePos)
                            local delta = lastMousePos and mousePos - lastMousePos or Vector2.zero
                            lastMousePos = mousePos

                            position:set(peek(position) + UDim2.fromOffset(delta.X, delta.Y))
                          end, Enum.UserInputType.MouseButton1, Enum.KeyCode.LeftShift, true),
                        },

                        [OnEvent "MouseButton1Click"] = function()
                          if peek(holding) then
                            return
                          end

                          local pos = UserInputService:GetMouseLocation()

                          local function newPoint()
                            local pts = currentCtrlPts
                            local overlay = peek(overlayValue)

                            local scaled = ((pos - overlay.AbsolutePosition) / overlay.AbsoluteSize)

                            local afterIdx = 0

                            for i, p in pts do
                              if p.Position.X.Scale > scaled.X then
                                break
                              end

                              afterIdx = i
                            end

                            insertControlPoint(
                              afterIdx + 1,
                              Path2DControlPoint.new(UDim2.fromScale(scaled.X, scaled.Y))
                            )
                          end

                          if
                            UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
                            or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
                          then
                            newPoint()
                            return
                          end

                          conf.ctx:is(ctx):during(function()
                            scope:Options({
                              position = pos,
                              options = {
                                {
                                  name = "New Point",
                                  on_click = newPoint,
                                },
                                if currentEffectKey
                                  then {
                                    name = "Load Curve",
                                    on_click = function()
                                      local objs = peek(props.effects)[currentEffectKey]

                                      local ref = objs[1]

                                      if not ref then
                                        return
                                      end

                                      local b1 = getBehavior(peek, currentEffectKey, true)
                                      local b2 = getBehavior(peek, currentEffectKey)

                                      local data =
                                        ref:GetAttribute(b1 == b2 and `{b1.name}_Curve` or `{b1.name}_{b2.name}_Curve`)

                                      if typeof(data) ~= "string" then
                                        return
                                      end

                                      -- lol so many conversion functions
                                      local points =
                                        utility.arrayToPath(utility.pointsToArray(emit_utility.deserializePath(data)))

                                      replaceControlPoints(points)
                                    end,
                                  }
                                  else nil,
                                {
                                  name = "Shift Points",
                                  on_click = function()
                                    scope:Prompt({
                                      title = "Point Shifter",

                                      padding = 0,
                                      position = pos,

                                      automatic_width = true,

                                      child = function(scope)
                                        local a = scope:Value(nil)
                                        local b = scope:Value(nil)

                                        local disabled = scope:Computed(function(use)
                                          local v1, v2 = use(a), use(b)
                                          return v1 == nil or v2 == nil
                                        end)

                                        return scope:New "Frame" {
                                          AutomaticSize = Enum.AutomaticSize.XY,
                                          BackgroundTransparency = 1,

                                          [Children] = {
                                            scope:Padding(ui_conf.padding.side),

                                            scope:New "Frame" {
                                              AutomaticSize = Enum.AutomaticSize.X,
                                              BackgroundTransparency = 1,

                                              Size = scope:Computed(function(use)
                                                return UDim2.fromOffset(
                                                  0,
                                                  use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
                                                )
                                              end),

                                              [Children] = {
                                                scope:New "UIListLayout" {
                                                  SortOrder = Enum.SortOrder.LayoutOrder,
                                                  FillDirection = Enum.FillDirection.Horizontal,

                                                  Padding = scope:Computed(function(use)
                                                    return UDim.new(0, use(ui_conf.padding.side))
                                                  end),
                                                },

                                                scope:NumberField({
                                                  value = a,
                                                  size = UDim2.new(0, 50, 1, 0),

                                                  placeholder = "from",

                                                  min = 0,
                                                  max = math.huge,
                                                }),

                                                scope:NumberField({
                                                  value = b,
                                                  size = UDim2.new(0, 50, 1, 0),

                                                  placeholder = "to",

                                                  min = 0,
                                                  max = math.huge,
                                                }),

                                                scope:Hover "TextButton" {
                                                  AutomaticSize = Enum.AutomaticSize.XY,

                                                  AnchorPoint = Vector2.new(1, 0),
                                                  Position = UDim2.fromScale(1, 0),

                                                  RichText = true,

                                                  Text = scope:Computed(function(use)
                                                    local v1, v2 = use(a), use(b)

                                                    return v1
                                                        and v2
                                                        and `shift by <font family="rbxassetid://16658246179">{string.format(
                                                          "%.2fx",
                                                          v1 / v2
                                                        )}</font>`
                                                      or "shift"
                                                  end),

                                            -- stylua: ignore
                                            BackgroundColor3 = scope:Switch(disabled, ui_conf.colors.muted, ui_conf.colors.primary, 30, 1),
                                            -- stylua: ignore
                                            TextColor3 = scope:Switch(disabled, ui_conf.colors.text, ui_conf.colors.base, 30, 1),

                                                  FontFace = ui_conf.font,
                                                  TextSize = ui_conf.text_sizes.mini,

                                                  [OnEvent "MouseButton1Click"] = function()
                                                    if peek(disabled) then
                                                      return
                                                    end

                                                    local v1, v2 = peek(a), peek(b)
                                                    local div = v1 / v2

                                                    local pts = {}

                                                    for i, p in currentCtrlPts do
                                                      table.insert(
                                                        pts,
                                                        Path2DControlPoint.new(
                                                          if i == 1
                                                              or i == #currentCtrlPts
                                                            then p.Position
                                                            else UDim2.fromScale(
                                                              math.clamp(p.Position.X.Scale * div, 0, 1),
                                                              p.Position.Y.Scale
                                                            ),
                                                          p.LeftTangent,
                                                          p.RightTangent
                                                        )
                                                      )
                                                    end

                                                    replaceControlPoints(pts)
                                                    onChange()

                                                    scope:doCleanup()
                                                  end,

                                                  [Children] = {
                                                    scope:Round(ui_conf.rounding.mini),
                                                    scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
                                                  },
                                                },
                                              },
                                            },
                                          },
                                        } :: Frame
                                      end,
                                    })
                                  end,
                                },
                              },
                            })
                          end)
                        end,
                      },
                    },
                  } :: Frame),
                },
              },

              scope:New "CanvasGroup" {
                BackgroundTransparency = 1,

                Size = scope:Computed(function(use)
                  return UDim2.new(1, 0, 1, -(use(bottomBarSize).Y / use(ui_conf.scale) + use(bottomBarPadding)))
                end),

                [Children] = {
                  scope:New "Frame" {
                    BackgroundTransparency = 1,

                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Size = UDim2.fromScale(1, 1),

                    Position = scope:Spring(position, 30, 1),

                    [Children] = {
                      scope:New "UIScale" {
                        Scale = scope:Spring(zoom, 30, 1),
                      },

                      pathValue:set(scope:New "Path2D" {
                        Thickness = 3,
                        Color3 = ui_conf.colors.text,
                      } :: Path2D),
                    },
                  },
                },
              },

              scope:New "Frame" {
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.new(0, 1),

                Position = scope:Computed(function(use)
                  return UDim2.new(0, 0, 1, -use(bottomBarPadding))
                end),

                Size = scope:Computed(function(use)
                  return UDim2.new(1, -use(bottomBarPadding), 0, 0)
                end),

                [Out "AbsoluteSize"] = bottomBarSize,

                [Children] = {
                  BottomBar(scope, {
                    nil_symbol = NIL,
                    padding = bottomBarPadding,
                    inputs = scope:ForValues(availableInputs, function(_, _, data)
                      return {
                        type = data.type,
                        input = data.input,
                      }
                    end),
                  }),
                },
              },
            },
          },
        },
      },
    },
  }

  local function onIndexChange()
    if not currentEffectKey then
      return
    end

    updateBehavior(currentEffectKey, peek(props.effects)[currentEffectKey])
  end

  scope:Observer(selectedTabIndex):onChange(onIndexChange)
  scope:Observer(selectedExpandIndex):onChange(onIndexChange)

  scope:Observer(props.effects):onBind(function()
    local hide = false

    local key
    local effects

    local current = peek(props.effects)

    for k, v in current do
      if #v == 0 then
        continue
      end

      if not EffectBehavior[k] or (k == "mesh_decals" and #current.meshes ~= 0) then
        continue
      end

      if effects then
        hide = true
        break
      end

      key = k
      effects = v
    end

    if hide then
      hidden:set(true)
      multiple:set(true)

      availableInputs:set({})
      selectedEffectType:set(nil)
    else
      local list = indexStorage[key]

      currentEffectKey = key
      keyval:set(key)

      hidden:set(false)
      multiple:set(#current.meshes ~= 0 and #current.mesh_decals ~= 0)

      selectedTabIndex:set(list and list[1] or 1)

      updateBehavior(key, effects)
    end
  end)

  replaceControlPoints(conf.default_curve)

  return frame,
    scope:Computed(function(use)
      return use(multiple) and not use(hidden)
    end),
    function()
      hidden:set(true)
      availableInputs:set({})
      selectedEffectType:set(nil)
    end
end

return CurveEditor
]]></ProtectedString>
