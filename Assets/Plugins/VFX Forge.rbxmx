						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local utility = require("../../lib/utility")
local handlers = require("./handlers")

type props = {
  effects: Fusion.Value<{
    particles: { ParticleEmitter },
    beams: { Beam },
    meshes: { Model },
    mesh_decals: { Decal },
    spin_models: { Model },
  }>,
}

local copylist = {
  {
    "tween_properties",
    {
      { "_END_VALUE", handlers.Attribute, "EndValue" },

      { "Duration", handlers.Attribute },

      { "Speed_Start", handlers.Attribute, "SpeedStart" },
      { "Speed_End", handlers.Attribute, "SpeedEnd" },
      { "Speed_Duration", handlers.Attribute, "SpeedDuration" },

      { "EmitDelay", handlers.Attribute },
    },
  },

  {
    "particles",
    {
      { "Brightness", handlers.Property },
      { "Color", handlers.Property },
      { "LightEmission", handlers.Property },
      { "LightInfluence", handlers.Property },
      { "Size", handlers.Property },
      { "Squash", handlers.Property },
      { "Transparency", handlers.Property },
      { "ZOffset", handlers.Property },
      { "Lifetime", handlers.Property },
      { "Rate", handlers.Property },
      { "Rotation", handlers.Property },
      { "Speed", handlers.Property },
      { "SpreadAngle", handlers.Property },
      { "ShapePartial", handlers.Property, "Partial" },
      { "Acceleration", handlers.Property },
      { "Drag", handlers.Property },
      { "TimeScale", handlers.Property },
      { "TimeScale_Start", handlers.Attribute, "StartTScale" },
      { "TimeScale_End", handlers.Attribute, "EndTScale" },
      { "TimeScale_Duration", handlers.Attribute, "TScaleDuration" },
      { "VelocityInheritance", handlers.Property },
      { "EmitCount", handlers.Attribute },
      { "EmitDelay", handlers.Attribute },
      { "EmitDuration", handlers.Attribute },
    },
  },

  {
    "beams",
    {
      { "Color", handlers.Property },
      { "Transparency", handlers.Property },
      { "Transparency_Scale_Start", handlers.Attribute, "StartTpScale" },
      { "Transparency_Scale_End", handlers.Attribute, "EndTpScale" },
      { "LightEmission", handlers.Property },
      { "LightInfluence", handlers.Property },
      { "TextureLength", handlers.Property },
      { "TextureSpeed", handlers.Property },
      { "ZOffset", handlers.Property },
      { "CurveSize0", handlers.Property },
      { "CurveSize1", handlers.Property },
      { "Width0", handlers.Property },
      { "Width0_Start", handlers.Attribute, "StartWidth0" },
      { "Width0_End", handlers.Attribute, "EndWidth0" },
      { "Width1", handlers.Property },
      { "Width1_Start", handlers.Attribute, "StartWidth1" },
      { "Width1_End", handlers.Attribute, "EndWidth1" },
      { "Speed_Start", handlers.Attribute, "StartSpeed" },
      { "Speed_End", handlers.Attribute, "EndSpeed" },
      { "Speed_Duration", handlers.Attribute, "SpeedDuration" },
      { "EmitCount", handlers.Attribute },
      { "EmitDelay", handlers.Attribute },
      { "EmitDuration", handlers.Attribute },
    },
  },

  {
    "trails",
    {
      { "Brightness", handlers.Property },
      { "Color", handlers.Property },
      { "LightEmission", handlers.Property },
      { "LightInfluence", handlers.Property },
      { "TextureLength", handlers.Property },
      { "Transparency", handlers.Property },
      { "Lifetime", handlers.Property },
      { "MaxLength", handlers.Property },
      { "MinLength", handlers.Property },
      { "WidthScale", handlers.Property },
    },
  },

  {
    "meshes",
    {
      { "EffectDuration", handlers.Attribute, "Duration" },
      { "Rate", handlers.Attribute, "Rate" },

      { "Part_Transparency_Start", handlers.Attribute, "TpStart" },
      { "Part_Transparency_End", handlers.Attribute, "TpEnd" },

      { "Part_RotSpeed_Start", handlers.Attribute, "RotSpeedStart" },
      { "Part_RotSpeed_End", handlers.Attribute, "RotSpeedEnd" },

      { "MinInitRot", handlers.Attribute, "MinRot" },
      { "MaxInitRot", handlers.Attribute, "MaxRot" },

      { "Speed_Start", handlers.Attribute, "SpeedStart" },
      { "Speed_End", handlers.Attribute, "SpeedEnd" },
      { "Speed_Duration", handlers.Attribute, "SpeedDuration" },

      { "EmitDelay", handlers.Attribute },
      { "EmitDuration", handlers.Attribute },
    },
  },

  {
    "shockwaves",
    {
      { "RayDirection", handlers.Attribute },
    },
  },

  {
    "beziers",
    {
      { "Duration", handlers.Attribute },
      { "SpreadAngle", handlers.Attribute },

      { "Rate", handlers.Attribute, "Rate" },
      { "ShapePartial", handlers.Attribute, "Partial" },

      { "MirrorRotation", handlers.Attribute, "Rotation" },

      { "Part_RotSpeed_Start", handlers.Attribute, "RotSpeedStart" },
      { "Part_RotSpeed_End", handlers.Attribute, "RotSpeedEnd" },

      { "MinInitRot", handlers.Attribute, "MinRot" },
      { "MaxInitRot", handlers.Attribute, "MaxRot" },

      { "ProjectileLifetime", handlers.Attribute, "Lifetime" },
      { "ProjectileSpeed", handlers.Attribute, "Speed" },

      { "Speed_Start", handlers.Attribute, "SpeedStart" },
      { "Speed_End", handlers.Attribute, "SpeedEnd" },
      { "Speed_Duration", handlers.Attribute, "SpeedDuration" },

      { "EmitDelay", handlers.Attribute },
      { "EmitDuration", handlers.Attribute },

      { "DestroyDelay", handlers.Attribute },
    },
  },

  {
    "shockwave_rings",
    {
      { "Radius", handlers.Attribute },
      { "Segments", handlers.Attribute },
      { "Lifetime", handlers.Attribute },

      { "Transparency_Start", handlers.Attribute, "TpStart" },
      { "Transparency_End", handlers.Attribute, "TpEnd" },

      { "SizeScaleStart", handlers.Attribute, "ScaleStart" },
      { "SizeScaleEnd", handlers.Attribute, "ScaleEnd" },

      { "MinSize", handlers.Attribute },
      { "MaxSize", handlers.Attribute },

      { "EmitDelay", handlers.Attribute },
    },
  },

  {
    "shockwave_lines",
    {
      { "Duration", handlers.Attribute },
      { "Lifetime", handlers.Attribute },

      { "Length", handlers.Attribute },
      { "Direction", handlers.Attribute },
      { "Rotation", handlers.Attribute },

      { "Rate_Start", handlers.Attribute, "RateStart" },
      { "Rate_End", handlers.Attribute, "RateEnd" },

      { "Transparency_Start", handlers.Attribute, "TpStart" },
      { "Transparency_End", handlers.Attribute, "TpEnd" },

      { "Scale_Start", handlers.Attribute, "ScaleStart" },
      { "Scale_End", handlers.Attribute, "ScaleEnd" },

      { "SizeScaleStart", handlers.Attribute, "ScaleIn" },
      { "SizeScaleEnd", handlers.Attribute, "ScaleOut" },

      { "MinSize", handlers.Attribute },
      { "MaxSize", handlers.Attribute },

      { "EmitDelay", handlers.Attribute },
    },
  },

  {
    "shockwave_debris",
    {
      { "Amount", handlers.Attribute },
      { "Lifetime", handlers.Attribute },

      { "LinearMagnitude", handlers.Attribute },
      { "AngularMagnitude", handlers.Attribute },

      { "Transparency_Start", handlers.Attribute, "TpStart" },
      { "Transparency_End", handlers.Attribute, "TpEnd" },

      { "SizeScaleEnd", handlers.Attribute, "ScaleEnd" },

      { "MinSize", handlers.Attribute },
      { "MaxSize", handlers.Attribute },

      { "MinDirection", handlers.Attribute },
      { "MaxDirection", handlers.Attribute },

      { "EmitDelay", handlers.Attribute },
    },
  },

  {
    "mesh_decals",
    {
      { "Transparency_Start", handlers.Attribute, "TpStart" },
      { "Transparency_End", handlers.Attribute, "TpEnd" },
      { "Color3", handlers.Property, "ColorStart" },
      {
        "Color3",
        handlers.Property,
        "ColorEnd",
        function(obj: Decal)
          local mesh = obj:FindFirstAncestorOfClass("Model")
          local goal = mesh and mesh:FindFirstChild("End")
          local decal = goal:FindFirstChild(obj.Name)

          if decal and decal:IsA("Decal") then
            return decal
          end

          return nil
        end,
      },
    },
  },

  {
    "spin_models",
    {
      { "SpinRotation", handlers.Attribute, "Rotation" },
      { "SpinDuration", handlers.Attribute, "Duration" },

      { "Scale_Start", handlers.Attribute, "ScaleStart" },
      { "Scale_End", handlers.Attribute, "ScaleEnd" },

      { "SpinSpeed_Start", handlers.Attribute, "SpeedStart" },
      { "SpinSpeed_End", handlers.Attribute, "SpeedEnd" },
      { "SpinSpeed_Duration", handlers.Attribute, "SpeedDuration" },

      { "EmitDelay", handlers.Attribute },
    },
  },

  {
    "screen_effects",
    {
      { "PartDistance", handlers.Attribute, "Distance" },
      { "PartScale", handlers.Attribute, "Scale" },

      { "OffsetPosition", handlers.Attribute, "Position" },
      { "OffsetRotation", handlers.Attribute, "Rotation" },
    },
  },

  {
    "screen_shakes",
    {
      { "Falloff", handlers.Attribute },

      { "Amplitude", handlers.Attribute },
      { "Frequency", handlers.Attribute },

      { "FadeInTime", handlers.Attribute },
      { "FadeOutTime", handlers.Attribute },
      { "SustainTime", handlers.Attribute },

      { "PositionInfluence", handlers.Attribute, "PosInfluence" },
      { "RotationInfluence", handlers.Attribute, "RotInfluence" },

      { "EmitDelay", handlers.Attribute },
      { "EmitDuration", handlers.Attribute },
    },
  },
}

local function PropertyShifter(scope: ui_types.scope, props: props)
  local amountValue = scope:Value(nil)

  local selected = scope:Value({})
  local scaledListContentSize = scope:Value(Vector2.zero)

  local listContentSize = scope:Computed(function(use)
    return use(scaledListContentSize) / use(ui_conf.scale)
  end)

  local buttonHeight = scope:Computed(function(use)
    return use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
  end)

  local flattened = scope:Computed(function(use)
    local sel = peek(selected)
    local effects = use(props.effects)

    local added = {}
    local flattened = {}

    for _, data in copylist do
      if #effects[data[1]] == 0 then
        continue
      end

      for _, info in data[2] do
        local name = info[1]
        local handler = info[2]
        local alias = info[3]

        local key = alias or name

        if table.find(added, key) then
          continue
        end

        table.insert(added, key)

        local entry = sel[handler]

        if not entry then
          entry = {}
          sel[handler] = entry
        end

        local item = entry[key]

        if not item then
          item = {
            selected = scope:Value(false),
          }

          entry[key] = item
        end

        item.reference = effects[1]

        table.insert(flattened, {
          name = key,
          item = item,
        })
      end
    end

    return flattened
  end)

  local function shift(factor: (x: number) -> number)
    for handler, entry in peek(selected) do
      for name, item in entry do
        if not peek(item.selected) then
          continue
        end

        for key, effects in peek(props.effects) do
          if #effects == 0 then
            continue
          end

          for i, v in copylist do
            if v[1] == key then
              for _, data in v[2] do
                if (data[1] == name or data[3] == name) and data[2] == handler then
                  for _, obj in effects do
                    local useObj = typeof(data[4]) == "function" and data[4](obj) or obj

                    if useObj then
                      handler(useObj, data[1], factor)
                    end
                  end

                  break
                end
              end
            end
          end
        end
      end
    end
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UISizeConstraint" {
        MaxSize = scope:Computed(function(use)
          return Vector2.new(
            math.huge,
            use(listContentSize).Y
              + use(buttonHeight) * 2
              + use(ui_conf.padding.side) * (#use(flattened) == 0 and 3 or 4)
              + 1
          )
        end),
      },

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalFlex = Enum.UIFlexAlignment.Fill,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:NumberField({
        min_size = scope:Computed(function(use)
          return Vector2.new(0, use(buttonHeight))
        end),

        max_size = scope:Computed(function(use)
          return Vector2.new(math.huge, use(buttonHeight))
        end),

        value = amountValue,

        min = -math.huge,
        max = math.huge,

        placeholder = "amount",
      }),

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.fromScale(1, 1)
        end),

        [Children] = {
          scope:New "UISizeConstraint" {
            MinSize = scope:Computed(function(use)
              return Vector2.new(0, use(buttonHeight))
            end),

            MaxSize = scope:Computed(function(use)
              return Vector2.new(math.huge, use(buttonHeight))
            end),
          },

          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "×",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),
            TextSize = ui_conf.text_sizes.special,

            [OnEvent "MouseButton1Click"] = function()
              local amount = peek(amountValue)

              if not amount then
                return
              end

              utility.record("multiply properties", function()
                shift(function(x)
                  return x * amount
                end)
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "+",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),
            TextSize = ui_conf.text_sizes.special,

            [OnEvent "MouseButton1Click"] = function()
              local amount = peek(amountValue)

              if not amount then
                return
              end

              utility.record("add properties", function()
                shift(function(x)
                  return x + amount
                end)
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "-",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = scope:Font(ui_conf.font, Enum.FontWeight.Bold),
            TextSize = ui_conf.text_sizes.special,

            [OnEvent "MouseButton1Click"] = function()
              local amount = peek(amountValue)

              if not amount then
                return
              end

              utility.record("subtract properties", function()
                shift(function(x)
                  return x - amount
                end)
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "÷",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = scope:Font(ui_conf.font, Enum.FontWeight.Bold),
            TextSize = ui_conf.text_sizes.special,

            [OnEvent "MouseButton1Click"] = function()
              local amount = peek(amountValue)

              if not amount then
                return
              end

              utility.record("divide properties", function()
                shift(function(x)
                  return x / amount
                end)
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 1),

        [Children] = {
          scope:Scrollable({
            content_size = listContentSize,
            children = {
              scope:New "CanvasGroup" {
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,

                Size = UDim2.fromScale(1, 0),

                [Children] = {
                  scope:Round(ui_conf.rounding.base),

                  scope:New "UIListLayout" {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    [Out "AbsoluteContentSize"] = scaledListContentSize,
                  },

                  scope:ForValues(flattened, function(_, scope, data)
                    return scope:Hover "TextButton" {
                      AutomaticSize = Enum.AutomaticSize.Y,

                      Size = UDim2.fromScale(1, 0),

                      AnchorPoint = Vector2.new(1, 0),
                      Position = UDim2.fromScale(1, 0),

                      Text = data.name,

                      BackgroundColor3 = scope:Switch(
                        data.item.selected,
                        scope:AlphaBlend(0.5, ui_conf.colors.surface, ui_conf.colors.primary),
                        ui_conf.colors.surface
                      ),

                      TextColor3 = ui_conf.colors.text,

                      FontFace = ui_conf.font,
                      TextSize = ui_conf.text_sizes.mini,

                      TextXAlignment = Enum.TextXAlignment.Left,
                      TextTruncate = Enum.TextTruncate.SplitWord,

                      [OnEvent "MouseButton1Click"] = function()
                        data.item.selected:set(not peek(data.item.selected))
                      end,

                      [Children] = {
                        scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
                      },
                    }
                  end),
                },
              },
            },
          }),
        },
      },
    },
  }
end

return PropertyShifter
]]></ProtectedString>
						<string name="ScriptGuid">{2B76BCBA-0EC4-4AD4-8B13-8BB2D2BB11D2}</string>
