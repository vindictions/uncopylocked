			<Item class="ModuleScript" referent="RBXF2B9734863EA4127959CACE253AA9041">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local function Switch<T>(
  scope: Fusion.Scope,
  state: Fusion.UsedAs<boolean>,
  a: Fusion.UsedAs<T>,
  b: Fusion.UsedAs<T>,
  speed: Fusion.UsedAs<number>?,
  damping: Fusion.UsedAs<number>?
)
  local switch = scope:Computed(function(use)
    local v1, v2 = use(a), use(b)
    return use(state) and v1 or v2
  end)

  if speed and damping then
    return scope:Spring(switch, speed, damping)
  else
    return switch
  end
end

return Switch
]]></ProtectedString>
					<string name="ScriptGuid">{2A347F88-0331-445B-8F72-741DC34AE5F2}</string>
