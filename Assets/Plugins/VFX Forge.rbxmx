        attr_scope = attrScope,
        attr = currentAttributes,
      }),
    })

    scope:Window({
      id = "curve_editor",
      title = "Curve editor",

      button_icon = "rbxassetid://100216578360193",

      position = Vector2.new(-8, 8),
      anchor = Vector2.new(1, 0),

