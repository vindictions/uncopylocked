					<Item class="ModuleScript" referent="RBX685BC508C5E54959B4FE8AFF310D32B3">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Children = Fusion.Children

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  name: string,
  placeholder: string?,

  value: Fusion.Value<string>,
  options: Fusion.UsedAs<{ string }>,
}

local function Number(scope: ui_types.scope, props: props)
  return scope:New "Frame" {
    BackgroundColor3 = ui_conf.colors.surface,

    Size = scope:Computed(function(use)
      return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.base) + use(ui_conf.padding.base) * 3)
    end),

    [Children] = {
      scope:Round(ui_conf.rounding.mini),
      scope:Padding(ui_conf.padding.side, ui_conf.padding.base, ui_conf.padding.base, ui_conf.padding.base),

      scope:New "TextLabel" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(1, -100 - use(ui_conf.padding.side), 1, 0)
        end),

        Text = props.name,
        TextSize = ui_conf.text_sizes.mini,

        FontFace = ui_conf.font,

        TextTruncate = Enum.TextTruncate.SplitWord,
        TextXAlignment = Enum.TextXAlignment.Left,

        TextColor3 = ui_conf.colors.text,
      },

      scope:New "Frame" {
        BackgroundColor3 = ui_conf.colors.overlay,

        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),

        Size = UDim2.new(0, 100, 1, 0),

        [Children] = {
          scope:Round(ui_conf.rounding.mini),

          scope:Dropdown({
            selected = props.value,
            options = props.options,

            stroke = true,

            pad_top = ui_conf.padding.side,

            item_bg = ui_conf.colors.overlay,
            background = ui_conf.colors.surface,
            scrollbar_bg = ui_conf.colors.base,

            background_sel = scope:AlphaBlend(0.2, ui_conf.colors.overlay, ui_conf.colors.primary),
          }),
        },
      },
    },
  }
end

return Number
]]></ProtectedString>
							<string name="ScriptGuid">{1DF2768C-2F00-4C28-87A2-FB04A6E04442}</string>
