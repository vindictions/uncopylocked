					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local attmap = require("../../mod/attmap")
local utility = require("../../lib/utility")
local storage = require("../../lib/storage")
local emit_utility = require("../../lib/emit/mod/utility")

type props = {
  effects: Fusion.Value<{
    particles: { ParticleEmitter },
    beams: { Beam },
    meshes: { Model },

    shockwave_rings: { Part },
    shockwave_debris: { Part },
  }>,
}

local function Resize(scope: ui_types.scope, props: props)
  local store = storage.new(scope, "resize", {
    min = scope:Value(0.5),
    max = scope:Value(2),
  })

  local factorValue = scope:Value(1)
  local prevFactor = 1

  local function submit(preview: boolean, map: { [string]: { Instance } }?)
    local absoluteFactor = peek(factorValue)
    local factor = absoluteFactor / prevFactor

    local function set(effects)
      for _, obj in effects.particles do
        obj.Size = emit_utility.scaleNumberSequence(obj.Size, factor)
        obj.Speed = NumberRange.new(obj.Speed.Min * factor, obj.Speed.Max * factor)

        obj.Acceleration *= factor
      end

      for _, obj in effects.beams do
        utility.scaleAttribute(obj, factor, "Width0_Start")
        utility.scaleAttribute(obj, factor, "Width1_Start")
        utility.scaleAttribute(obj, factor, "Width0_End")
        utility.scaleAttribute(obj, factor, "Width1_End")

        obj.Width0 *= factor
        obj.Width1 *= factor

        obj.CurveSize0 *= factor
        obj.CurveSize1 *= factor
      end

      for _, obj in effects.trails do
        local a0, a1 = obj.Attachment0, obj.Attachment1

        local ref = attmap[obj]

        if ref then
          local b0, b1 = ref[1], ref[2]

          if b0 and b1 then
            a0, a1 = b0, b1
          end
        end

        if a0 then
          a0.Position *= factor
        end

        if a1 then
          a1.Position *= factor
        end
      end

      for _, obj in effects.meshes do
        local start = obj:FindFirstChild("Start")
        local goal = obj:FindFirstChild("End")

        if not start or not goal then
          continue
        end

        start.Size *= factor
        goal.Size *= factor

        local startMesh = start:FindFirstChildOfClass("SpecialMesh")
        local goalMesh = goal:FindFirstChildOfClass("SpecialMesh")

        if startMesh and goalMesh then
          startMesh.Scale *= factor
          goalMesh.Scale *= factor
        end
      end

      for _, obj in effects.spin_models do
        utility.scaleAttribute(obj, factor, "Scale_Start")
        utility.scaleAttribute(obj, factor, "Scale_End")
      end

      for _, obj in effects.beziers do
        local part = obj:FindFirstChildOfClass("Part")

        if part then
          local de = utility.getEffects({ part })
          set(de)
        end
      end

      for _, obj in effects.shockwave_rings do
        utility.scaleAttribute(obj, factor, "Radius")

        utility.scaleAttribute(obj, factor, "MinSize")
        utility.scaleAttribute(obj, factor, "MaxSize")
      end

      for _, obj in effects.shockwave_lines do
        utility.scaleAttribute(obj, factor, "Length")

        utility.scaleAttribute(obj, factor, "MinSize")
        utility.scaleAttribute(obj, factor, "MaxSize")
      end

      for _, obj in effects.shockwave_debris do
        obj.Size *= factor

        utility.scaleAttribute(obj, factor, "LinearMagnitude")
        utility.scaleAttribute(obj, factor, "AngularMagnitude")

        utility.scaleAttribute(obj, factor, "MinSize")
        utility.scaleAttribute(obj, factor, "MaxSize")
      end

      for _, obj in effects.screen_shakes do
        utility.scaleAttribute(obj, factor, "Falloff")
      end
    end

    local effects = map or peek(props.effects)

    if preview then
      set(effects)
    else
      utility.record("confirm resize", function()
        set(effects)
      end)
    end

    prevFactor = absoluteFactor
  end

  local height = scope:Computed(function(use)
    return use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
  end)

  local size = scope:Computed(function(use)
    return UDim2.new(1, 0, 0, use(height))
  end)

  local prevEffects

  -- reset when plugin is turned off or smth
  table.insert(scope, function()
    factorValue:set(1)
    submit(true)
  end)

  scope:Observer(props.effects):onBind(function()
    factorValue:set(math.min(1, peek(store.max)))

    if prevEffects then
      submit(true, prevEffects)
    end

    prevEffects = peek(props.effects)
  end)

  scope:Observer(factorValue):onChange(function()
    submit(true)
  end)

  return scope:New "Frame" {
    AutomaticSize = Enum.AutomaticSize.Y,
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = size,

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:NumberField({
            value = store.min,

            size = UDim2.fromScale(0.75, 1),
            padding = ui_conf.padding.base,

            min = 0.001,
            max = store.max,

            placeholder = "min",
          }),

          scope:NumberField({
            value = factorValue,
            padding = ui_conf.padding.base,

            min = 0.001,
            max = math.huge,

            placeholder = "factor",
          }),

          scope:NumberField({
            value = store.max,

            size = UDim2.fromScale(0.75, 1),
            padding = ui_conf.padding.base,

            min = store.min,
            max = math.huge,

            placeholder = "min",
          }),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(1, 0, 0, 8 + use(ui_conf.padding.prop))
        end),

        [Children] = {
          scope:Slider({
            value = factorValue,
            background = ui_conf.colors.surface,

            size = UDim2.new(1, 0, 0, 8),

            min = store.min,
            max = store.max,
          }),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = size,

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:Hover "TextButton" {
            Size = UDim2.fromScale(1, 1),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Text = "resize",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.mini,

            [OnEvent "MouseButton1Click"] = function()
              submit()

              prevFactor = 1
              factorValue:set(1)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },

          scope:Hover "ImageButton" {
            BackgroundColor3 = ui_conf.colors.surface,

            [OnEvent "MouseButton1Click"] = function()
              factorValue:set(1)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),

              scope:New "UISizeConstraint" {
                MinSize = scope:Computed(function(use)
                  return Vector2.new(use(height), use(height))
                end),
              },

              scope:New "ImageLabel" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.one * 0.5,
                Position = UDim2.fromScale(0.5, 0.5),

                Size = UDim2.fromOffset(14, 14),

                Image = "rbxassetid://116360941559301",
                ImageColor3 = ui_conf.colors.text,
              },
            },
          },
        },
      },
    },
  }
end

return Resize
]]></ProtectedString>
						<string name="ScriptGuid">{75248BE1-DE01-4F63-9692-57190AF56AE6}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
