				</Properties>
				<Item class="ModuleScript" referent="RBX9F94BEB44BBA49C6856276E9CB5E654C">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local updates = require("../../.updates")
local storage = require("../../lib/storage")

type props = {}

type banner_props = {
  id: string,
  text: string,
}

-- derived from https://github.com/axiom-co/markdowner/blob/main/src/init.luau (mit license)
local patterns = {
  "%*%*%*[%w%p%s]+%*%*%*",
  "%*%*[%w%p%s]+%*%*",
  "%*[%w%p%s]+%*",
  "~~[%w%p%s]+~~",
  "`[%w%p%s]+`",
  "__[%w%p%s]+__",
  "^# [%w%p%s]+$",
  "^## [%w%p%s]+$",
  "^### [%w%p%s]+$",
}

local syntax = {
  "***",
  "**",
  "*",
  "~~",
  "`",
  "__",
  "# ",
  "## ",
  "### ",
}

local richtext = {
  { "<b><i>", "</i></b>" },
  { "<b>", "</b>" },
  { "<i>", "</i>" },
  { "<s>", "</s>" },
  { "<font family='rbxasset://fonts/families/BuilderMono.json'>", "</font>" },
  { "<u>", "</u>" },
  {
    function(use)
      return `<b><font size='{use(ui_conf.text_sizes.special)}' weight='semibold'>`
    end,
    "</font></b>",
  },
  {
    function(use)
      return `<b><font size='{use(ui_conf.text_sizes.title)}' weight='semibold'>`
    end,
    "</font></b>",
  },
  {
    function(use)
      return `<b><font size='{use(ui_conf.text_sizes.base)}' weight='semibold'>`
    end,
    "</font></b>",
  },
}

local function toRichText(scope, text: string)
  local lines = string.split(text:gsub("^%s+\n", ""):gsub("%s+$", ""), "\n")

  return scope:Computed(function(use)
    local raw = {}
    local res = {}

    local from = 0

    for i, line in lines do
      if i == 1 then
        from = line:match("^ +"):len()
      end

      line = string.sub(line, from + 1, -1)

      table.insert(raw, line)

      for index, pattern in patterns do
        line = line:gsub(pattern, function(result)
          local a = richtext[index][1]
          local b = richtext[index][2]

          if typeof(a) == "function" then
            a = a(use)
          end

          if typeof(b) == "function" then
            b = b(use)
          end

          return `{a}{result:gsub(syntax[index], "")}{b}`
        end)
      end

      table.insert(res, line)
    end

    return { table.concat(res, "\n"), table.concat(raw, "\n") }
  end)
end

local function UpdateLog(scope: ui_types.scope, props: props)
  local pstore = storage.new(scope, "update_log", {
    banners_hidden = {},
  })

  local scaledContentSize = scope:Value(Vector2.zero)

  local contentSize = scope:Computed(function(use)
    return use(scaledContentSize) / use(ui_conf.scale)
  end)

  local function Banner(props: banner_props)
    if pstore.banners_hidden[props.id] == true then
      return
    end

    local scope = scope:innerScope()

    return scope:Hover "Frame" {
      AutomaticSize = Enum.AutomaticSize.Y,
      Size = UDim2.fromScale(1, 0),

      BackgroundColor3 = scope:AlphaBlend(0.4, ui_conf.colors.base, ui_conf.colors.primary),

      [Children] = {
        scope:Round(ui_conf.rounding.base),
        scope:Padding(ui_conf.padding.side, ui_conf.padding.base),

        scope:New "ImageButton" {
          BackgroundTransparency = 1,

          AnchorPoint = Vector2.new(1, 0.5),
          Position = UDim2.fromScale(1, 0.5),

          Size = scope:Computed(function(use)
            local size = use(ui_conf.text_sizes.mini)
            return UDim2.fromOffset(size, size)
          end),

          Image = "rbxassetid://133032633237208",
          ImageColor3 = scope:AlphaBlend(0.4, ui_conf.colors.text, ui_conf.colors.primary),

          [OnEvent "MouseButton1Click"] = function()
            pstore.banners_hidden[props.id] = true
            pstore:write("banners_hidden")

            scope:doCleanup()
          end,
        },

        scope:New "TextBox" {
          AutomaticSize = Enum.AutomaticSize.Y,
          BackgroundTransparency = 1,

          Size = scope:Computed(function(use)
            return UDim2.new(1, -(use(ui_conf.text_sizes.base) + use(ui_conf.padding.base)), 0, 0)
          end),

          TextSize = ui_conf.text_sizes.mini,

          Text = props.text,
          TextColor3 = ui_conf.colors.text,

          TextTruncate = Enum.TextTruncate.SplitWord,
          TextXAlignment = Enum.TextXAlignment.Left,

          TextEditable = false,
        },
      },
    }
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UISizeConstraint" {
        MaxSize = scope:Computed(function(use)
          return Vector2.new(math.huge, use(contentSize).Y + use(ui_conf.padding.side) * 2)
        end),
      },

      scope:Scrollable({
        content_size = contentSize,
        padding = 1,

        children = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),

            [Out "AbsoluteContentSize"] = scaledContentSize,
          },

          Banner({
            id = "docs_link",
            text = "Check out the docs at zilibobi.github.io/forge-docs",
          }),

          Banner({
            id = "discord_invite",
            text = "Join our Discord server: discord.gg/Qme9KPN3pF",
          }),

          scope:ForValues(updates, function(_, scope, update)
            local focused = scope:Value(false)
            local textCompute = toRichText(scope, update.notes)

            return scope:Hover "Frame" {
              AutomaticSize = Enum.AutomaticSize.Y,
              BackgroundColor3 = ui_conf.colors.surface,

              Size = UDim2.fromScale(1, 0),

              [Children] = {
                scope:Round(ui_conf.rounding.base),
                scope:Padding(ui_conf.padding.side),

                scope:New "UIListLayout" {
                  SortOrder = Enum.SortOrder.LayoutOrder,

                  Padding = scope:Computed(function(use)
                    return UDim.new(0, use(ui_conf.padding.side))
                  end),
                },

                scope:New "TextLabel" {
                  AutomaticSize = Enum.AutomaticSize.Y,
                  BackgroundTransparency = 1,

                  Size = UDim2.fromScale(1, 0),

                  FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),
                  TextSize = ui_conf.text_sizes.base,

                  Text = `Version {update.v}`,
                  TextColor3 = ui_conf.colors.text,

                  TextXAlignment = Enum.TextXAlignment.Left,
                },

                scope:New "TextBox" {
                  AutomaticSize = Enum.AutomaticSize.Y,
                  BackgroundTransparency = 1,

                  Size = UDim2.fromScale(1, 0),

                  FontFace = ui_conf.font,
                  TextSize = ui_conf.text_sizes.base,

                  Text = scope:Computed(function(use)
                    local text = use(textCompute)
                    return use(focused) and text[2] or text[1]
                  end),

                  TextColor3 = ui_conf.colors.text,

                  TextXAlignment = Enum.TextXAlignment.Left,

                  RichText = true,
                  TextWrapped = true,
                  TextEditable = false,

                  [OnEvent "Focused"] = function()
                    focused:set(true)
                  end,

                  [OnEvent "FocusLost"] = function()
                    focused:set(false)
                  end,
                },
              },
            }
          end),
        },
      }),
    },
  }
end

return UpdateLog
]]></ProtectedString>
