				<Item class="ModuleScript" referent="RBXC3BC2F7B0D9D4B7DAD7918E74F61D9BA">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local HttpService = game:GetService("HttpService")
local StudioService = game:GetService("StudioService")
local CollectionService = game:GetService("CollectionService")

local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local logger = require("../../lib/logger")
local storage = require("../../lib/storage")
local utility = require("../../lib/utility")
local emit_utility = require("../../lib/emit/mod/utility")

local conf = require("../../.conf")
local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local upload_queue = require("./upload_queue")

local List = require("./cmp/List")
local JobList = require("./cmp/JobList")

type props = {
  effects: Fusion.Value<{
    mesh_decals: { Decal },
  }>,
}

local sidebarWidth = 140

local function FlipbookImporter(scope: ui_types.scope, props: props)
  local settings = conf.settings.flipbooks

  -- remove any dirty local flipbook tags from previous session
  for _, tag in CollectionService:GetAllTags() do
    if tag:match("^_local_flipbook_") then
      for _, obj in CollectionService:GetTagged(tag) do
        obj:RemoveTag(tag)

        obj:SetAttribute("FlipbookTextures", nil)
        obj:SetAttribute("FlipbookEnabled", false)
      end
    end
  end

  upload_queue.initThreads(scope, 3)

  local store = storage.new(scope, "mesh_flipbooks", {
    uploaded = scope:Value({}),
  })

  local searchQuery = scope:Value("")

  local scaledContentSize = scope:Value(Vector2.zero)
  local sideScaledContentSize = scope:Value(Vector2.zero)

  local searchBarValue: Fusion.Value<TextBox?> = scope:Value(nil)

  local contentSize = scope:Computed(function(use)
    return use(scaledContentSize) / use(ui_conf.scale)
  end)

  local sideContentSize = scope:Computed(function(use)
    return use(sideScaledContentSize) / use(ui_conf.scale)
  end)

  local uploadJobs = scope:Value({})
  local tempFlipbooks = scope:Value({})

  local function delete(value)
    return function(flipbook)
      local list = peek(value)
      local index = table.find(list, flipbook)

      if index then
        table.remove(list, index)
      end

      value:set(list)

      if flipbook._scope then
        flipbook._scope:doCleanup()
      end
    end
  end

  local function apply(flipbook)
    local e = peek(props.effects)

    local data = buffer.tostring(emit_utility.serializeFlipbook(flipbook.images))

    utility.record("apply flipbook", function()
      for _, obj in e.mesh_decals do
        for _, tag in CollectionService:GetTags(obj) do
          if tag:match("^_local_flipbook_") then
            obj:RemoveTag(tag)
          end
        end

        if flipbook._id then
          obj:AddTag(flipbook._id)
        end

        obj:SetAttribute("FlipbookEnabled", true)
        obj:SetAttribute("FlipbookTextures", data)

        obj:SetAttribute("Flipbook_Change_Duration", peek(flipbook.duration))
      end
    end)
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "Frame" {
        BackgroundColor3 = ui_conf.colors.surface,

        Size = scope:Spring(
          scope:Computed(function(use)
            return UDim2.new(0, #use(uploadJobs) == 0 and 0 or sidebarWidth, 1, 0)
          end),
          30,
          1
        ),

        [Children] = {
          scope:Round(ui_conf.rounding.base),
          scope:Padding(ui_conf.padding.side),

          scope:Scrollable({
            content_size = sideContentSize,

            background = ui_conf.colors.surface,
            scrollbar_bg = ui_conf.colors.base,

            children = {
              scope:New "UIListLayout" {
                SortOrder = Enum.SortOrder.LayoutOrder,

                Padding = scope:Computed(function(use)
                  return UDim.new(0, use(ui_conf.padding.side))
                end),

                [Out "AbsoluteContentSize"] = sideScaledContentSize,
              },

              JobList(scope, {
                jobs = uploadJobs,
              }),
            },
          }),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),

        Size = scope:Spring(
          scope:Computed(function(use)
            return UDim2.new(1, -(#use(uploadJobs) == 0 and 0 or sidebarWidth + use(ui_conf.padding.side)), 1, 0)
          end),
          30,
          1
        ),

        [Children] = {
          scope:New "Frame" {
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,

            Size = UDim2.fromScale(1, 0),

            [Children] = {
              scope:Hover "TextButton" {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.fromScale(1, 0),

                Size = scope:Computed(function(use)
                  return UDim2.fromOffset(
                    use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2,
                    use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
                  )
                end),

                FontFace = ui_conf.font,

                BackgroundColor3 = ui_conf.colors.primary,
                TextColor3 = ui_conf.colors.surface,

                Text = "+",

                TextSize = ui_conf.text_sizes.base,

                [OnEvent "MouseButton1Click"] = function()
                  local files = StudioService:PromptImportFiles({ "png", "jpg" })

                  if not files then
                    logger.error("could not import images because one of the files was over the 100 MB limit")
                  end

                  if #files == 0 then
                    return
                  end

                  local tempScope = scope:innerScope()

                  local flipbook = {
                    _scope = tempScope,
                    _id = `_local_flipbook_{HttpService:GenerateGUID(false)}`,

                    images = {},

                    name = scope:Value("Unnamed Flipbook"),
                    duration = tempScope:Value(1 / peek(settings.default_fps) * #files),
                  }

                  table.insert(tempScope, function()
                    for _, obj in CollectionService:GetTagged(flipbook._id) do
                      obj:RemoveTag(flipbook._id)

                      obj:SetAttribute("FlipbookTextures", nil)
                      obj:SetAttribute("FlipbookEnabled", false)
                    end
                  end)

                  local uploading = false

                  function flipbook.upload()
                    if uploading then
                      return
                    end

                    uploading = true

                    local completed = scope:Value(0)
                    local failed = scope:Value(0)

                    local retryInfo = {}
                    local uploadedIDs = {}

                    scope:Observer(completed):onChange(function()
                      if peek(completed) == #flipbook.images then
                        local list = peek(store.uploaded)

                        table.insert(list, {
                          images = uploadedIDs,

                          name = scope:Value(peek(flipbook.name)),
                          duration = scope:Value(peek(flipbook.duration)),
                        })

                        store.uploaded:set(list)

                        local data = buffer.tostring(emit_utility.serializeFlipbook(uploadedIDs))

                        for _, obj in CollectionService:GetTagged(flipbook._id) do
                          obj:RemoveTag(flipbook._id)
                          obj:SetAttribute("FlipbookTextures", data)
                        end

                        delete(tempFlipbooks)(flipbook)
                      end
                    end)

                    local function uploadAsync(i: number, id: number)
                      local res = upload_queue.add(i, "rbxtemp://" .. id)
                      local inc = res and completed or failed

                      if res then
                        uploadedIDs[i] = res
                      else
                        table.insert(retryInfo, { i, id })
                      end

                      inc:set(peek(inc) + 1)
                    end

                    local job = {
                      title = flipbook.name,

                      completed = completed,
                      target = #flipbook.images,

                      failed = failed,
                      retry = function()
                        local save = table.clone(retryInfo)

                        table.clear(retryInfo)

                        failed:set(0)

                        for _, info in save do
                          uploadAsync(info[1], info[2])
                        end
                      end,
                    }

                    local list = peek(uploadJobs)

                    table.insert(list, job)
                    table.insert(tempScope, function()
                      local index = table.find(list, job)

                      if index then
                        table.remove(list, index)
                      end

                      uploadJobs:set(list)
                    end)

                    uploadJobs:set(list)

                    for i, id in flipbook.images do
                      uploadAsync(i, id)
                    end
                  end

                  for _, file in files do
                    table.insert(tempScope, file)
                    table.insert(flipbook.images, tonumber(file:GetTemporaryId():match("%d+")))
                  end

                  local list = peek(tempFlipbooks)

                  table.insert(list, 1, flipbook)

                  table.insert(tempScope, function()
                    local index = table.find(list, flipbook)

                    if index then
                      table.remove(list, index)
                    end
                  end)

                  tempFlipbooks:set(list)
                end,

                [Children] = {
                  scope:Round(ui_conf.rounding.mini),
                },
              },

              scope:Hover "Frame" {
                BackgroundColor3 = ui_conf.colors.surface,

                Size = scope:Computed(function(use)
                  return UDim2.new(
                    1,
                    -(use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2 + use(ui_conf.padding.side)),
                    0,
                    use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
                  )
                end),

                [Children] = {
                  scope:Round(ui_conf.rounding.mini),

                  searchBarValue:set(scope:New "TextBox" {
                    BackgroundTransparency = 1,

                    AnchorPoint = Vector2.new(0.5, 0),
                    Position = UDim2.fromScale(0.5, 0),

                    Size = scope:Computed(function(use)
                      return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
                    end),

                    FontFace = ui_conf.font,

                    PlaceholderText = "search",

                    TextColor3 = ui_conf.colors.text,
                    PlaceholderColor3 = ui_conf.colors.muted,

                    TextSize = ui_conf.text_sizes.mini,

                    ClipsDescendants = true,

                    TextXAlignment = Enum.TextXAlignment.Left,

                    [Out "Text"] = searchQuery,

                    [OnEvent "Focused"] = function()
                      local bar = peek(searchBarValue)

                      if bar then
                        bar.CursorPosition = #bar.Text + 1
                        bar.SelectionStart = 0
                      end
                    end,
                  } :: TextBox),
                },
              },
            },
          },

          scope:New "Frame" {
            BackgroundTransparency = 1,

            AnchorPoint = Vector2.new(0, 1),
            Position = UDim2.fromScale(0, 1),

            Size = scope:Computed(function(use)
              return UDim2.new(
                1,
                0,
                1,
                -(use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2 + use(ui_conf.padding.side))
              )
            end),

            [Children] = {
              scope:Scrollable({
                content_size = contentSize,

                children = {
                  scope:New "UIListLayout" {
                    SortOrder = Enum.SortOrder.LayoutOrder,

                    Padding = scope:Computed(function(use)
                      return UDim.new(0, use(ui_conf.padding.side))
                    end),

                    [Out "AbsoluteContentSize"] = scaledContentSize,
                  },

                  List(scope, {
                    title = "Local",

                    query = searchQuery,
                    items = tempFlipbooks,

                    apply = apply,
                    delete = delete(tempFlipbooks),
                  }),

                  List(scope, {
                    title = "Uploaded",

                    query = searchQuery,
                    items = store.uploaded,

                    apply = apply,
                    delete = delete(store.uploaded),
                  }),
                },
              }),
            },
          },
        },
      },
    },
  }
end

return FlipbookImporter
]]></ProtectedString>
