                    component = ButtonInput(scope, {
                      text = scope:Computed(function(use)
                        return use(load) and "Unload Textures" or "Load Textures"
                      end),
                      on_click = function()
                        local value = not peek(load)
                        load:set(value)

                        for _, a in selectedParticleAncestors do
                          if value then
                            a:AddTag(emit_utility.TEXTURE_LOAD_TAG)
                          else
                            a:RemoveTag(emit_utility.TEXTURE_LOAD_TAG)
                          end
                        end
                      end,
                    }),
                  },
                },
              },
            },
          }
        end)()
