						<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local peek = Fusion.peek

-- yes, a stinky clanker generated this
local function calculator(scope, job)
  local eta = scope:Value(nil :: number?)

  local eta_speed = 0
  local last_completed = 0
  local eta_speed_calculated_at = 0

  local last_time = os.clock()

  local function update_eta()
    local target = peek(job.target)
    local current_completed = peek(job.completed)

    local current_time = os.clock()
    local now_ms = current_time * 1000

    if current_completed >= target then
      eta:set(0)
      return
    end

    local time_delta = current_time - last_time
    local progress_delta = current_completed - last_completed

    if progress_delta > 0 and time_delta > 0 and (eta_speed_calculated_at + 800) < now_ms then
      local current_speed = progress_delta / time_delta
      eta_speed_calculated_at = now_ms

      if eta_speed == 0 or (eta_speed_calculated_at + 4000) < now_ms then
        eta_speed = current_speed
      else
        eta_speed = (eta_speed * 4.0 + current_speed) / 5.0
      end
    end

    local remaining = target - current_completed

    if eta_speed == 0 then
      eta:set(nil)
    else
      local estimated_seconds = remaining / eta_speed
      eta:set(math.min(estimated_seconds, 60 * 60 * 60 * 24))
    end

    if progress_delta > 0 then
      last_completed = current_completed
      last_time = current_time
    end
  end

  local active = true

  task.spawn(function()
    while active do
      update_eta()
      task.wait(0.1)
    end
  end)

  table.insert(scope, function()
    active = false
  end)

  return eta
end

return calculator
]]></ProtectedString>
						<string name="ScriptGuid">{7BC03A25-593B-48BD-B61D-A8AB19EE88B9}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">eta_calculator</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX6D1D073DE96148D0AE7A9F477CFCA011">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local AssetService = game:GetService("AssetService")

local logger = require("../../lib/logger")

local rng = Random.new()

local queue = {}
queue.queued = {}

queue.threads = {}
queue.scheduled = {}

function queue.initThreads(scope, amount: number)
  if #queue.threads ~= 0 then
    logger.error("attempt to init uploader threads before cleaning up")
  end

  local active = true

  for i = 1, amount do
    local queued = {}

    queue.queued[i] = queued
    queue.scheduled[i] = false

    queue.threads[i] = coroutine.create(function()
      while active do
        local item = table.remove(queued)

        if item then
          local ok, err = pcall(function()
            local image = AssetService:CreateEditableImageAsync(item.id)

            if not image then
              error(`couldn't create an editable image from image id {item.id}`)
            end

            local status, id = AssetService:CreateAssetAsync(image, Enum.AssetType.Image, {
              Name = `flipbook_{item.index}`,
              Description = "uploaded by vfx forge",
            })

            if status ~= Enum.CreateAssetResult.Success then
              error(`api responded with status {status.Name}`)
            end

            task.spawn(item.thread, id)
          end)

          item.attempts += 1

          if not ok then
            if item.attempts < 5 then
              local sec = item.attempts ^ 2

              task.delay(sec, function()
                queue.schedule(item)
              end)

              logger.warn(
                `error during uploading. attempt {item.attempts + 1}/5 to reupload the image will be made in {sec} seconds. error: {err}`
              )
            else
              task.spawn(item.thread, false)
            end
          end
        end

        if #queued == 0 then
          queue.scheduled[i] = false
          coroutine.yield()
        end
      end
    end)
  end

  table.insert(scope, function()
    table.clear(queue.queued)
    table.clear(queue.threads)
    table.clear(queue.scheduled)

    active = false
  end)
end

function queue.schedule(item)
  local index = rng:NextInteger(1, #queue.threads)

  table.insert(queue.queued[index], item)

  if not queue.scheduled[index] then
    queue.scheduled[index] = true
    task.defer(queue.threads[index])
  end
end

function queue.add(index: number, id: string)
  queue.schedule({
    id = id,
    index = index,
    thread = coroutine.running(),

    attempts = 0,
  })

  return coroutine.yield()
end

return queue
]]></ProtectedString>
