			<Properties>
				<ProtectedString name="Source"><![CDATA[if game:GetService("RunService"):IsRunning() then
  return
end

local Fusion = require(script.Parent.pkg.Fusion)

local AttributeOut = Fusion.AttributeOut
local peek = Fusion.peek

local scope = Fusion.scoped(Fusion)

local conf = require("./.conf")
local vfx = require("./lib/emit")

local ui_conf = require("./cmp/ui_conf")
local ui_types = require("./cmp/ui_types")

-- initialize before requiring ui_types
vfx.init()

conf.setup(scope)
ui_conf.setup(scope)

-- init after configs because it relies on them
local path_prediction = require("./mod/emitter/path_prediction")

path_prediction.init(scope)

local utility = require("./lib/utility")
local storage = require("./lib/storage")

local EmitModuleImporter = require("./cmp/emit_importer/EmitModuleImporter")

local main = require("./main")

local toolbar = plugin:CreateToolbar("VFX Forge")

local toggle = toolbar:CreateButton(
  "Toggle UI",
  "Enable/disable the UI part of the plugin\n\nWhen disabled, all UI activity is stopped and cleaned up",
  "rbxassetid://93007659466532"
)

local import = toolbar:CreateButton("Emit Module", "Import the emit module", "rbxassetid://77573286073459")

local guiScope = ui_types.ext_scope()
local guiEnabled = scope:Value(true)

local store = storage.new(scope, "init", {
  enabled = guiEnabled,
})

plugin:SetAttribute("GuiEnabled", peek(guiEnabled))

scope:Hydrate(plugin) {
  [AttributeOut "GuiEnabled"] = guiEnabled,
}

scope:Observer(store.enabled):onBind(function()
  local enabled = peek(store.enabled)

  if enabled then
    utility.try("failed to initialize GUI: %s", main, guiScope)
  else
    guiScope:doCleanup()
    guiScope = ui_types.ext_scope()
  end
end)

toggle.Click:Connect(function()
  store.enabled:set(not peek(store.enabled))
end)

local importScope

import.Click:Connect(function()
  if not peek(guiEnabled) then
    return
  end

  if importScope then
    importScope:doCleanup()
    return
  end

  importScope = guiScope:innerScope()

  table.insert(importScope, function()
    importScope = nil
  end)

  conf.ctx:is(conf.current_ctx):during(function()
    local scope = importScope

    scope:Window({
      id = "module_importer",
      title = "License Agreement",

      position = Vector2.new(0, 0),
      anchor = Vector2.new(0.5, 0.5),

      size = Vector2.new(500, 600),

      close_cleanup = true,
      global_enabled = true,

      visible = scope:Value(true),

      child = EmitModuleImporter(scope, {}),
    })
  end)
end)

plugin.Unloading:Connect(function()
  scope:doCleanup()
  guiScope:doCleanup()

  vfx.deinit()
end)
]]></ProtectedString>
