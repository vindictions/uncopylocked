				<ProtectedString name="Source"><![CDATA[local CoreGui = game:GetService("CoreGui")
local Selection = game:GetService("Selection")
local MarketplaceService = game:GetService("MarketplaceService")

local Fusion = require(script.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("./.conf")
local logger = require("./lib/logger")
local symbols = require("./.symbols")
local updates = require("./.updates")
local ui_conf = require("./cmp/ui_conf")
local utility = require("./lib/utility")
local storage = require("./lib/storage")
local ui_types = require("./cmp/ui_types")
local emit_utility = require("./lib/emit/mod/utility")
local path_prediction = require("./mod/emitter/path_prediction")

local Emit = require("./cmp/emit/Emit")
local Adder = require("./cmp/adder/Adder")
local Retime = require("./cmp/retime/Retime")
local Resize = require("./cmp/resize/Resize")
local EmitCode = require("./cmp/code/EmitCode")
local Settings = require("./cmp/settings/Settings")
local UpdateLog = require("./cmp/updlog/UpdateLog")
local Attributes = require("./cmp/attributes/Attributes")
local CurveCopier = require("./cmp/copier/CurveCopier")
local CurveEditor = require("./cmp/curve/CurveEditor")
local ColorPicker = require("./cmp/color_picker/ColorPicker")
local PropertyShifter = require("./cmp/shifter/PropertyShifter")
local FlipbookImporter = require("./cmp/flipbooks/FlipbookImporter")

local TextInput = require("./cmp/attributes/cmp/TextInput")
local RangeInput = require("./cmp/attributes/cmp/RangeInput")
local NumberInput = require("./cmp/attributes/cmp/NumberInput")
local ButtonInput = require("./cmp/attributes/cmp/ButtonInput")
local VectorInput = require("./cmp/attributes/cmp/VectorInput")
local CheckboxInput = require("./cmp/attributes/cmp/CheckboxInput")
local DropdownInput = require("./cmp/attributes/cmp/DropdownInput")

local updateChecked = false

local function main(scope: ui_types.scope)
  local attrScope = scope:Value(scope:innerScope())

  local selectedEmitters = scope:Value({})
  local currentAttributes = scope:Value(nil)

  local selectedEffects = scope:Value({})

  local bezierPreviewEnabled = scope:Value(false)

  local bezierPathsVisible = scope:Value(false)
  local debrisPathsVisible = scope:Value(false)
  local particlePathsVisible = scope:Value(false)

  local function checkSelection()
    peek(attrScope):doCleanup()

    local scope = scope:innerScope()

    local selected = Selection:Get()

    local e, firstSelectedParticle, selectedParticleAncestors = utility.getEffects(selected)

    attrScope:set(scope)
    selectedEffects:set(e)

    if not attrScope then
      return
    end

    selectedEmitters:set(selected)

    local particleScope, bezierScope, debrisScope

    local function updateParticleVisuals()
      if particleScope then
        particleScope:doCleanup()
      end

      particleScope = scope:innerScope()

      if firstSelectedParticle and peek(particlePathsVisible) then
        path_prediction.draw(particleScope, firstSelectedParticle)
      end
    end

    local function updateBezierVisuals()
      if bezierScope then
        bezierScope:doCleanup()
      end

      bezierScope = scope:innerScope()

      local first = e.beziers[1]

      if not first then
        return
      end

      if peek(bezierPreviewEnabled) then
        path_prediction.draw_bezier_preview(bezierScope, first)
      elseif peek(bezierPathsVisible) then
        path_prediction.draw_bezier(bezierScope, first)
      end
    end

    local function updateDebrisVisuals()
      if debrisScope then
        debrisScope:doCleanup()
      end

      debrisScope = scope:innerScope()

      local first = e.shockwave_debris[1]

      if not first then
        return
      end

      if peek(debrisPathsVisible) then
        path_prediction.draw_debris(debrisScope, first)
      end
    end

    updateBezierVisuals()
    updateDebrisVisuals()
    updateParticleVisuals()

    scope:Observer(particlePathsVisible):onChange(updateParticleVisuals)

    scope:Observer(bezierPathsVisible):onChange(updateBezierVisuals)
    scope:Observer(bezierPreviewEnabled):onChange(updateBezierVisuals)

    scope:Observer(debrisPathsVisible):onChange(updateDebrisVisuals)

    local function Writer<T>(objs: { Instance }, name: string, default: T | () -> T, fromProp: string?): Fusion.Value<T>
      local function get()
        local default = default

        if typeof(default) == "function" then
          default = default()
        end

        local use = utility.collectAttributeFromMany(objs, name, typeof(default), nil, default)

        if use == nil then
          use = default
        end

        return use
      end

      local consume = false
      local consumeAttrChange = false

      local value = scope:Value(get())

      local function update()
        if consumeAttrChange then
          return
        end

        local use = get()

        if use ~= peek(value) then
          consume = true
          value:set(use)
        end
      end

      for _, obj in objs do
        if fromProp then
          table.insert(scope, obj:GetPropertyChangedSignal(fromProp):Connect(update))
        end

        table.insert(scope, obj:GetAttributeChangedSignal(name):Connect(update))
      end

      scope:Observer(value):onChange(function()
        if consume then
          consume = false
          return
        end

        consumeAttrChange = true

        utility.record("set attribute", function()
          for _, obj in objs do
            local v = peek(value)

            if typeof(v) ~= "table" then
              obj:SetAttribute(name, v)
            end
          end
        end)

        consumeAttrChange = false
      end)

      return value
    end

    local attributes = {
      if #e.tween_properties > 0
        then coroutine.wrap(function()
          local prop = ""

          for _, obj in e.tween_properties do
            if prop ~= "" and obj.Name ~= prop then
              prop = symbols.nil_symbol
              break
            end

            prop = obj.Name
          end

          if typeof(prop) == "string" then
            local obj = e.tween_properties[1]

            local ok, b = pcall(function()
              return obj.Parent[prop]
            end)

            if not ok or b == obj then
              prop = ""
            end
          end

          local list = scope:Value({})
          local property = scope:Value(prop)

          task.spawn(function()
            local unique = {}

            for _, obj in e.tween_properties do
              table.insert(unique, utility.getProperties(obj.Parent, scope))
            end

            local counts = {}
            local total = #unique

            for _, props in unique do
              local seen = {}

              for _, prop in ipairs(props) do
                if not seen[prop] then
                  counts[prop] = (counts[prop] or 0) + 1
                  seen[prop] = true
                end
              end
            end

            local common = {}

            for prop, count in pairs(counts) do
              if count == total then
                table.insert(common, prop)
              end
            end

            list:set(common)
          end)

          scope:Observer(property):onChange(function()
            local value = peek(property)

            if value == symbols.nil_symbol then
              return
            end

            utility.record("set tween property", function()
              for _, obj in e.tween_properties do
                local parent = obj.Parent

                if parent then
                  obj.Name = value
                  obj:SetAttribute("_END_VALUE", parent[value])
                end
              end
            end)
          end)

          return {
            title = "Tween Property",
            value = {
              {
                name = "EmitDelay",
                component = NumberInput(scope, {
                  value = Writer(e.tween_properties, "EmitDelay", 0),

                  min = 0,
                  max = math.huge,
                }),
              },
              {
                name = "Duration",
                component = RangeInput(scope, {
                  value = Writer(e.tween_properties, "Duration", NumberRange.new(1, 1)),
                }),
              },
              {
                name = "Property",
                component = DropdownInput(scope, {
                  value = property,
                  options = list,

                  search = true,
                }),
              },
              {
                name = "ResetOnFinish",
                component = CheckboxInput(scope, {
                  value = Writer(e.tween_properties, "ResetOnFinish", true),
                }),
              },
            },
          }
        end)()
        else nil,

      if #e.spin_models > 0
        then {
          title = "Model",
          value = {
            {
              title = "Emit",
              value = {
                {
                  name = "Delay",
                  component = NumberInput(scope, {
                    value = Writer(e.spin_models, "EmitDelay", 0),
                  }),
                },
              },
            },
            {
              title = "Spin",
              value = {
                {
                  name = "Rotation",
                  component = VectorInput(scope, {
                    three_d = true,
                    value = Writer(e.spin_models, "SpinRotation", vector.zero),
                  }),
                },
                {
                  name = "Duration",
                  component = NumberInput(scope, {
                    value = Writer(e.spin_models, "SpinDuration", 0.5),
                  }),
                },
                {
                  name = "SyncPosition",
                  component = CheckboxInput(scope, {
                    value = Writer(e.spin_models, "SyncPosition", false),
                  }),
                },
              },
            },
            {
              title = "Scale",
              value = {
                {
                  name = "Start",
                  component = NumberInput(scope, {
                    value = Writer(e.spin_models, "Scale_Start", 1),

                    min = 0.001,
                    max = math.huge,
                  }),
                },
                {
                  name = "End",
                  component = NumberInput(scope, {
                    value = Writer(e.spin_models, "Scale_End", 1),

                    min = 0.001,
                    max = math.huge,
                  }),
                },
              },
            },
          },
        }
        else nil,

      if #e.particles > 0
        then coroutine.wrap(function()
          local load = scope:Value(utility.collectTagFromMany(selectedParticleAncestors, emit_utility.TEXTURE_LOAD_TAG))

          return {
            title = "Particle",
            value = {
              {
                title = "Emit",
                value = {
                  {
                    name = "Count",
                    component = NumberInput(scope, {
                      int = true,
                      value = Writer(e.particles, "EmitCount", 1),
                    }),
                  },
                  {
                    name = "Delay",
                    component = NumberInput(scope, {
                      value = Writer(e.particles, "EmitDelay", 0),
                    }),
                  },
                  {
                    name = "Duration",
                    component = NumberInput(scope, {
                      value = Writer(e.particles, "EmitDuration", 0),
                    }),
