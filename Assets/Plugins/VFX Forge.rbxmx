				<Item class="ModuleScript" referent="RBXA4904840FFF2455D9C2EF3CA3CD44A9B">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local emit_utility = require("../../lib/emit/mod/utility")

local function shift(f: (x: number) -> number, x: unknown)
  local t = typeof(x)

  if t == "number" then
    return f(x)
  elseif t == "Vector3" then
    return Vector3.new(f(x.X), f(x.Y), f(x.Z))
  elseif t == "Vector2" then
    return Vector2.new(f(x.X), f(x.Y))
  elseif t == "NumberRange" then
    return NumberRange.new(f(x.Min), f(x.Max))
  elseif t == "NumberSequence" then
    return emit_utility.scaleNumberSequence(x, function(a, b)
      return f(a), f(b)
    end)
  elseif t == "ColorSequence" then
    local pts = {}

    for _, pt in x.Keypoints do
      table.insert(
        pts,
        ColorSequenceKeypoint.new(
          pt.Time,
          Color3.new(f(pt.Value.R * 255) / 255, f(pt.Value.G * 255) / 255, f(pt.Value.B * 255) / 255)
        )
      )
    end

    return ColorSequence.new(pts)
  elseif t == "Color3" then
    return Color3.new(f(x.R * 255) / 255, f(x.G * 255) / 255, f(x.B * 255) / 255)
  end

  return x
end

local handlers = {}

function handlers.Property(obj: Instance, name: string, factor: number)
  local ok, x = pcall(function()
    return obj[name]
  end)

  if not ok then
    logger.warn(`failed to read property '{name}' from {obj:GetFullName()}: {x}`)
    return
  elseif typeof(x) == "Instance" then
    logger.warn(`failed to read property '{name}' from {obj:GetFullName()} because it has a child with the same name`)
    return
  end

  obj[name] = shift(factor, x)
end

function handlers.Attribute(obj: Instance, name: string, factor: number)
  local x = obj:GetAttribute(name)

  if x == nil then
    return
  end

  obj:SetAttribute(name, shift(factor, x))
end

return handlers
]]></ProtectedString>
