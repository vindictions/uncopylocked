					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)
local Oklab = require(script.Parent.Parent.pkg.Fusion.Colour.Oklab)

local function AlphaBlend(
  scope: Fusion.Scope,
  alpha: Fusion.UsedAs<number>,
  bg: Fusion.UsedAs<Color3>,
  fg: Fusion.UsedAs<Color3>
)
  return scope:Computed(function(use)
    local lab1 = Oklab.fromSRGB(use(fg))
    local lab2 = Oklab.fromSRGB(use(bg))

    return Oklab.toSRGB(lab1:Lerp(lab2, 1 - alpha))
  end)
end

return AlphaBlend
]]></ProtectedString>
