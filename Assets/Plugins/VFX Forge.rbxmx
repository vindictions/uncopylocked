    local offset = 0

    for i = 1, #attributes do
      local v = attributes[i - offset]

      if v == nil then
        table.remove(attributes, i - offset)
        offset += 1
      end
    end

    currentAttributes:set(attributes)
  end

  local vpbar = scope:New "Frame" {
    BackgroundTransparency = 1,

    AnchorPoint = Vector2.one * 0.5,
    Position = UDim2.fromScale(0.5, 0.5),

    Size = scope:Computed(function(use)
      local pad = use(ui_conf.padding.side)
      return UDim2.new(1, -pad * 2, 1, -pad * 2)
    end),

    ZIndex = 1000,

    [Children] = {
      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,

        FillDirection = scope:Computed(function(use)
          return Enum.FillDirection[use(conf.settings.ui.buttons_direction)]
