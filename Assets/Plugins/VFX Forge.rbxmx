			<Item class="ModuleScript" referent="RBX34F5253467B646968D40DA6D0F84DC83">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../.conf")
local logger = require("../lib/logger")
local ui_conf = require("./ui_conf")

type props = {
  near_element: GuiObject?,
  near_padding: Fusion.UsedAs<number>?,

  float: Vector2?,
  anchor: Vector2?,

  padding_axes: Vector2?,

  text: Fusion.UsedAs<string>,
}

local function Tooltip(scope: Fusion.Scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create tooltip because the ctx contextual is not set for current thread")
  end

  local initPriority = peek(ctx.current_priority)

  scope = scope:innerScope()

  scope:Observer(ctx.current_priority):onChange(function()
    if peek(ctx.current_priority) ~= initPriority then
      scope:doCleanup()
    end
  end)

  local pad = (props.padding_axes or Vector2.one) * (peek(props.near_padding) or Vector2.zero)

  local float = props.float or Vector2.zero
  local anchor = props.anchor or Vector2.zero

  local absPos = scope:Value(Vector2.zero)
  local absSize = scope:Value(Vector2.zero)

  local tooltipSize = scope:Value(Vector2.zero)

  local tp = scope:Value(1)
  local tpAnim = scope:Spring(tp, 20, 1)

  local mousePos = scope:Value(Vector2.zero)

  if not props.near_element then
    table.insert(
      scope,
      RunService.RenderStepped:Connect(function()
        mousePos:set(UserInputService:GetMouseLocation())
      end)
    )
  else
    scope:New "Frame" {
      Parent = props.near_element,

      BackgroundTransparency = 1,
      Size = UDim2.fromScale(1, 1),

      [Out "AbsoluteSize"] = absSize,
      [Out "AbsolutePosition"] = absPos,
    }
  end

  scope:New "ScreenGui" {
    Parent = CoreGui,

    ResetOnSpawn = false,
    IgnoreGuiInset = true,

    DisplayOrder = scope:Computed(function(use)
      return use(ui_conf.display_order) + 8
    end),

    [Children] = {
      scope:New "UIScale" {
        Scale = ui_conf.scale,
      },

      scope:New "TextLabel" {
        AutomaticSize = Enum.AutomaticSize.XY,

        BackgroundTransparency = tpAnim,
        TextTransparency = tpAnim,

        Position = scope:Computed(function(use)
          local scale = peek(ui_conf.scale)

          local s = use(tooltipSize)
          local p = use(ui_conf.padding.side)

          local pos = props.near_element and use(absPos) or use(mousePos)
          local size = use(absSize)

          local res = (pos + size * float + s * anchor) / scale + pad

          local viewport = workspace.CurrentCamera.ViewportSize / scale

          return UDim2.fromOffset(
            math.clamp(res.X, p, viewport.X - s.X / scale - p),
            math.clamp(res.Y, p, viewport.Y - s.Y / scale - p)
          )
        end),

        FontFace = Font.fromId(16658246179),
        RichText = true,

        BackgroundColor3 = ui_conf.colors.text,
        TextColor3 = ui_conf.colors.base,

        Text = props.text,
        TextSize = ui_conf.text_sizes.mini,

        TextXAlignment = Enum.TextXAlignment.Left,

        [Out "AbsoluteSize"] = tooltipSize,

        [Children] = {
          scope:Round(ui_conf.rounding.base),
          scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
        },
      },
    },
  }

  tp:set(0)
end

return Tooltip
]]></ProtectedString>
					<string name="ScriptGuid">{EB96E5CE-52D0-4E2C-A4D6-6419C0F4DE7A}</string>
