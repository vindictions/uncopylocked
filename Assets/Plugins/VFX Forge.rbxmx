			<Item class="ModuleScript" referent="RBXB84D1BF3137E478191C426813EC31130">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local peek = Fusion.peek

local currentlyHolding = {}

local function OnHold(
  scope: Fusion.Scope,
  state: Fusion.Value<boolean>,
  callback: (mousePos: Vector2, deltaPos: number) -> (),
  inputType: Enum.UserInputType?,
  keyRequired: Enum.KeyCode?,
  single: boolean?
)
  if not inputType then
    inputType = Enum.UserInputType.MouseButton1
  end

  local conn: RBXScriptConnection?
  local keyListenerConn: RBXScriptConnection?

  local function cleanup(destroying: boolean?)
    local index = table.find(currentlyHolding, state)

    if index then
      table.remove(currentlyHolding, index)
    end

    if conn then
      conn:Disconnect()
      conn = nil
    end

    if keyListenerConn then
      keyListenerConn:Disconnect()
      keyListenerConn = nil
    end

    if not destroying then
      state:set(false)
    end
  end

  table.insert(
    scope,
    UserInputService.InputEnded:Connect(function(input)
      if input.UserInputType ~= inputType or not conn then
        return
      end

      state:set(false)
    end)
  )

  table.insert(scope, function()
    cleanup(true)
  end)

  scope:Observer(state):onBind(function()
    local value = peek(state)

    if value then
      table.insert(currentlyHolding, state)

      local prev = UserInputService:GetMouseLocation()

      conn = RunService.RenderStepped:Connect(function(deltaTime)
        local mousePos = UserInputService:GetMouseLocation()

        task.spawn(function()
          local res = callback(mousePos, prev - mousePos)

          if res == true then
            state:set(false)
          end
        end)

        prev = mousePos
      end)

      if keyRequired then
        keyListenerConn = UserInputService.InputEnded:Connect(function(i)
          if i.KeyCode ~= keyRequired then
            return
          end

          cleanup()
        end)
      end
    else
      cleanup()
    end
  end)

  return scope:New "Frame" {
    Active = true,
    BackgroundTransparency = 1,

    Size = UDim2.fromScale(1, 1),

    ZIndex = 100,

    [OnEvent "InputBegan"] = function(input: InputObject)
      if
        input.UserInputType ~= inputType
        or (keyRequired and not UserInputService:IsKeyDown(keyRequired))
        or single and #currentlyHolding ~= 0
      then
        return
      end

      state:set(true)
    end,
  }
end

return OnHold
]]></ProtectedString>
					<string name="ScriptGuid">{AF243A53-69C2-40C3-BE0C-3B3B6D3A02EC}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">OnHold</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXB6EA70FC567B4CD0BD94F9A747C7FE41">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local plugin = script:FindFirstAncestorOfClass("Plugin")

local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local peek = Fusion.peek

local conf = require("../.conf")
local utility = require("../lib/utility")

local function snakeToTitle(s: string)
  local words = {}

  for word in s:gmatch("([^_]+)") do
    -- hax ????
    if word == "ui" then
      word = "UI"
    end

    local capitalized = word:sub(1, 1):upper() .. word:sub(2)
    table.insert(words, capitalized)
  end

  return table.concat(words, " ")
end

local function OnKeybind(
  scope: Fusion.Scope,
  id: string,
  name: string,
  seq: Fusion.UsedAs<{ string }>,
  callback: () -> ()
)
  local action = plugin:CreatePluginAction(id, `VFX Forge: {snakeToTitle(id)}`, name, "")

  action.Triggered:Connect(callback)

  table.insert(scope, action)

  local pressed = {}

  table.insert(
    scope,
    UserInputService.InputBegan:Connect(function(input)
      if
        input.UserInputType ~= Enum.UserInputType.Keyboard
        or UserInputService:GetFocusedTextBox()
        or conf.input_locked
      then
        return
      end

      table.insert(pressed, utility.getDisplayKey(input.KeyCode.Name))

      if #pressed ~= #peek(seq) then
        return
      end

      local down = true

      for i, key in peek(seq) do
        if pressed[i] ~= utility.getDisplayKey(key) then
          down = false
          break
        end
      end

      if down then
        task.spawn(callback)
      end
    end)
  )

  table.insert(
    scope,
    UserInputService.InputEnded:Connect(function(input)
      local index = table.find(pressed, utility.getDisplayKey(input.KeyCode.Name))

      if index then
        table.remove(pressed, index)
      end
    end)
  )
end

return OnKeybind
]]></ProtectedString>
					<string name="ScriptGuid">{15723DE1-A0EB-49A7-BAD9-BA689C4DABAD}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">OnKeybind</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXE4B3D2E61C7C41FDA37C07669CFF957A">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local CoreGui = game:GetService("CoreGui")
local TextService = game:GetService("TextService")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../.conf")
local logger = require("../lib/logger")
local ui_conf = require("./ui_conf")

type props = {
  position: Vector2?,
  near_element: GuiObject?,

  near_padding: Fusion.UsedAs<number>?,

  float: Vector2?,

  options: {
    {
      name: string,
      on_click: () -> (),
    }
  },
}

local function Options(scope: Fusion.Scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create options because the ctx contextual is not set for current thread")
  end

  scope = scope:innerScope()

  local pad = peek(props.near_padding) or 0
  local float = props.float or Vector2.zero

  local el = props.near_element

  local pos = el and el.AbsolutePosition or props.position
  local size = el and el.AbsoluteSize or Vector2.zero

  local scale = peek(ui_conf.scale)

  local absSize = scope:Value(Vector2.zero)
  local position = scope:Value(
    UDim2.fromOffset(
      (pos.X + size.X * float.X) / scale + pad * float.X,
      (pos.Y + size.Y * float.Y) / scale + pad * float.Y
    )
  )

  local tp = scope:Value(1)
  local tpAnim = scope:Spring(tp, 20, 1)

  local widest = scope:Value(0)

  scope:New "ScreenGui" {
    Parent = CoreGui,

    ResetOnSpawn = false,
    IgnoreGuiInset = true,

    DisplayOrder = scope:Computed(function(use)
      return use(ui_conf.display_order) + 10
    end),

    [Children] = {
      scope:New "UIScale" {
        Scale = ui_conf.scale,
      },

      scope:New "ImageButton" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        [OnEvent "MouseButton1Click"] = function()
          scope:doCleanup()
        end,
      },

      scope:New "CanvasGroup" {
        AutomaticSize = Enum.AutomaticSize.Y,

        Size = scope:Computed(function(use)
          return UDim2.fromOffset(use(widest), 0)
        end),

        BackgroundTransparency = 1,
        GroupTransparency = tpAnim,

        Position = position,
        ZIndex = 100,

        [Out "AbsoluteSize"] = absSize,

        [Children] = {
          scope:Round(ui_conf.rounding.base),

          scope:New "UIStroke" {
            Color = ui_conf.colors.highlight,
            Transparency = tpAnim,

            Thickness = 1,
          },

          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
          },

          scope:ForValues(props.options, function(_, valueScope, opt)
            local bounds = scope:Computed(function(use, scope)
              local params = scope:New "GetTextBoundsParams" {
                Text = opt.name,
                Font = use(ui_conf.font),
                Size = use(ui_conf.text_sizes.mini),
                Width = 10_000,
              }

              return TextService:GetTextBoundsAsync(params).X + use(ui_conf.padding.side) * 2
            end)

            local function upd()
              local width = peek(bounds)

              if width > peek(widest) then
                widest:set(width)
              end
            end

            upd()

            scope:Observer(ui_conf.font):onChange(upd)
            scope:Observer(ui_conf.padding.prop):onChange(upd)
            scope:Observer(ui_conf.text_sizes.mini):onChange(upd)

            return valueScope:Hover "TextButton" {
              AutomaticSize = Enum.AutomaticSize.XY,

              Size = scope:Computed(function(use)
                return UDim2.fromOffset(use(widest), 0)
              end),

              BackgroundColor3 = ui_conf.colors.surface,
              TextColor3 = ui_conf.colors.text,

              FontFace = ui_conf.font,

              Text = opt.name,
              TextSize = ui_conf.text_sizes.mini,

              TextXAlignment = Enum.TextXAlignment.Left,

              [OnEvent "MouseButton1Click"] = function()
                scope:doCleanup()

                if opt.on_click then
                  conf.ctx:is(ctx):during(opt.on_click)
                end
              end,

              [Children] = {
                valueScope:Padding(ui_conf.padding.side, ui_conf.padding.base),
              },
            }
          end),
        },
      },
    },
  }

  scope:Observer(absSize):onBind(function()
    local s = peek(absSize) / scale

    local pos = peek(position)
    local pad = peek(ui_conf.padding.side)

    local viewport = workspace.CurrentCamera.ViewportSize / scale

    position:set(
      UDim2.fromOffset(
        math.clamp(pos.X.Offset, pad, viewport.X - s.X - pad),
        math.clamp(pos.Y.Offset, pad, viewport.Y - s.Y - pad)
      )
    )
  end)

  tp:set(0)
end

return Options
]]></ProtectedString>
					<string name="ScriptGuid">{25F694E6-E7B4-4F63-BF35-71A02818D2BC}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Options</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX8076F8E835D541C7890FE8514A543AF0">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

type num = Fusion.UsedAs<number>

local function leftAndRight(n: num, size: num, size2: num?, size3: num?, size4: num?)
  if not size2 and not size3 and not size4 then
    return size
  elseif (size and size2 and not size3 and not size4) or n == 1 then
    return size
  elseif n == 2 then
    return size3
  end

  return 0
end

local function topAndBottom(n: num, size: num, size2: num?, size3: num?, size4: num?)
  if not size2 and not size3 and not size4 then
    return size
  elseif (size and size2 and not size3 and not size4) or n == 1 then
    return size2
  elseif n == 2 then
    return size4
  end

  return 0
end

local function comp(scope: Fusion.Scope, num: num)
  return scope:Computed(function(use)
    return UDim.new(0, use(num))
  end)
end

local function Padding(scope: Fusion.Scope, ...: num)
  return scope:New "UIPadding" {
    PaddingLeft = comp(scope, leftAndRight(1, ...)),
    PaddingTop = comp(scope, topAndBottom(1, ...)),
    PaddingRight = comp(scope, leftAndRight(2, ...)),
    PaddingBottom = comp(scope, topAndBottom(2, ...)),
  }
end

return Padding
]]></ProtectedString>
					<string name="ScriptGuid">{7DA7580E-636D-42F5-99A8-E880740BB162}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Padding</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXBDB5FD3A32634B4BB1FA462661894404">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[--!nolint LocalShadow
local Fusion = require(script.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local peek = Fusion.peek

local ui_conf = require("./ui_conf")

type props = {
  title: Fusion.UsedAs<string>,
  padding: Fusion.UsedAs<number>?,

  float: Vector2?,
  float_anchor: Vector2?,

  anchor: Vector2?,

  size: Vector2?,
  position: Vector2?,
  near_element: GuiObject?,

  automatic_width: boolean?,
  automatic_height: boolean?,

  on_close: (() -> ())?,

  child: (scope: Fusion.Scope) -> GuiObject,
}

local function Prompt(scope: Fusion.Scope, props: props)
  local scope = scope:innerScope()

  local pad = peek(props.padding) or peek(ui_conf.padding.side)

  local float = props.float or Vector2.zero
  local float_anchor = props.float_anchor or Vector2.zero

  local el = props.near_element

  local pos = el and el.AbsolutePosition or props.position
  local size = el and el.AbsoluteSize or props.size or Vector2.zero

  local scale = peek(ui_conf.scale)

  local th = peek(ui_conf.text_sizes.title_bar) + peek(ui_conf.padding.base) * 2

  local position = Vector2.new(
    (pos.X + size.X * float.X + size.X * float_anchor.X) / scale + pad * float.X,
    (pos.Y + size.Y * float.Y + (size.Y + th) * float_anchor.Y) / scale + pad * float.Y
  )

  if props.on_close then
    table.insert(scope, props.on_close)
  end

  local win = scope:Window({
    title = props.title,
    position = position,

    size = props.size,
    anchor = props.anchor,

    automatic_width = props.automatic_width,
    automatic_height = props.automatic_height,

    focused = true,
    close_cleanup = true,

    disable_resize = true,
    disable_anchor = true,

    focus_priority = 100,

    display_order = scope:Computed(function(use)
      return use(ui_conf.display_order) + 5
    end),

    child = props.child(scope),
  })

  scope:New "ImageButton" {
    Parent = win,

    BackgroundTransparency = 1,
    Size = UDim2.fromScale(1, 1),

    ZIndex = -1,

    [OnEvent "MouseButton1Click"] = function()
      scope:doCleanup()
    end,
  }
end

return Prompt
]]></ProtectedString>
					<string name="ScriptGuid">{F7D1403C-DFDD-4EE8-A6D5-FD3F0035FD7E}</string>
