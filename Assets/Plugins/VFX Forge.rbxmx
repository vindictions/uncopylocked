					<Item class="Script" referent="RBX5EEA32ECF25E47769B89733D6301F8F8">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local Bezier = require(script.Parent.Parent.Parent.Parent.lib.emit.obj.Bezier)

local logger = require(script.Parent.Parent.Parent.Parent.lib.logger)
local shape = require(script.Parent.Parent.Parent.Parent.lib.emit.mod.shape)
local utility = require(script.Parent.Parent.Parent.Parent.lib.emit.mod.utility)
local emit_utility = require(script.Parent.Parent.Parent.Parent.lib.emit.mod.utility)

local actor = script:GetActor()

if not actor then
  logger.error("no actor found for " .. script:GetFullName())
end

local drawFuncMap = {
  Box = {
    Volume = shape.getPointWithinBox,
    Surface = shape.getPointOnBox,
  },

  Cylinder = {
    Volume = function(seed, cframe, size, normal, partial)
      return shape.getPointWithinCylinder(seed, 0, partial, cframe, size, normal)
    end,

    Surface = function(seed, cframe, size, normal, partial)
      return shape.getPointWithinCylinder(seed, 1, partial, cframe, size, normal)
    end,
  },

  Sphere = {
    Volume = function(seed, cframe, size, normal, partial)
      return shape.getPointWithinSphere(seed, 0, partial, cframe, size, normal)
    end,

    Surface = function(seed, cframe, size, normal, partial)
      return shape.getPointWithinSphere(seed, 1, partial, cframe, size, normal)
    end,
  },

  Disc = {
    Volume = function(seed, cframe, size, normal, partial)
      return shape.getPointWithinDisc(seed, 0, partial, cframe, size, normal)
    end,

    Surface = function(seed, cframe, size, normal, partial)
      return shape.getPointWithinDisc(seed, 1, partial, cframe, size, normal)
    end,
  },
}

actor:BindToMessageParallel(
  "drawBezierChunk",
  function(
    effect: Attachment,
    shape: string,
    style: string,
    partial: number,
    emission_direction: Enum.NormalId,
    face: string,
    spreadAngle: vector,
    mirror: boolean,
    mirrorRot: vector,
    points: { vector },
    handle: WireframeHandleAdornment,
    from: number,
    to: number
  )
    local parent = effect.Parent

    if not parent then
      return
    end

    if not parent:IsA("BasePart") and not parent:IsA("Attachment") then
      parent = effect
    end

    debug.profilebegin("vfxPathWorker::drawBezierChunk")

    local drawFunc = drawFuncMap[shape] and drawFuncMap[shape][style]

    if not drawFunc then
      logger.warnOnce(
        0,
        `shape function for shape {shape} with style {style} doesn't exist! you shouldn't be seeing this message, but it seems like something went wrong!!!`
      )
      return
    end

    local originSize: Vector3?
    local originCFrame: CFrame?

    if effect then
      if parent:IsA("BasePart") then
        originSize = parent.Size
        originCFrame = parent.CFrame
      elseif parent:IsA("Attachment") then
        originSize = Vector3.zero
        originCFrame = parent.WorldCFrame
      end
    end

    if not originCFrame then
      return
    end

    local endPoint = effect:FindFirstChild("End")
    local endT1 = endPoint and endPoint:FindFirstChild("T1")

    if endPoint and not endPoint:IsA("Attachment") then
      endPoint = nil
    end

    if endT1 and not endT1:IsA("Attachment") then
      endT1 = nil
    end

    local bezier = not endPoint and Bezier.new(points, 100)

    local lines = {}

    for i = from, to do
      local rng = Random.new(i + 1)

      local cf = if parent:IsA("Attachment")
        then originCFrame * CFrame.new(Vector3.zero, Vector3.FromNormalId(emission_direction)).Rotation
        else drawFunc(i, originCFrame, originSize, emission_direction, partial)

      local normal = Vector3.FromNormalId(emission_direction)

      local pitchAxis = normal:Cross(originCFrame.LookVector)

      if pitchAxis.Magnitude < 0.001 then
        pitchAxis = normal:Cross(originCFrame.UpVector)
      end

      local spread = CFrame.fromAxisAngle(normal, math.rad(rng:NextNumber(-spreadAngle.x, spreadAngle.x)))
        * CFrame.fromAxisAngle(pitchAxis, math.rad(rng:NextNumber(-spreadAngle.y, spreadAngle.y)))

      cf *= spread

      if face == "Inward" or (face == "InAndOut" and rng:NextInteger(0, 1) == 1) then
        cf *= CFrame.fromOrientation(0, math.pi, 0)
      end

      if endPoint and mirror and (cf.Position - endPoint.WorldPosition).Unit:Dot(cf.RightVector) >= 0 then
        local rot = mirrorRot * emit_utility.DEG_TO_RAD
        cf *= CFrame.fromOrientation(rot.x, rot.y, rot.z)
      end

      if endPoint then
        local pts = {}

        for i, pt in points do
          table.insert(
            pts,
            if i == (#points - 1)
              then endT1 and endT1.WorldPosition or endPoint.WorldPosition
              else if i == #points then endPoint.WorldPosition else cf * (pt - points[1])
          )
        end

        bezier = Bezier.new(pts)
      end

      local prev = nil

      bezier:forSample(0.5, function(pos, i)
        if not endPoint then
          pos = cf * (pos - points[1])
        end

        if prev then
          table.insert(lines, prev)
        end

        if i ~= 0 then
          prev = pos
        end

        table.insert(lines, pos)
      end)
    end

    debug.profileend()

    task.synchronize()
    debug.profilebegin("vfxPathWorker::addBezierLinesSerial")

    handle:AddLines(lines)

    debug.profileend()
  end
)

actor:BindToMessageParallel(
  "drawChunk",
  function(emitter: ParticleEmitter, handle: WireframeHandleAdornment, from: number, to: number, rate: number)
    debug.profilebegin("vfxPathWorker::drawChunk")

    local drawFunc = drawFuncMap[emitter.Shape.Name] and drawFuncMap[emitter.Shape.Name][emitter.ShapeStyle.Name]

    if not drawFunc then
      logger.warnOnce(
        100,
        `shape function for shape {emitter.Shape.Name} with style {emitter.ShapeStyle.Name} doesn't exist! this is likely because roblox added a new shape and it's currently not supported by the plugin.`
      )
      return
    end

    local originSize: Vector3?
    local originCFrame: CFrame?

    local parent = emitter.Parent

    if parent then
      if parent:IsA("BasePart") then
        originSize = parent.Size
        originCFrame = parent.CFrame
      elseif parent:IsA("Attachment") then
        originSize = Vector3.zero
        originCFrame = parent.WorldCFrame
      end
    end

    if not originCFrame then
      return
    end

    local lines = {}

    local single = parent and parent:IsA("Attachment") and emitter.SpreadAngle == Vector2.zero

    for i = from, to do
      local rng = Random.new(i + 1)

      local speed = if single then emitter.Speed.Max else rng:NextNumber(emitter.Speed.Min, emitter.Speed.Max)

      local lifetime = if single
        then emitter.Lifetime.Max
        else rng:NextNumber(emitter.Lifetime.Min, emitter.Lifetime.Max)

      local function getSurfaceCFrame(cf: CFrame, n: Vector3, pos: Vector3)
        local up = math.abs(n:Dot(Vector3.yAxis)) > 0.99 and Vector3.zAxis or Vector3.yAxis
        local rot = CFrame.lookAt(Vector3.zero, n, up)
        return cf * CFrame.new(pos) * rot
      end

      local cf = if parent:IsA("Attachment")
        then shape.getSurfaceCFrame(originCFrame, Vector3.FromNormalId(emitter.EmissionDirection), Vector3.zero)
        else drawFunc(i, originCFrame, originSize, emitter.EmissionDirection, emitter.ShapePartial)

      local normal = Vector3.FromNormalId(emitter.EmissionDirection)

      local pitchAxis = normal:Cross(originCFrame.LookVector)

      if pitchAxis.Magnitude < 0.001 then
        pitchAxis = normal:Cross(originCFrame.UpVector)
      end

      local spread = CFrame.fromOrientation(
        math.rad(rng:NextNumber(-emitter.SpreadAngle.X, emitter.SpreadAngle.X)),
        math.rad(rng:NextNumber(-emitter.SpreadAngle.Y, emitter.SpreadAngle.Y)),
        0
      )

      cf *= spread

      if
        emitter.ShapeInOut == Enum.ParticleEmitterShapeInOut.Inward
        or (emitter.ShapeInOut == Enum.ParticleEmitterShapeInOut.InAndOut and rng:NextInteger(0, 1) == 1)
      then
        cf *= CFrame.fromOrientation(0, math.pi, 0)
      end

      local drag = emitter.Drag
      local acceleration = emitter.LockedToPart and originCFrame:VectorToWorldSpace(emitter.Acceleration)
        or emitter.Acceleration

      local pos = cf.Position
      local velocity = cf.LookVector * speed

      local prevPos = pos
      local prevDir: Vector3?

      local samples = lifetime / (1 / rate)

      local function deltaStep(deltaTime: number, last: boolean)
        local startPos = pos

        local endVelocity = (velocity + acceleration * deltaTime) * (2 ^ (-drag * deltaTime))
        local avgVelocity = (velocity + endVelocity) / 2

        local nextPos = pos + avgVelocity * deltaTime

        velocity = endVelocity

        local delta = nextPos - startPos
        local dir = delta.Magnitude > 0 and delta.Unit or prevDir or Vector3.zero

        if prevDir or last then
          if prevDir and prevDir:Dot(dir) <= math.cos(math.rad(2)) then
            table.insert(lines, prevPos)
            table.insert(lines, startPos)
            prevPos = startPos
          elseif last then
            table.insert(lines, prevPos)
            table.insert(lines, nextPos)
          end
        end

        prevDir = dir
        pos = nextPos
      end

      local remainder = samples <= 1 and samples or samples % 1
      local wholeSamples = math.floor(samples)

      for j = 1, wholeSamples do
        deltaStep(1 / rate, remainder == 0 and j == wholeSamples)
      end

      if remainder ~= 0 then
        deltaStep(remainder / rate, true)
      end
    end

    debug.profileend()

    task.synchronize()
    debug.profilebegin("vfxPathWorker::addLinesSerial")

    handle:AddLines(lines)

    debug.profileend()
  end
)

actor:BindToMessageParallel(
  "drawDebrisChunk",
  function(origin: Attachment, ref: Part, handle: WireframeHandleAdornment, from: number, to: number, rate: number)
    local lines = {}

    local linmag = utility.getRangeAttribute(ref, "LinearMagnitude", NumberRange.new(15, 25), nil, true)
    local airtime =
      utility.getRangeAttribute(ref, "Airtime", NumberRange.new(0.5, 0.5), NumberRange.new(0, math.huge), true)

    local minDir = utility.getAttribute(ref, "MinDirection", -vector.one, true)
    local maxDir = utility.getAttribute(ref, "MaxDirection", vector.one, true)

    local acceleration = Vector3.new(0, -workspace.Gravity, 0)

    for i = from, to do
      local rng = Random.new(i + 1)

      local lifetime = 1

      local pos = origin.WorldPosition

      local relDir = utility.randomUnitVector(minDir, maxDir, rng)
      local worldDir = origin.WorldCFrame:VectorToWorldSpace(relDir)

      local velocity = utility.getImpulseForce(
        origin.WorldPosition,
        origin.WorldPosition + worldDir.Unit * rng:NextNumber(linmag.Min, linmag.Max),
        rng:NextNumber(airtime.Min, airtime.Max)
      )

      local prevPos = pos
      local prevDir: Vector3?

      local samples = lifetime / (1 / rate)

      local function deltaStep(deltaTime: number, last: boolean)
        local nextPos = pos + velocity * deltaTime + acceleration * (0.5 * deltaTime ^ 2)
        velocity = (velocity + acceleration * deltaTime)

        local delta = nextPos - pos
        local dir = delta.Magnitude > 0 and delta.Unit or prevDir or Vector3.zero

        if prevDir then
          if prevDir:Dot(dir) <= math.cos(math.rad(2)) then
            table.insert(lines, prevPos)
            table.insert(lines, nextPos)

            prevPos = nextPos
          elseif last then
            table.insert(lines, prevPos)
            table.insert(lines, nextPos)
          end
        else
          prevDir = dir
        end

        pos = nextPos
      end

      local remainder = samples % 1
      local wholeSamples = math.floor(samples)

      for j = 1, wholeSamples do
        deltaStep(1 / rate, remainder == 0 and j == wholeSamples)
      end

      if remainder ~= 0 then
        deltaStep(remainder / rate, true)
      end
    end

    task.synchronize()
    handle:AddLines(lines)
  end
)

actor:SetAttribute("loaded", true)
]]></ProtectedString>
