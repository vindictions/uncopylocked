			<Item class="ModuleScript" referent="RBX86C2D7DDC72B4E50A474803FE97DB509">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Font = require("./Font")
local Hover = require("./Hover")
local Round = require("./Round")
local Stroke = require("./Stroke")
local OnHold = require("./OnHold")
local Window = require("./Window")
local Prompt = require("./Prompt")
local Switch = require("./Switch")
local Slider = require("./Slider")
local Options = require("./Options")
local Padding = require("./Padding")
local Tooltip = require("./Tooltip")
local Dropdown = require("./Dropdown")
local OnKeybind = require("./OnKeybind")
local ScaleColor = require("./ScaleColor")
local Scrollable = require("./Scrollable")
local AlphaBlend = require("./AlphaBlend")
local ErrorPrompt = require("./ErrorPrompt")
local NumberField = require("./NumberField")

local extended_scope = {
  Font = Font,
  Round = Round,
  Hover = Hover,
  Stroke = Stroke,
  OnHold = OnHold,
  Window = Window,
  Prompt = Prompt,
  Switch = Switch,
  Slider = Slider,
  Options = Options,
  Padding = Padding,
  Tooltip = Tooltip,
  Dropdown = Dropdown,
  OnKeybind = OnKeybind,
  ScaleColor = ScaleColor,
  Scrollable = Scrollable,
  AlphaBlend = AlphaBlend,
  ErrorPrompt = ErrorPrompt,
  NumberField = NumberField,
}

export type scope = Fusion.Scope<typeof(Fusion) & typeof(extended_scope)>

local ui_types = {}

function ui_types.ext_scope(scope: Fusion.Scope?)
  if scope then
    return scope:deriveScope(extended_scope)
  else
    local t = table.clone(Fusion)

    for k, v in extended_scope do
      t[k] = v
    end

    return Fusion.scoped(t)
  end
end

return ui_types
]]></ProtectedString>
