							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")
local symbols = require("../../../.symbols")

type props = {
  int: boolean?,
  three_d: boolean?,
  readonly: boolean?,

  value: Fusion.Value<vector>,

  min: vector?,
  max: vector?,
}

local NUMBER = "(%-?%d*%.?%d+)"

local function VectorInput(scope: ui_types.scope, props: props)
  local unmodifiedInput = ""

  local inputBox: Fusion.Value<TextBox?> = scope:Value(nil)

  local function updateText(vec: vector)
    if vec == symbols.nil_symbol then
      return "-"
    end

    local function fmt(s: number)
      return string.format(`%.3f`, s):gsub("0*$", ""):gsub("%.$", "")
    end

    if props.int then
      return `{tostring(math.round(vec.x))}, {tostring(math.round(vec.y))}{props.three_d and ", " .. tostring(
        math.round(vec.z)
      ) or ""}`
    else
      return `{fmt(vec.x)}, {fmt(vec.y)}{props.three_d and ", " .. fmt(vec.z) or ""}`
    end
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    AnchorPoint = Vector2.new(0.5, 0),
    Position = UDim2.fromScale(0.5, 0),

    Size = scope:Computed(function(use)
      return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
    end),

    ClipsDescendants = true,

    [Children] = {
      inputBox:set(scope:New "TextBox" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        FontFace = ui_conf.font,
        TextEditable = not props.readonly,

        Text = scope:Computed(function(use)
          local vec = use(props.value)
          return updateText(vec)
        end),

        TextColor3 = props.readonly and ui_conf.colors.muted or ui_conf.colors.text,
        TextSize = ui_conf.text_sizes.mini,

        TextXAlignment = Enum.TextXAlignment.Left,

        [OnEvent "Focused"] = function()
          local input = peek(inputBox)

          if input then
            unmodifiedInput = input.Text

            input.CursorPosition = #input.Text + 1
            input.SelectionStart = 0
          end
        end,

        [OnEvent "FocusLost"] = function()
          local input = peek(inputBox)
          local x, y, z = 0, 0, 0

          if props.three_d then
            x, y, z = input.Text:match(`{NUMBER}[,%s]%s*{NUMBER}[,%s]%s*{NUMBER}`)
          else
            x, y = input.Text:match(`{NUMBER}[,%s]%s*{NUMBER}`)
          end

          if not x then
            x = input.Text:match(`{NUMBER}`)
            y = x

            if props.three_d then
              z = x
            end
          end

          x, y, z = tonumber(x), tonumber(y), tonumber(z)

          if x and y and z then
            input.Text = unmodifiedInput

            local vec = vector.create(x, y, z)

            if props.min then
              vec = vector.min(vec, props.min)
            end

            if props.max then
              vec = vector.max(vec, props.max)
            end

            props.value:set(vec)
          else
            input.Text = unmodifiedInput
          end
        end,

        [Children] = {
          scope:Padding(1, 0, 0, 0),
        },
      } :: TextBox),
    },
  },
    function(vec: vector)
      local input = peek(inputBox)
      input.Text = updateText(vec)
    end
end

return VectorInput
]]></ProtectedString>
