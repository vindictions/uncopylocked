					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local CoreGui = game:GetService("CoreGui")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("./ui_conf")
local symbols = require("../.symbols")

type props = {
  search: Fusion.UsedAs<boolean>?,
  stroke: Fusion.UsedAs<boolean>?,

  pad_top: Fusion.UsedAs<number>?,
  pad_around: Fusion.UsedAs<number>?,

  options: Fusion.UsedAs<string>,
  selected: Fusion.Value<string>,

  item_bg: Fusion.UsedAs<Color3>,

  background: Fusion.UsedAs<Color3>,
  scrollbar_bg: Fusion.UsedAs<Color3>,
  background_sel: Fusion.UsedAs<Color3>,
}

type list_props = props & {
  size: Fusion.Value<Vector2>,
  origin: Fusion.Value<Vector2>,
}

local function List(scope: Fusion.Scope, props: list_props)
  scope = scope:innerScope()

  local mainScope = scope

  local scaledContentSize = scope:Value(Vector2.zero)

  local contentSize = scope:Computed(function(use)
    return use(scaledContentSize) / use(ui_conf.scale)
  end)

  local tp = scope:Value(1)
  local tpAnim = scope:Spring(tp, 20, 1)

  local searchQuery = scope:Value("")
  local searchBarValue: Fusion.Value<TextBox?> = scope:Value(nil)

  local searchHeight = scope:Computed(function(use)
    return use(props.search) and use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop) or 0
  end)

  local scrollbarHolding = scope:Value(false)

  local viewport = scope:Value(workspace.CurrentCamera.ViewportSize)

  table.insert(
    scope,
    workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
      viewport:set(workspace.CurrentCamera.ViewportSize)
    end)
  )

  scope:New "ScreenGui" {
    Parent = CoreGui,

    ResetOnSpawn = false,
    IgnoreGuiInset = true,

    DisplayOrder = scope:Computed(function(use)
      return use(ui_conf.display_order) + 5
    end),

    [Children] = {
      scope:New "UIScale" {
        Scale = ui_conf.scale,
      },

      scope:New "ImageButton" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        [OnEvent "MouseButton1Click"] = function()
          if not peek(scrollbarHolding) then
            scope:doCleanup()
          end
        end,
      },

      scope:New "CanvasGroup" {
        BackgroundColor3 = props.background,

        GroupTransparency = tpAnim,

        Size = scope:Computed(function(use)
          local scale = use(ui_conf.scale)

          local size = use(props.size) / scale
          local origin = use(props.origin) / scale

          return UDim2.fromOffset(
            math.ceil(use(props.size).X / use(ui_conf.scale)) - 1,
            math.clamp(
              use(contentSize).Y
                + use(ui_conf.padding.base) * 2
                + (use(searchHeight) + (use(props.search) and use(ui_conf.padding.base) or 0)),
              0,
              math.max(
                75,
                use(viewport).Y - origin.Y - size.Y - use(props.pad_top or 0) - use(ui_conf.padding.side) - 1
              )
            )
          )
        end),

        Position = scope:Computed(function(use)
          local scale = use(ui_conf.scale)

          local size = use(props.size) / scale
          local origin = use(props.origin) / scale

          return UDim2.fromOffset(origin.X + 1, origin.Y + size.Y + use(props.pad_top or 0) + 1)
        end),

        [Children] = {
          if props.stroke
            then scope:New "UIStroke" {
              Color = props.item_bg,

              Thickness = 1,
              Transparency = tpAnim,
            }
            else nil,

          scope:Round(ui_conf.rounding.base),
          scope:Padding(props.pad_around or ui_conf.padding.base),

          scope:Hover "Frame" {
            BackgroundColor3 = props.item_bg,

            Size = scope:Computed(function(use)
              return UDim2.new(1, 0, 0, use(searchHeight))
            end),

            [Children] = {
              scope:Round(ui_conf.rounding.mini),

              searchBarValue:set(scope:New "TextBox" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.new(0.5, 0),
                Position = UDim2.fromScale(0.5, 0),

                Size = scope:Computed(function(use)
                  return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
                end),

                FontFace = ui_conf.font,

                PlaceholderText = "search",

                TextColor3 = ui_conf.colors.text,
                PlaceholderColor3 = ui_conf.colors.muted,

                TextSize = ui_conf.text_sizes.mini,

                Visible = props.search,
                ClipsDescendants = true,

                TextXAlignment = Enum.TextXAlignment.Left,

                [Out "Text"] = searchQuery,

                [OnEvent "Focused"] = function()
                  local bar = peek(searchBarValue)

                  if bar then
                    bar.CursorPosition = #bar.Text + 1
                    bar.SelectionStart = 0
                  end
                end,
              } :: TextBox),
            },
          },

          scope:New "Frame" {
            BackgroundTransparency = 1,

            Position = scope:Computed(function(use)
              return UDim2.fromOffset(0, use(searchHeight) + (use(props.search) and use(ui_conf.padding.base) or 0))
            end),

            Size = scope:Computed(function(use)
              return UDim2.new(1, 0, 1, -(use(searchHeight) + (use(props.search) and use(ui_conf.padding.base) or 0)))
            end),

            [Children] = {
              scope:Scrollable({
                scrollbar_holding = scrollbarHolding,

                background = props.background,
                scrollbar_bg = props.scrollbar_bg,

                content_size = contentSize,
                scrollbar_padding = ui_conf.padding.base,

                children = {
                  scope:New "CanvasGroup" {
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,

                    Size = UDim2.fromScale(1, 0),

                    [Children] = {
                      scope:Round(ui_conf.rounding.mini),

                      scope:New "UIListLayout" {
                        SortOrder = Enum.SortOrder.LayoutOrder,

                        [Out "AbsoluteContentSize"] = scaledContentSize,
                      },

                      scope:ForPairs(props.options, function(_, scope, index, text)
                        local hovered = scope:Value(false)

                        return index,
                          scope:Hover("TextButton", nil, hovered) {
                            Size = scope:Computed(function(use)
                              return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.nano) + use(ui_conf.padding.prop))
                            end),

                            FontFace = ui_conf.font,

                            TextColor3 = ui_conf.colors.text,

                            BackgroundColor3 = scope:Computed(function(use)
                              if use(props.selected) == text then
                                local sel = use(props.background_sel)
                                local normal = use(props.item_bg)

                                return use(hovered) and normal or sel
                              else
                                return use(props.item_bg)
                              end
                            end),

                            LayoutOrder = scope:Computed(function(use)
                              local start, stop = string.find(text:lower(), use(searchQuery):lower(), 1, true)
                              return ((start and stop ~= 0) and start ^ 2 or 1000 + index)
                            end),

                            Text = text,
                            TextSize = ui_conf.text_sizes.nano,

                            TextTruncate = Enum.TextTruncate.SplitWord,
                            TextXAlignment = Enum.TextXAlignment.Left,

                            [OnEvent "MouseButton1Click"] = function()
                              props.selected:set(text)
                              mainScope:doCleanup()
                            end,

                            [Children] = {
                              scope:Padding(ui_conf.padding.prop, 0),
                            },
                          }
                      end),
                    },
                  },
                },
              }),
            },
          },
        },
      },
    },
  }

  tp:set(0)

  if props.search then
    local bar = peek(searchBarValue)

    if bar then
      bar:CaptureFocus()
    end
  end

  return scope
end

local function Dropdown(scope: Fusion.Scope, props: props)
  local expanded = scope:Value(false)

  local size = scope:Value(Vector2.zero)
  local origin = scope:Value(Vector2.zero)

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    Size = UDim2.fromScale(1, 1),

    [Children] = {
      scope:New "ImageButton" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.fromScale(1, 1)
        end),

        [Out "AbsoluteSize"] = size,
        [Out "AbsolutePosition"] = origin,

        [OnEvent "MouseButton1Click"] = function()
          expanded:set(not peek(expanded))

          local listScope = List(scope, {
            search = props.search,
            stroke = props.stroke,

            pad_top = props.pad_top,
            pad_around = props.pad_around,

            options = props.options,
            selected = props.selected,

            item_bg = props.item_bg,

            background = props.background,
            scrollbar_bg = props.scrollbar_bg,
            background_sel = props.background_sel,

            size = size,
            origin = origin,
          })

          table.insert(listScope, function()
            expanded:set(false)
          end)
        end,

        [Children] = {
          scope:Padding(ui_conf.padding.side, 0),

          scope:New "ImageLabel" {
            BackgroundTransparency = 1,

            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.fromScale(1, 0.5),

            Size = scope:Computed(function(use)
              return UDim2.fromOffset(8, 8)
            end),

            Image = scope:Computed(function(use)
              return use(expanded) and "rbxassetid://113719849566863" or "rbxassetid://76559305799118"
            end),

            ImageColor3 = ui_conf.colors.text,
          },

          scope:New "TextLabel" {
            BackgroundTransparency = 1,

            Size = scope:Computed(function(use)
              return UDim2.new(1, -8, 1, 0)
            end),

            Text = scope:Computed(function(use)
              local sel = use(props.selected)
              return sel == symbols.nil_symbol and "-" or sel
            end),

            TextColor3 = ui_conf.colors.text,

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.mini,

            TextTruncate = Enum.TextTruncate.SplitWord,
            TextXAlignment = Enum.TextXAlignment.Left,

            [Children] = {
              scope:Padding(0, 0, ui_conf.padding.side, 0),
            },
          },
        },
      },
    },
  }
end

return Dropdown
]]></ProtectedString>
					<string name="ScriptGuid">{2D65C835-2879-4C1D-B707-11849986187A}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Dropdown</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXF5EF5C432AB64A86B1BE72D88BD7AEFE">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local TextService = game:GetService("TextService")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Children = Fusion.Children
local peek = Fusion.peek

local ui_conf = require("./ui_conf")

type props = {
  title: Fusion.UsedAs<string>?,
  padding: Fusion.UsedAs<number>?,

  text: Fusion.UsedAs<string>,

  size: Vector2?,
  position: Vector2?,

  precompute_height: boolean?,

  on_close: (() -> ())?,

  float: Vector2?,
  near_element: GuiObject?,
}

local function ErrorPrompt(scope: Fusion.Scope, props: props)
  local height = 0

  if props.precompute_height then
    local params = scope:New "GetTextBoundsParams" {
      Text = peek(props.text),
      Font = peek(ui_conf.font),
      Size = peek(ui_conf.text_sizes.mini),
      Width = props.size and props.size.x or 350,
    }

    height = TextService:GetTextBoundsAsync(params).Y + peek(ui_conf.padding.side) * 4

    if props.size then
      props.size = Vector2.new(props.size.x, height)
    end

    if props.position then
      props.position = Vector2.new(
        props.position.x,
        props.position.y - (peek(ui_conf.text_sizes.title_bar) + peek(ui_conf.padding.base) * 2) / 2
      )
    end
  end

  scope:Prompt({
    title = props.title or "Error",

    float = props.float,

    padding = props.padding,
    near_element = props.near_element,

    size = props.size or Vector2.new(350, height),

    anchor = props.anchor,
    position = props.position,

    on_close = props.on_close,

    automatic_height = true,

    child = function(scope)
      return scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 0),

        [Children] = {
          scope:Padding(ui_conf.padding.side),

          scope:Hover "TextBox" {
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = ui_conf.colors.surface,

            Size = UDim2.fromScale(1, 0),

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.base,

            Text = props.text,
            TextColor3 = ui_conf.colors.text,

            TextWrapped = true,
            TextEditable = false,

            [Children] = {
              scope:Round(ui_conf.rounding.base),
              scope:Padding(ui_conf.padding.side),
            },
          },
        },
      }
    end,
  })
end

return ErrorPrompt
]]></ProtectedString>
					<string name="ScriptGuid">{1E2C18FD-ECA9-4CA7-ABAF-63F00087651F}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">ErrorPrompt</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXD041248F989E4B969F491CE1F4DA5A41">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local peek = Fusion.peek

local function _Font(scope: Fusion.Scope, font: Fusion.UsedAs<Font>, weight: Enum.FontWeight?, style: Enum.FontStyle?)
  if (not weight and not style) or (peek(font).Weight == weight and peek(font).Style == style) then
    return font
  else
    return scope:Computed(function(use)
      if style then
        return Font.new(use(font).Family, weight, style)
      else
        return Font.new(use(font).Family, weight)
      end
    end)
  end
end

return _Font
]]></ProtectedString>
					<string name="ScriptGuid">{5BDF62C4-4C6C-48DA-BA84-0B569F73CACD}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Font</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX1146EAFB26F14FEEADB1A44253785AEB">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent

local logger = require("../lib/logger")
local ui_conf = require("./ui_conf")

local function Hover(scope: Fusion.Scope, class: string, factor: number?, hovered: Fusion.Value<boolean>?)
  return function(props: Fusion.PropertyTable)
    local hovered = hovered or scope:Value(false)

    local key = if props.BackgroundTransparency == 1 and class == "ImageButton" or class == "ImageLabel"
      then "ImageColor3"
      else "BackgroundColor3"

    local color = props[key]

    if not color then
      logger.error("hover objects must have a background color specified in the property table")
    end

    props[key] = scope:Spring(
      scope:Computed(function(use, scope)
        local normal = use(color)
        local scaled = use(scope:ScaleColor(
          scope:Computed(function(use)
            return (factor and use(factor) or 1.05) * use(ui_conf.hover_scale)
          end),
          color
        ))

        return use(hovered) and scaled or normal
      end),
      30,
      1
    )

    props[OnEvent "MouseEnter"] = function()
      hovered:set(true)
    end

    props[OnEvent "MouseLeave"] = function()
      hovered:set(false)
    end

    local obj = scope:New(class)(props)

    -- EVIL HAX!11!
    obj.AncestryChanged:Once(function()
      local gui = obj:FindFirstAncestorOfClass("ScreenGui")

      if gui then
        table.insert(
          scope,
          gui:GetPropertyChangedSignal("Enabled"):Connect(function()
            if not gui.Enabled then
              hovered:set(false)
            end
          end)
        )
      end
    end)

    return obj
  end
end

return Hover
]]></ProtectedString>
					<string name="ScriptGuid">{1DC66464-B6C4-4265-BBFD-7D18D171BFC6}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Hover</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXEBE7EC1522104015A3DC647B45E6410C">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("./ui_conf")
local symbols = require("../.symbols")

type props = {
  value: Fusion.Value<number?>,

  size: Fusion.UsedAs<UDim2>?,
  background: Fusion.UsedAs<Color3>?,

  min_size: Fusion.UsedAs<Vector2>?,
  max_size: Fusion.UsedAs<Vector2>?,

  padding: Fusion.UsedAs<number>?,

  placeholder: string?,
  on_enter: (() -> ())?,

  int: boolean?,
  suffix: string?,

  min: Fusion.UsedAs<number>,
  max: Fusion.UsedAs<number>,
}

local function NumberField(scope: Fusion.Scope, props: props)
  local unmodifiedInput = ""

  local bounds = scope:Value(Vector2.zero)
  local absSize = scope:Value(Vector2.zero)

  local inputValue: Fusion.Value<TextBox?> = scope:Value(nil)

  return scope:Hover "ImageButton" {
    BackgroundColor3 = props.background or ui_conf.colors.surface,

    Size = props.size or UDim2.fromScale(1, 1),
    SizeConstraint = props.size_constraint or Enum.SizeConstraint.RelativeXY,

    [OnEvent "MouseButton1Click"] = function()
      local input = peek(inputValue)

      if input then
        input:CaptureFocus()
      end
    end,

    [Children] = {
      scope:Round(ui_conf.rounding.mini),

      if props.min_size or props.max_size
        then scope:New "UISizeConstraint" {
          MinSize = props.min_size or Vector2.zero,
          MaxSize = props.max_size or Vector2.zero,
        }
        else nil,

      inputValue:set(scope:New "TextBox" {
        BackgroundTransparency = 1,

        AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.fromScale(0.5, 0),

        Size = scope:Computed(function(use)
          return UDim2.new(1, -use(props.padding or ui_conf.padding.side) * 2, 1, 0)
        end),

        FontFace = ui_conf.font,

        Text = scope:Computed(function(use)
          local v = use(props.value)

          if v == symbols.nil_symbol then
            return "-"
          end

          local txt = v and string.format("%.2f", v):gsub("0*$", ""):gsub("%.$", "") or ""

          return `{txt}{props.suffix or ""}`
        end),

        PlaceholderText = props.placeholder or "",

        TextColor3 = ui_conf.colors.text,
        PlaceholderColor3 = ui_conf.colors.muted,

        TextSize = ui_conf.text_sizes.mini,

        ClipsDescendants = true,

        TextXAlignment = scope:Computed(function(use)
          return use(bounds).X > use(absSize).X and Enum.TextXAlignment.Left or Enum.TextXAlignment.Center
        end),

        [Out "TextBounds"] = bounds,
        [Out "AbsoluteSize"] = absSize,

        [OnEvent "Focused"] = function()
          local input = peek(inputValue)

          if input then
            unmodifiedInput = input.Text

            input.CursorPosition = #input.Text + 1
            input.SelectionStart = 0
          end
        end,

        [OnEvent "FocusLost"] = function(enter: boolean)
          local input = peek(inputValue)
          local text = input.Text

          if props.suffix then
            text = string.gsub(text:lower(), `{props.suffix:lower()}$`, "")
          end

          local value = tonumber(text)

          if value then
            input.Text = unmodifiedInput
            props.value:set(math.clamp(props.int and math.round(value) or value, peek(props.min), peek(props.max)))
          else
            input.Text = unmodifiedInput
          end

          if enter and props.on_enter then
            props.on_enter()
          end
        end,
      } :: TextBox),
    },
  }
end

return NumberField
]]></ProtectedString>
