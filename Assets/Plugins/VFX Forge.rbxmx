					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local function Round(scope: Fusion.Scope, offset: Fusion.UsedAs<number>, scale: Fusion.UsedAs<number>?)
  return scope:New "UICorner" {
    CornerRadius = scope:Computed(function(use)
      return UDim.new(use(scale) or 0, use(offset))
    end),
  }
end

return Round
]]></ProtectedString>
					<string name="ScriptGuid">{B1C1AB91-D8D3-4214-A359-2DFCEC7E3214}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Round</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXC4A64EB12D8D42CF8192A2C9D1673D5B">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)
local Oklab = require(script.Parent.Parent.pkg.Fusion.Colour.Oklab)

local function ScaleColor(scope: Fusion.Scope, factor: Fusion.UsedAs<number>, color: Fusion.UsedAs<Color3>)
  return scope:Computed(function(use)
    local lab = Oklab.fromSRGB(use(color))
    return Oklab.toSRGB(Vector3.new(lab.X * use(factor) ^ (1 / 3), lab.Y, lab.Z))
  end)
end

return ScaleColor
]]></ProtectedString>
					<string name="ScriptGuid">{2579392A-F452-494D-9048-28156993728F}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">ScaleColor</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX549B60E2CEC84E35A4D3FCCB7408CC74">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local OnChange = Fusion.OnChange
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("./ui_conf")

type props = {
  padding: number?,

  scrollbar_padding: Fusion.UsedAs<number>?,
  scrollbar_holding: Fusion.Value<boolean>?,

  on_canvaspos: (() -> ())?,

  offset: number?,

  size: Fusion.UsedAs<UDim2>?,
  content_size: Fusion.Value<Vector2>,

  background: Fusion.UsedAs<Color3>?,
  scrollbar_bg: Fusion.UsedAs<Color3>?,

  children: Fusion.Child?,
}

local function Scrollable(scope: Fusion.Scope, props: props)
  local scrollingFrameValue: Fusion.Value<ScrollingFrame?> = scope:Value(nil)

  local offset = props.offset or 0

  local canvasPos = scope:Value(0)
  local scrollWindowSize = scope:Value(Vector2.zero)

  local topScrollAlpha = scope:Value(1)
  local topScrollAlphaAnim = scope:Spring(topScrollAlpha, 30, 1.5)

  local bottomScrollAlpha = scope:Value(0)
  local bottomScrollAlphaAnim = scope:Spring(bottomScrollAlpha, 30, 1.5)

  local function handleScrollInput(input: InputObject)
    if input.UserInputType ~= Enum.UserInputType.MouseWheel then
      return
    end

    local maxScroll = math.max(peek(props.content_size).Y * peek(ui_conf.scale) - peek(scrollWindowSize).Y, 0) + offset

    canvasPos:set(math.clamp(peek(canvasPos) - 50 * peek(ui_conf.scale) * input.Position.Z, 0, maxScroll))

    local alpha = math.clamp(peek(canvasPos) / maxScroll, 0, 1)

    bottomScrollAlpha:set(maxScroll ~= 0 and (alpha == 1 and 1 or 0) or 1)
    topScrollAlpha:set(maxScroll ~= 0 and (alpha == 0 and 1 or 0) or 1)
  end

  scope:Observer(props.content_size):onChange(function()
    handleScrollInput({ UserInputType = Enum.UserInputType.MouseWheel, Position = Vector3.zero })
  end)

  local scrollbarVisible = scope:Computed(function(use)
    return use(props.content_size).y > (use(scrollWindowSize).y / use(ui_conf.scale))
  end)

  return {
    scope:New "Frame" {
      BackgroundColor3 = props.scrollbar_bg or ui_conf.colors.surface,

      AnchorPoint = Vector2.new(1, 0),
      Position = UDim2.fromScale(1, 0),

      Size = UDim2.new(0, 6, 1, 0),
      ZIndex = -1,

      Visible = scrollbarVisible,

      [Children] = {
        scope:Round(0, 0.5),
        scope:OnHold(props.scrollbar_holding or scope:Value(false), function(mousePos, deltaPos)
          local frame = peek(scrollingFrameValue)

          if not frame then
            return
          end

          local pos = frame.AbsolutePosition.Y
          local window = peek(scrollWindowSize).Y
          local content = peek(props.content_size).Y * peek(ui_conf.scale)

          local maxScroll = math.max(content - window, 0) + offset
          local oldAlpha = math.clamp(peek(canvasPos) / maxScroll, 0, 1)

          if (mousePos.Y < pos and oldAlpha == 0) or (mousePos.Y > pos + window and oldAlpha == 1) then
            return
          end

          canvasPos:set(math.clamp(peek(canvasPos) - deltaPos.Y * (content / window), 0, maxScroll))

          local alpha = math.clamp(peek(canvasPos) / maxScroll, 0, 1)

          bottomScrollAlpha:set(maxScroll ~= 0 and (alpha == 1 and 1 or 0) or 1)
          topScrollAlpha:set(maxScroll ~= 0 and (alpha == 0 and 1 or 0) or 1)
        end),
      },
    },

    scope:New "Frame" {
      Size = scope:Computed(function(use)
        return UDim2.new(1, -(6 + use(props.scrollbar_padding or ui_conf.padding.side)), 0, 40)
      end),

      ZIndex = 10,
      Visible = scrollbarVisible,

      [Children] = {
        scope:New "UIGradient" {
          Rotation = 90,

          Transparency = scope:Computed(function(use)
            return NumberSequence.new({
              NumberSequenceKeypoint.new(0, use(topScrollAlphaAnim)),
              NumberSequenceKeypoint.new(1, 1),
            })
          end),

          Color = scope:Computed(function(use)
            return ColorSequence.new({
              ColorSequenceKeypoint.new(0, use(props.background or ui_conf.colors.base)),
              ColorSequenceKeypoint.new(1, use(props.background or ui_conf.colors.base)),
            })
          end),
        },
      },
    },

    scope:New "Frame" {
      AnchorPoint = Vector2.new(0, 1),
      Position = UDim2.fromScale(0, 1),

      Size = scope:Computed(function(use)
        return UDim2.new(1, -(6 + use(props.scrollbar_padding or ui_conf.padding.side)), 0, 40)
      end),

      ZIndex = 10,
      Visible = scrollbarVisible,

      [Children] = {
        scope:New "UIGradient" {
          Rotation = 90,

          Transparency = scope:Computed(function(use)
            return NumberSequence.new({
              NumberSequenceKeypoint.new(0, 1),
              NumberSequenceKeypoint.new(1, use(bottomScrollAlphaAnim)),
            })
          end),

          Color = scope:Computed(function(use)
            return ColorSequence.new({
              ColorSequenceKeypoint.new(0, use(props.background or ui_conf.colors.base)),
              ColorSequenceKeypoint.new(1, use(props.background or ui_conf.colors.base)),
            })
          end),
        },
      },
    },

    scrollingFrameValue:set(scope:New "ScrollingFrame" {
      BackgroundTransparency = 1,

      Size = props.size or UDim2.fromScale(1, 1),

      ScrollBarThickness = 6,
      ScrollBarImageColor3 = ui_conf.colors.overlay,

      ScrollingEnabled = false,

      TopImage = "rbxassetid://16409388485",
      MidImage = "rbxassetid://16409399075",
      BottomImage = "rbxassetid://16409396084",

      CanvasPosition = scope:Spring(
        scope:Computed(function(use)
          return Vector2.new(0, use(canvasPos))
        end),
        30,
        1
      ),

      CanvasSize = scope:Computed(function(use)
        return UDim2.fromOffset(0, use(props.content_size).Y + offset)
      end),

      [OnChange "CanvasPosition"] = props.on_canvaspos,

      [OnEvent "InputBegan"] = handleScrollInput,
      [OnEvent "InputChanged"] = handleScrollInput,

      [Out "AbsoluteWindowSize"] = scrollWindowSize,

      [Children] = {
        scope:Padding(
          props.padding or 0,
          props.padding or 0,
          scope:Computed(function(use)
            return use(scrollbarVisible) and 6 + use(props.scrollbar_padding or ui_conf.padding.side)
              or props.padding
              or 0
          end),
          props.padding or 0
        ),

        props.children,
      },
    } :: ScrollingFrame),
  }
end

return Scrollable
