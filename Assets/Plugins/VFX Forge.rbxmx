      bezierPathsVisible:set(not peek(bezierPathsVisible))
      debrisPathsVisible:set(not peek(debrisPathsVisible))
    end
  )

  local th = peek(ui_conf.text_sizes.title_bar) + peek(ui_conf.padding.base) * 2

  scope:OnKeybind("toggle_ui", "Hides/shows UI", conf.settings.keybinds.toggle_ui, function()
    if not peek(shouldBeVisible) then
      return
    end

    guiHidden:set(not peek(guiHidden))
  end)

  local notifText = scope:Value(nil)
  local tp = scope:Value(1)

  local tpAnim = scope:Spring(tp, 30, 1)

  do
    local hideThread

    scope:Observer(notifText):onChange(function()
      if hideThread then
        task.cancel(hideThread)
      end

      tp:set(0)

      hideThread = task.delay(10, function()
        tp:set(1)
        hideThread = nil
      end)
    end)
  end

  local function checkForUpdates()
    if updateChecked or not peek(conf.settings.notifs.check_for_updates) then
      return
    end

    local ok, res, v = pcall(function()
      local info = MarketplaceService:GetProductInfo(133927382668067)

      local desc = info.Description
      local ver = desc and string.match(desc, "!V (.+)")

      if not ver then
        return
      end

      local first = updates[1]

      local num = utility.getVerNum(ver)
      local current = first and utility.getVerNum(first.v) or 0

      return num > current, ver
    end)

    if ok then
      if res then
        notifText:set(`new version {v} is now available`)
      end
    else
      logger.warn(`could not compare against the latest version: {res}`)
    end

    updateChecked = true
  end

  scope:Observer(guiEnabled):onBind(checkForUpdates)
  scope:Observer(conf.settings.notifs.check_for_updates):onBind(checkForUpdates)

  local store = storage.new(scope, "main", {
    updlog_key = "",
