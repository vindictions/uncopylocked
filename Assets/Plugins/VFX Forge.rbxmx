					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Selection = game:GetService("Selection")
local RunService = game:GetService("RunService")
local TextService = game:GetService("TextService")

local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../../.conf")
local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local vfx = require("../../lib/emit")
local attmap = require("../../mod/attmap")
local utility = require("../../lib/utility")

local Promise = require("../../lib/emit/obj/Promise")

type props = {
  effects: Fusion.UsedAs<{
    particles: { ParticleEmitter },
    meshes: { Model },
    beams: { Beam },
    beziers: { Attachment },
  }>,
}

local function Emit(scope: ui_types.scope, props: props)
  local settings = conf.settings.emission

  local widest = scope:Value(0)
  local looped = scope:Value(false)
  local attributes = scope:Value({})

  scope:Observer(props.effects):onBind(function()
    widest:set(0)

    local entries = {}

    local fx = peek(props.effects)

    local function add(name, attr, def, ...)
      local objs = {}

      for _, list in { ... } do
        for _, v in list do
          table.insert(objs, v)
        end
      end

      if #objs == 0 then
        return
      end

      table.insert(entries, { name, attr, def, objs })
    end

    add("Count", "EmitCount", 1, fx.particles, fx.meshes, fx.beziers)

    add(
      "Delay",
      "EmitDelay",
      0,
      fx.particles,
      fx.meshes,
      fx.beams,
      fx.beziers,
      fx.spin_models,
      fx.screen_shakes,
      fx.shockwave_rings,
      fx.shockwave_lines,
      fx.shockwave_debris,
      fx.tween_properties
    )

    add("Duration", "EmitDuration", 0, fx.particles, fx.meshes, fx.beziers, fx.screen_shakes)

    attributes:set(entries)
  end)

  local emitScope

  local function clickEmit()
    if emitScope then
      local s = emitScope
      -- prevent anything else from destroying twice
      emitScope = nil

      s:doCleanup()
    end

    emitScope = scope:innerScope()

    local args = Selection:Get()

    local trail_att = {}
    local trail_previews = {}

    local active = true

    table.insert(emitScope, function()
      active = false
    end)

    local offset = 0

    for i = 1, #args do
      i -= offset

      local obj = args[i]

      if obj:IsA("Trail") then
        table.remove(args, i)
        table.insert(trail_previews, obj)

        offset += 1
      end
    end

    local oneshot

    local function emit()
      if not emitScope then
        return
      end

      if oneshot then
        oneshot:doCleanup()
      end

      oneshot = emitScope:innerScope()

      local promises = {}

      for _, trail in trail_previews do
        local pre = trail_att[trail]

        local r0, r1 = trail.Attachment0, trail.Attachment1

        local o, c0, c1

        if pre then
          r0, r1, o = pre[1], pre[2], pre[5]
        end

        if not pre and not r0 or not r1 or not r0:IsDescendantOf(workspace) or not r1:IsDescendantOf(workspace) then
          if not o then
            o = (workspace.CurrentCamera.CFrame * CFrame.new(0, 0, -10)).Position
          end

          c0 = CFrame.new(-0.5, 0, 0)
          c1 = CFrame.new(0.5, 0, 0)
        else
          local function upd()
            o = r0.WorldPosition - (r0.Position - r1.Position) / 2

            c0 = r0.CFrame
            c1 = r1.CFrame
          end

          upd()

          table.insert(oneshot, r0:GetPropertyChangedSignal("CFrame"):Connect(upd))
          table.insert(oneshot, r1:GetPropertyChangedSignal("CFrame"):Connect(upd))
        end

        if not pre then
          local a0 = emitScope:New "Attachment" {
            Parent = workspace.Terrain,
            CFrame = c0,
          }

          local a1 = emitScope:New "Attachment" {
            Parent = workspace.Terrain,
            CFrame = c1,
          }

          pre = { r0, r1, a0, a1, o }
          attmap[trail] = { r0, r1 }

          trail_att[trail] = pre

          local initEnabled = trail.Enabled

          table.insert(emitScope, function()
            oneshot = nil
            attmap[trail] = nil

            trail.Enabled = initEnabled

            trail.Attachment0 = r0
            trail.Attachment1 = r1
          end)
        end

        local a0, a1 = pre[3], pre[4]

        local elapsed = 0

        local function getRot(alpha: number)
          return CFrame.fromOrientation(0, math.pi * 2 * alpha, 0) * CFrame.new(0, 0, peek(settings.trail_radius))
        end

        table.insert(
          promises,
          Promise.new(function(resolve)
            local conn
            conn = RunService.RenderStepped:Connect(function(deltaTime)
              -- don't overwrite anything after cleaning up
              if not oneshot then
                return
              end

              local duration = peek(settings.trail_lap_duration)

              local alpha = math.clamp(elapsed / duration, 0, 1)

              local cf = CFrame.lookAt((CFrame.new(o) * getRot(alpha)).p, (CFrame.new(o) * getRot(alpha + 1 / 60).p))

              trail.Enabled = true

              trail.Attachment0 = a0
              trail.Attachment1 = a1

              a0.CFrame = cf * c0
              a1.CFrame = cf * c1

              elapsed += deltaTime

              if elapsed > (duration + (peek(looped) and 0 or trail.Lifetime)) then
                conn:Disconnect()
                resolve()
              end
            end)

            table.insert(oneshot, function()
              oneshot = nil

              conn:Disconnect()
              resolve()
            end)
          end)
        )
      end

      -- remove from args when deleted
      for _, arg in args do
        table.insert(
          emitScope,
          arg.AncestryChanged:Connect(function()
            local index = table.find(args, arg)

            if arg:IsDescendantOf(game) then
              if not index then
                table.insert(args, arg)
              end

              return
            end

            if index then
              table.remove(args, index)
            end

            if #args == 0 then
              looped:set(false)
            end
          end)
        )
      end

      local env = vfx.emit(table.unpack(args))

      table.insert(promises, env.Finished)

      local function run()
        if active and peek(looped) then
          emit()
        elseif emitScope then
          emitScope:doCleanup()
          emitScope = nil
        end
      end

      local timer = peek(settings.timer)

      if timer <= 0.01 or not peek(looped) then
        Promise.all(promises):finally(run)
      else
        task.delay(timer, run)
      end
    end

    emit()
  end

  scope:OnKeybind("emit", "Emits currently selected effects", conf.settings.keybinds.emit, clickEmit)

  return scope:New "Frame" {
    AutomaticSize = Enum.AutomaticSize.Y,
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = scope:Computed(function(use)
          return UDim.new(0, use(ui_conf.padding.side))
        end),
      },

      scope:New "Frame" {
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,

        Size = UDim2.fromScale(1, 0),

        Visible = scope:Computed(function(use)
          return #use(attributes) > 0
        end),

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:ForValues(attributes, function(_, scope, info)
            local size = scope:Value(Vector2.zero)

            local function get()
              return utility.collectAttributeFromMany(info[4], info[2], "number", nil, info[3])
            end

            local consume = false
            local consumeTwo = false

            local value = scope:Value(get())

            for _, obj in info[4] do
              table.insert(
                scope,
                obj:GetAttributeChangedSignal(info[2]):Connect(function()
                  if consumeTwo then
                    return
                  end

                  local use = get()

                  if use ~= peek(value) then
                    consume = true
                    value:set(use)
                  end
                end)
              )
            end

            scope:Observer(value):onChange(function()
              if consume then
                consume = false
                return
              end

              consumeTwo = true

              utility.record("set emit attributes", function()
                for _, obj in info[4] do
                  obj:SetAttribute(info[2], peek(value))
                end
              end)

              consumeTwo = false
            end)

            local bounds = scope:Computed(function(use, scope)
              local params = scope:New "GetTextBoundsParams" {
                Text = info[1],
                Font = use(ui_conf.font),
                Size = use(ui_conf.text_sizes.mini),
                Width = 10_000,
              }

              return TextService:GetTextBoundsAsync(params).X + use(ui_conf.padding.prop) * 2
            end)

            local function upd()
              local width = peek(bounds)

              if width > peek(widest) then
                widest:set(width)
              end
            end

            upd()

            scope:Observer(ui_conf.font):onChange(upd)
            scope:Observer(ui_conf.padding.prop):onChange(upd)
            scope:Observer(ui_conf.text_sizes.mini):onChange(upd)

            local cmp = scope:NumberField({
              value = value,

              min = 0,
              max = math.huge,
            })

            return scope:New "Frame" {
              BackgroundTransparency = 1,

              Size = scope:Computed(function(use)
                return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2)
              end),

              [Children] = {
                scope:New "TextLabel" {
                  AutomaticSize = Enum.AutomaticSize.X,

                  Size = scope:Computed(function(use)
                    return UDim2.new(0, use(widest), 1, 0)
                  end),

                  BackgroundColor3 = ui_conf.colors.surface,
                  TextColor3 = ui_conf.colors.text,

                  Text = info[1],
                  TextWrapped = true,

                  FontFace = ui_conf.font,
                  TextSize = ui_conf.text_sizes.mini,

                  TextTruncate = Enum.TextTruncate.SplitWord,
                  TextXAlignment = Enum.TextXAlignment.Left,

                  [Out "AbsoluteSize"] = size,

                  [Children] = {
                    scope:Round(ui_conf.rounding.mini),
                    scope:Padding(ui_conf.padding.prop, 0),
                  },
                },

                scope:New "Frame" {
                  BackgroundColor3 = ui_conf.colors.surface,

                  AnchorPoint = Vector2.new(1, 0),
                  Position = UDim2.fromScale(1, 0),

                  Size = scope:Computed(function(use)
                    return UDim2.new(1, -(use(ui_conf.padding.side) + use(widest)), 1, 0)
                  end),

                  [Children] = {
                    scope:Round(ui_conf.rounding.mini),
                    cmp,
                  },
                },
              },
            }
          end),
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,

        Size = UDim2.fromScale(1, 0),

        [Children] = {
          scope:Hover "TextButton" {
            AutomaticSize = Enum.AutomaticSize.Y,

            Size = scope:Computed(function(use)
              return UDim2.new(
                1,
                -(use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2 + use(ui_conf.padding.side)),
                0,
                0
              )
            end),

            Text = "emit",

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.mini,

            [OnEvent "MouseButton1Click"] = clickEmit,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
              scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
            },
          },

          scope:Hover "ImageButton" {
            BackgroundColor3 = ui_conf.colors.surface,

            AnchorPoint = Vector2.xAxis,
            Position = UDim2.fromScale(1, 0),

            Size = scope:Computed(function(use)
              local size = use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
              return UDim2.fromOffset(size, size)
            end),

            [OnEvent "MouseButton1Click"] = function()
              looped:set(not peek(looped))
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),

              scope:Hover "ImageLabel" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.one * 0.5,
                Position = UDim2.fromScale(0.5, 0.5),

                Size = UDim2.fromOffset(14, 14),

                Image = scope:Switch(looped, "rbxassetid://97601699844948", "rbxassetid://85991599953288"),
                ImageColor3 = ui_conf.colors.text,
              },
            },
          },
        },
      },
    },
  }
end

return Emit
]]></ProtectedString>
