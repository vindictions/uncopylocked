		<Item class="ModuleScript" referent="RBX378AB76FF939449DB7822DA82AFEB7E7">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.pkg.Fusion)

local Contextual = Fusion.Contextual

local storage = require("./lib/storage")
local ui_conf = require("./cmp/ui_conf")

local conf = {}

conf.input_locked = false

conf.default_curve = {
  Path2DControlPoint.new(UDim2.fromScale(0, 1), UDim2.new(), UDim2.fromScale(0.25, -0.25)),
  Path2DControlPoint.new(UDim2.fromScale(1, 0), UDim2.fromScale(-0.25, 0.25), UDim2.new()),
}

conf.settings = {}
conf.class_map = {}

conf.ctx = Contextual(nil :: {
  focus_stack: Fusion.Value<{ Fusion.Value<boolean> }>,

  current_priority: Fusion.Value<number>,

  global_enabled: Fusion.UsedAs<boolean>,
  current_focused: Fusion.Value<boolean>?,
  current_holding: Fusion.Value<boolean>?,

  focused_before_priority: Fusion.Value<boolean>?,

  viewport_toolbar: Frame,
}?)

function conf.setup(scope: Fusion.Scope)
  conf.settings = storage.new(scope, "settings", {
    notifs = {
      check_for_updates = scope:Value(true),
    },

    flipbooks = {
      default_fps = scope:Value(60),
    },

    path_preview = {
      workers = scope:Value(24),
      points = scope:Value(200),
      sample_rate = scope:Value(32),
      transparency = scope:Value(0.75),
    },

    emission = {
      timer = scope:Value(0),
      trail_radius = scope:Value(5),
      trail_lap_duration = scope:Value(2),
    },

    keybinds = {
      toggle_ui = scope:Value({ "LeftControl", "Backquote" }),
      toggle_adder = scope:Value({ "Backquote" }),

      emit = scope:Value({ "R" }),

      toggle_enabled = scope:Value({ "LeftShift", "R" }),
      toggle_paths = scope:Value({ "LeftControl", "Q" }),
    },

    code = {
      import_services = scope:Value(true),
      import_workspace = scope:Value(false),
      services_full_name = scope:Value(true),
    },

    ui = {
      scale = scope:Value(1),

      font = scope:Value(16658221428),

      display_order = scope:Value(1000),

      buttons_horizontal = scope:Value("Right"),
      buttons_vertical = scope:Value("Bottom"),

      buttons_direction = scope:Value("Horizontal"),

      text_sizes = {
        nano = scope:Value(15),
        mini = scope:Value(16),
        base = scope:Value(18),

        title_bar = scope:Value(18),
        title = scope:Value(20),

        special = scope:Value(24),
      },

      rounding = {
        base = scope:Value(8),
        mini = scope:Value(6),
        nano = scope:Value(4),
      },

      padding = {
        resize = scope:Value(4),

        base = scope:Value(4),
        prop = scope:Value(6),
        side = scope:Value(8),
      },
    },
  })

  for k, v in conf.settings.ui do
    if k == "font" then
      local id = v

      v = scope:Computed(function(use)
        return Font.fromId(use(id))
      end)
    end

    ui_conf[k] = v
  end
end

return conf
]]></ProtectedString>
