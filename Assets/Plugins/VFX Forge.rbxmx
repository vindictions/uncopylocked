			<Item class="ModuleScript" referent="RBXBB3D8D11FF4D449D9437B9805BB63C88">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local logger = require("../lib/logger")

export type colors<T> = {
  base: T,
  surface: T,
  overlay: T,

  muted: T,
  subtle: T,

  text: T,

  highlight: T,

  -- code
  code_string: T,

  code_builtin: T,
  code_keyword: T,

  code_operator: T,

  code_key: T,
  code_method: T,

  -- accents
  primary: T,
}

export type values = colors<Fusion.Value<Color3>>

type theme = {
  _env: {},
  _scope: Fusion.Scope,

  current: string,
  variant: string,

  builtin: { [string]: colors<string> },

  setup: (scope: Fusion.Scope, env: {}) -> (),
  set: (colors: string | { colors: colors<string> }, variant: string?, create: boolean?) -> (),
}

local theme = {} :: theme

theme.builtin = {
  ["Catpuccin"] = {
    ["Mocha"] = {
      hover_scale = 1,

      colors = {
        base = "#181825",
        surface = "#1e1e2e",
        overlay = "#45475a",

        muted = "#585b70",
        subtle = "#6c7086",

        text = "#cdd6f4",

        highlight = "#7f849c",

        -- code
        code_string = "#a6e3a1",

        code_builtin = "#f38ba8",
        code_keyword = "#cba6f7",

        code_operator = "#89dceb",

        code_key = "#f9e2af",
        code_method = "#89b4fa",

        -- accents
        primary = "#f38ba8",
      },
    },
  },

  ["Rosé Pine"] = {
    ["Moon"] = {
      hover_scale = 1,

      colors = {
        base = "#232136",
        surface = "#2a273f",
        overlay = "#393552",

        muted = "#6e6a86",
        subtle = "#908caa",

        text = "#e0def4",

        highlight = "#44415a",

        -- code
        code_string = "#f6c177",

        code_builtin = "#ea9a97",
        code_keyword = "#eb6f92",

        code_operator = "#908caa",

        code_key = "#9ccfd8",
        code_method = "#c4a7e7",

        -- accents
        primary = "#c4a7e7",
      },
    },

    ["Dawn"] = {
      hover_scale = 0.95 / 1.05,

      colors = {
        base = "#faf4ed",
        surface = "#fffaf3",
        overlay = "#f2e9e1",

        muted = "#9893a5",
        subtle = "#797593",

        text = "#575279",

        highlight = "#dfdad9",

        -- code
        code_string = "#ea9d34",

        code_builtin = "#d7827e",
        code_keyword = "#b4637a",

        code_operator = "#797593",

        code_key = "#56949f",
        code_method = "#907aa9",

        -- accents
        primary = "#907aa9",
      },
    },
  },

  ["Retro"] = {
    ["Default"] = {

      colors = {
        base = "#1b0f19",
        surface = "#2d2031",
        overlay = "#382c3c",

        text = "#fff2d5",

        muted = "#69576e",
        subtle = "#543c5c",

        highlight = "#433846",

        code_string = "#f6c177",

        code_builtin = "#ea9a97",
        code_keyword = "#eb6f92",

        code_operator = "#908caa",

        code_key = "#9ccfd8",
        code_method = "#c4a7e7",

        -- accents
        primary = "#fca59b",
      },
    },
  },
}

theme.current = "Rosé Pine"
theme.variant = "Moon"

function theme.setup(scope, env)
  local colors = {}

  theme._scope = scope
  theme._env = env

  env.colors = colors
  env.hover_scale = scope:Value(1)

  theme.set(theme.current, theme.variant, true)
end

local function set(key: string, source: {})
  local val = source[key]

  if val ~= nil and theme._env[key] then
    theme._env[key]:set(val)
  end
end

function theme.set(colors, variant, create)
  if not theme._env then
    logger.error("attempt to set a theme before setup")
  end

  local t = typeof(colors) == "table" and colors or theme.builtin[colors]

  if variant then
    t = t[variant]
  end

  if not t or not t.colors then
    logger.error(`unknown theme {colors} with variant {variant}`)
  end

  set("hover_scale", t)

  local map = theme._env.colors

  for k, v in t.colors do
    local c = map[k]

    if c then
      map[k] = c:set(v)
    elseif create then
      map[k] = theme._scope:Value(Color3.fromHex(v))
    else
      logger.warn(`theme has an unknown color '{k}'`)
    end
  end
end

return theme
]]></ProtectedString>
					<string name="ScriptGuid">{FBB3B77E-8A7D-4B0E-86F5-463976F63F5D}</string>
