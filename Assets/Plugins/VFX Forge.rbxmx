							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")
local symbols = require("../../../.symbols")

type props = {
  value: Fusion.Value<number>,

  int: boolean?,
  center: boolean?,
  readonly: Fusion.UsedAs<boolean>?,

  min: number?,
  max: number?,
}

local function NumberInput(scope: ui_types.scope, props: props)
  local unmodifiedInput = ""

  local inputBox: Fusion.Value<TextBox?> = scope:Value(nil)

  local function updateText(x: number)
    if props.int then
      return tostring(math.round(x))
    else
      return string.format("%.3f", x):gsub("0*$", ""):gsub("%.$", "")
    end
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    AnchorPoint = Vector2.new(0.5, 0),
    Position = UDim2.fromScale(0.5, 0),

    Size = scope:Computed(function(use)
      return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
    end),

    ClipsDescendants = true,

    [Children] = {
      inputBox:set(scope:New "TextBox" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        FontFace = ui_conf.font,

        Text = scope:Computed(function(use)
          local x = use(props.value)

          if x == symbols.nil_symbol then
            return "-"
          end

          return updateText(x)
        end),

        TextColor3 = scope:Computed(function(use)
          return use(props.readonly) and use(ui_conf.colors.muted) or use(ui_conf.colors.text)
        end),

        TextSize = ui_conf.text_sizes.mini,

        TextXAlignment = props.center and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left,

        TextEditable = scope:Computed(function(use)
          return not use(props.readonly)
        end),

        [OnEvent "Focused"] = function()
          local input = peek(inputBox)

          if input then
            unmodifiedInput = input.Text

            input.CursorPosition = #input.Text + 1
            input.SelectionStart = 0
          end
        end,

        [OnEvent "FocusLost"] = function()
          local input = peek(inputBox)
          local inputValue = tonumber(input.Text)

          if inputValue then
            props.value:set(math.clamp(inputValue, props.min or -math.huge, props.max or math.huge), true)
          else
            input.Text = unmodifiedInput
          end
        end,

        [Children] = {
          scope:Padding(1, 0, 0, 0),
        },
      } :: TextBox),
    },
  },
    function(x: number)
      local input = peek(inputBox)
      input.Text = updateText(x)
    end
end

return NumberInput
]]></ProtectedString>
