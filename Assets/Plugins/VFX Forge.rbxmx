				<Item class="ModuleScript" referent="RBXC8121FFFE804469985530B507D349569">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local CoreGui = game:GetService("CoreGui")
local Terrain = workspace:WaitForChild("Terrain")
local Selection = game:GetService("Selection")
local RunService = game:GetService("RunService")

local Gizmo = require(script.Parent.Parent.Parent.pkg.Gizmo)
local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local plugin = script:FindFirstAncestorOfClass("Plugin")

local OnEvent = Fusion.OnEvent
local peek = Fusion.peek

local conf = require("../../.conf")
local ui_conf = require("../../cmp/ui_conf")
local ui_types = require("../../cmp/ui_types")

local emit_utility = require("../../lib/emit/mod/utility")

local Bezier = require("../../lib/emit/obj/Bezier")

local OVERWORKED = 0
local POINTS_PER_WORKER = 0

local RERENDER_PROPERTIES = {
  Emitter = {
    "EmissionDirection",
    "Lifetime",
    "Speed",
    "SpreadAngle",

    "Shape",
    "ShapeInOut",
    "ShapePartial",
    "ShapeStyle",

    "Drag",
    "Acceleration",

    "LockedToPart",
  },

  Part = {
    "Size",
    "CFrame",
  },

  Attachment = {
    "CFrame",
  },
}

local BEZIER_RERENDER = {
  Attributes = {
    "ShapePartial",
    "Shape",
    "ShapeStyle",
    "EmissionDirection",
    "ShapeFace",
    "SpreadAngle",
    "MirrorPaths",
    "MirrorRotation",
  },

  Part = {
    "Size",
    "CFrame",
  },

  Attachment = {
    "CFrame",
  },
}

local DEBRIS_RERENDER = {
  Attributes = {
    "LinearMagnitude",
    "AngularMagnitude",
    "MinDirection",
    "MaxDirection",
    "Airtime",
  },

  Part = {
    "AssemblyLinearVelocity",
  },

  Origin = {
    "CFrame",
  },
}

local rng = Random.new()

local function sphereVolume(scope: ui_types.scope)
  return scope:New "SphereHandleAdornment" {
    Parent = CoreGui,
    Adornee = workspace.Terrain,

    AlwaysOnTop = true,

    Radius = 0.15,
    Color3 = ui_conf.colors.primary,

    ZIndex = 1,
  }
end

local function getDrawShape(scope: ui_types.scope)
  local spherePartialVolume

  local function cleanupPersistent()
    if not spherePartialVolume then
      return
    end

    for _, obj in spherePartialVolume do
      obj:Destroy()
    end

    spherePartialVolume = nil
  end

  table.insert(scope, cleanupPersistent)

  return function(parent: Instance?, direction: Enum.NormalId, shape: string, partial: number)
    if spherePartialVolume and shape ~= "Sphere" then
      cleanupPersistent()
    end

    local part = if parent and parent:IsA("BasePart") then parent else nil

    if not part then
      return
    end

    debug.profilebegin("vfxGizmoFrame")

    Gizmo.PushProperty("AlwaysOnTop", true)
    Gizmo.PushProperty("Transparency", 0)
    Gizmo.PushProperty("Color3", peek(ui_conf.colors.primary))

    if shape == "Box" then
      Gizmo.Box:Draw(part.CFrame, part.Size, false)
    elseif shape == "Cylinder" then
      Gizmo.Cylinder:Draw(part.CFrame, part.Size, partial, direction, 24)
    elseif shape == "Sphere" then
      Gizmo.Sphere:Draw(part.CFrame, part.Size, 24, 360)

      local cf = part.CFrame
      local pos = part.Position
      local radius = part.Size / 2

      local alpha = math.pi / 2 + partial * math.pi
      local cos = math.cos(alpha)
      local sin = math.sin(alpha)

      local n = Vector3.FromNormalId(direction)

      local u = n:Cross(Vector3.yAxis)

      if u.Magnitude < 0.001 then
        u = n:Cross(Vector3.xAxis)
      end

      local v = n:Cross(u)

      local function projectRadius(vec)
        return math.abs(vec.X) * radius.X + math.abs(vec.Y) * radius.Y + math.abs(vec.Z) * radius.Z
      end

      local rAxis = projectRadius(n)

      local rU = projectRadius(u)
      local rV = projectRadius(v)

      local p1 = (u * (cos * rU)) + (n * (sin * rAxis))
      local p2 = (u * (-cos * rU)) + (n * (sin * rAxis))
      local p3 = (v * (-cos * rV)) + (n * (sin * rAxis))
      local p4 = (v * (cos * rV)) + (n * (sin * rAxis))

      if not spherePartialVolume then
        spherePartialVolume = {
          sphereVolume(scope),
          sphereVolume(scope),
          sphereVolume(scope),
          sphereVolume(scope),
          sphereVolume(scope),
        }
      end

      local vol = spherePartialVolume

      vol[1].CFrame = cf
      vol[2].CFrame = cf * CFrame.new(p1)
      vol[3].CFrame = cf * CFrame.new(p2)
      vol[4].CFrame = cf * CFrame.new(p3)
      vol[5].CFrame = cf * CFrame.new(p4)

      Gizmo.Ray:Draw(pos, cf * p1)
      Gizmo.Ray:Draw(pos, cf * p2)
      Gizmo.Ray:Draw(pos, cf * p3)
      Gizmo.Ray:Draw(pos, cf * p4)
    elseif shape == "Disc" then
      Gizmo.Disc:Draw(part.CFrame, part.Size, partial, direction, 24)
    end

    debug.profileend()
  end
end

local workers = {}
local visualizer = {}

function visualizer.init(scope: Fusion.Scope)
  local settings = conf.settings.path_preview

  OVERWORKED = scope:Computed(function(use)
    return use(settings.points) % use(settings.workers)
  end)

  POINTS_PER_WORKER = scope:Computed(function(use)
    return use(settings.points) // use(settings.workers)
  end)

  workers = scope:Computed(function(use, scope)
    local w = {}

    for i = 1, use(settings.workers) do
      local worker = script.Parent.worker:Clone()
      worker.Parent = script.Parent

      worker.job.Disabled = false

      table.insert(w, worker)
      table.insert(scope, worker)
    end

    return w
  end)

  visualizer.scope = scope

  Gizmo.Init()
  table.insert(scope, Gizmo.DoCleaning)
end

function visualizer.draw(scope: ui_types.scope, emitter: ParticleEmitter)
  local settings = conf.settings.path_preview

  local handle = scope:New "WireframeHandleAdornment" {
    Adornee = Terrain,

    AlwaysOnTop = true,
    Color3 = Color3.new(1, 1, 1),

    Transparency = settings.transparency,

    Parent = CoreGui,
  } :: WireframeHandleAdornment

  local drawShape = getDrawShape(scope)

  table.insert(
    scope,
    RunService.RenderStepped:Connect(function()
      drawShape(emitter.Parent, emitter.EmissionDirection, emitter.Shape.Name, emitter.ShapePartial)
    end)
  )

  local renderScope = scope:innerScope()

  local function render()
    handle:Clear()

    renderScope:doCleanup()
    renderScope = scope:innerScope()

    local parent = emitter.Parent
    local origin = if parent and (parent:IsA("BasePart") or parent:IsA("Attachment")) then parent else nil

    local last = 1

    local function chunk(from: number, to: number, worker: Actor)
      task.spawn(function()
        if not worker:GetAttribute("loaded") then
          worker:GetAttributeChangedSignal("loaded"):Wait()
        end

        worker:SendMessage("drawChunk", emitter, handle, from, to, peek(settings.sample_rate))
      end)
    end

    if origin then
      if origin:IsA("BasePart") then
        for _, prop in RERENDER_PROPERTIES.Part do
          table.insert(renderScope, origin:GetPropertyChangedSignal(prop):Connect(render))
        end
      else
        for _, prop in RERENDER_PROPERTIES.Attachment do
          table.insert(renderScope, origin:GetPropertyChangedSignal(prop):Connect(render))
        end
      end

      local w = peek(workers)

      if origin:IsA("BasePart") or emitter.SpreadAngle ~= Vector2.zero then
        for i, worker in w do
          local pts = peek(settings.points)

          if last >= pts then
            if pts == 1 then
              chunk(1, 1, w[rng:NextInteger(1, #w)])
            end

            break
          end

          local to = pts == 1 and 1
            or last + if i <= peek(OVERWORKED) then peek(POINTS_PER_WORKER) + 1 else peek(POINTS_PER_WORKER)

          chunk(last, to, worker)

          last = to
        end
      else
        chunk(1, 1, w[rng:NextInteger(1, #w)])
      end
    end
  end

  scope:Observer(workers):onChange(render)

  scope:Observer(settings.points):onChange(render)
  scope:Observer(settings.sample_rate):onChange(render)
  scope:Observer(settings.transparency):onChange(render)

  for _, prop in RERENDER_PROPERTIES.Emitter do
    table.insert(scope, emitter:GetPropertyChangedSignal(prop):Connect(render))
  end

  table.insert(scope, emitter.AncestryChanged:Connect(render))

  render()
end

local function bezierPreliminary(scope: ui_types.scope, root: Attachment, metadata: boolean?)
  local points, attachments, attachmentToPointMap = emit_utility.getBezierPoints(root, metadata)

  table.insert(
    scope,
    root.DescendantAdded:Connect(function(desc)
      if not desc:IsA("Attachment") then
        return
      end

      if attachmentToPointMap[desc.Parent] and desc.Name == "T0" and not desc.Parent:FindFirstChild("T1") then
        desc.Name = "T1"
      elseif attachmentToPointMap[desc.Parent] and desc.Name == "T1" and not desc.Parent:FindFirstChild("T0") then
        desc.Name = "T0"
      elseif desc.Parent == root then
        desc.Name = tostring(#root:GetChildren())
      end
    end)
  )

  return points, attachments, attachmentToPointMap
end

function visualizer.draw_debris(scope: ui_types.scope, ref: Part)
  local origin = emit_utility.findFirstClassWithTag(ref, "Attachment", emit_utility.SHOCKWAVE_TAG)

  if not origin then
    return
  end

  local settings = conf.settings.path_preview

  local handle = scope:New "WireframeHandleAdornment" {
    Adornee = Terrain,

    AlwaysOnTop = true,
    Color3 = Color3.new(1, 1, 1),

    Transparency = settings.transparency,

    Parent = CoreGui,
  } :: WireframeHandleAdornment

  table.insert(
    scope,
    RunService.RenderStepped:Connect(function()
      Gizmo.PushProperty("AlwaysOnTop", true)
      Gizmo.PushProperty("Transparency", 0)
      Gizmo.PushProperty("Color3", peek(ui_conf.colors.primary))

      Gizmo.Sphere:Draw(
        origin.CFrame,
        vector.one * 2 * emit_utility.getAttribute(ref, "InheritanceRadius", 5, true),
        24,
        360
      )
    end)
  )

  local function render()
    handle:Clear()

    local last = 1

    local function chunk(from: number, to: number, worker: Actor)
      task.spawn(function()
        if not worker:GetAttribute("loaded") then
          worker:GetAttributeChangedSignal("loaded"):Wait()
        end

        worker:SendMessage("drawDebrisChunk", origin, ref, handle, from, to, peek(settings.sample_rate))
      end)
    end

    local w = peek(workers)

    for i, worker in w do
      local pts = peek(settings.points)

      if last >= pts then
        if pts == 1 then
          chunk(1, 1, w[rng:NextInteger(1, #w)])
        end

        break
      end

      local to = pts == 1 and 1
        or last + if i <= peek(OVERWORKED) then peek(POINTS_PER_WORKER) + 1 else peek(POINTS_PER_WORKER)

      chunk(last, to, worker)

      last = to
    end
  end

  scope:Observer(workers):onChange(render)

  scope:Observer(settings.points):onChange(render)
  scope:Observer(settings.sample_rate):onChange(render)
  scope:Observer(settings.transparency):onChange(render)

  for _, attr in DEBRIS_RERENDER.Attributes do
    table.insert(scope, ref:GetAttributeChangedSignal(attr):Connect(render))
  end

  for _, prop in DEBRIS_RERENDER.Origin do
    table.insert(scope, origin:GetPropertyChangedSignal(prop):Connect(render))
  end

  for _, prop in DEBRIS_RERENDER.Part do
    table.insert(scope, ref:GetPropertyChangedSignal(prop):Connect(render))
  end

  render()
end

function visualizer.draw_bezier(scope: ui_types.scope, effect: Attachment)
  local root = effect:FindFirstChild("Points")

  if not root then
    return
  end

  local settings = conf.settings.path_preview

  local handle = scope:New "WireframeHandleAdornment" {
    Adornee = Terrain,

    AlwaysOnTop = true,
    Color3 = Color3.new(1, 1, 1),

    Transparency = settings.transparency,

    Parent = CoreGui,
  } :: WireframeHandleAdornment

  local points = bezierPreliminary(scope, root)

  local drawShape = getDrawShape(scope)

  local function getAttributes()
    local partial = emit_utility.getAttribute(effect, "ShapePartial", 1, true)

    local shape = emit_utility.getEnumAttribute(effect, "Shape", "Box", { "Box", "Cylinder", "Sphere", "Disc" }, true)
    local style = emit_utility.getEnumAttribute(effect, "ShapeStyle", "Volume", { "Volume", "Surface" }, true)

    local emission_direction = emit_utility.getEnumAttribute(
      effect,
      "EmissionDirection",
      "Top",
      { "Top", "Bottom", "Left", "Right", "Front", "Back" },
      true
    )

    local face =
      emit_utility.getEnumAttribute(effect, "ShapeFace", "Outward", { "InAndOut", "Inward", "Outward" }, true)
    local spreadAngle = emit_utility.getAttribute(effect, "SpreadAngle", vector.zero, true)

    local mirror = emit_utility.getAttribute(effect, "MirrorPaths", true, true)
    local mirrorRot = emit_utility.getAttribute(effect, "MirrorRotation", vector.create(0, 0, 180), true)

    return shape, partial, Enum.NormalId[emission_direction], style, face, spreadAngle, mirror, mirrorRot
  end

  table.insert(
    scope,
    RunService.RenderStepped:Connect(function()
      local shape, partial, emission_direction = getAttributes()
      drawShape(effect.Parent, emission_direction, shape, partial)
    end)
  )

  local renderScope = scope:innerScope()

  local function render()
    handle:Clear()

    renderScope:doCleanup()
    renderScope = scope:innerScope()

    local last = 1
    local shape, partial, emission_direction, style, face, spreadAngle, mirror, mirrorRot = getAttributes()

    local function chunk(from: number, to: number, worker: Actor)
      task.spawn(function()
        if not worker:GetAttribute("loaded") then
          worker:GetAttributeChangedSignal("loaded"):Wait()
        end

        worker:SendMessage(
          "drawBezierChunk",
          effect,
          shape,
          style,
          partial,
          emission_direction,
          face,
          spreadAngle,
          mirror,
          mirrorRot,
          points,
          handle,
          from,
          to
        )
      end)
    end

    local endPoint = effect:FindFirstChild("End")
    local endT1 = endPoint and endPoint:FindFirstChild("T1")

    if endPoint and not endPoint:IsA("Attachment") then
      endPoint = nil
    end

    if endT1 and not endT1:IsA("Attachment") then
      endT1 = nil
    end

    if endPoint then
      table.insert(renderScope, endPoint:GetPropertyChangedSignal("CFrame"):Connect(render))
    end

    if endT1 then
      table.insert(renderScope, endT1:GetPropertyChangedSignal("CFrame"):Connect(render))
    end

    local parent = effect.Parent

    if parent then
      local w = peek(workers)

      if parent:IsA("BasePart") then
        for _, prop in BEZIER_RERENDER.Part do
          table.insert(renderScope, parent:GetPropertyChangedSignal(prop):Connect(render))
        end
      else
        for _, prop in BEZIER_RERENDER.Attachment do
          table.insert(renderScope, effect:GetPropertyChangedSignal(prop):Connect(render))
        end

        chunk(1, 1, w[rng:NextInteger(1, #w)])
      end

      if parent:IsA("BasePart") or spreadAngle ~= vector.zero then
        for i, worker in w do
          local pts = peek(settings.points)

          if last >= pts then
            if pts == 1 then
              chunk(1, 1, w[rng:NextInteger(1, #w)])
            end

            break
          end

          local to = pts == 1 and 1
            or last + if i <= peek(OVERWORKED) then peek(POINTS_PER_WORKER) + 1 else peek(POINTS_PER_WORKER)

          chunk(last, to, worker)

          last = to
        end
      end
    end
  end

  scope:Observer(workers):onChange(render)

  scope:Observer(settings.points):onChange(render)
  scope:Observer(settings.transparency):onChange(render)

  for _, attr in BEZIER_RERENDER.Attributes do
    table.insert(scope, effect:GetAttributeChangedSignal(attr):Connect(render))
  end

  table.insert(scope, effect.AncestryChanged:Connect(render))

  render()
end

function visualizer.draw_bezier_preview(scope: ui_types.scope, effect: Part)
  local root = effect:FindFirstChild("Points")

  if not root then
    return
  end

  local handle = scope:New "WireframeHandleAdornment" {
    Adornee = Terrain,

    AlwaysOnTop = true,
    Color3 = Color3.new(1, 1, 1),

    Thickness = 10,

    Parent = CoreGui,
  } :: WireframeHandleAdornment

  local points, attachments, attachmentToPointMap = bezierPreliminary(scope, root, true)
  local bezier = Bezier.new(points, 100)

  local function render()
    handle:Clear()

    local lines = {}
    local prev = nil

    bezier:forSample(0.5, function(pos, i)
      pos = root.WorldCFrame * pos

      if prev then
        table.insert(lines, prev)
      end

      if i ~= 0 then
        prev = pos
      end

      table.insert(lines, pos)
    end)

    handle:AddLines(lines)
  end

  render()

  local spherePartialVolume

  local function cleanupPersistent()
    if not spherePartialVolume then
      return
    end

    for _, obj in spherePartialVolume do
      obj:Destroy()
    end

    spherePartialVolume = nil
  end

  table.insert(scope, cleanupPersistent)
  table.insert(
    scope,
    RunService.RenderStepped:Connect(function()
      if not spherePartialVolume then
        spherePartialVolume = {}

        for i, p in points do
          local attachment = attachments[i]
          local isControl = tonumber(attachment.Name)

          local hovered = scope:Value(false)

          table.insert(
            spherePartialVolume,
            scope:New "SphereHandleAdornment" {
              Parent = CoreGui,
              Adornee = workspace.Terrain,

              AlwaysOnTop = true,

              Radius = isControl and 0.5 or 0.25,

              Color3 = scope:Spring(
                scope:Computed(function(use, scope)
                  local normal = use(ui_conf.colors.primary)
                  local scaled = use(scope:ScaleColor(
                    scope:Computed(function(use)
                      return 1.15 * use(ui_conf.hover_scale)
                    end),
                    ui_conf.colors.primary
                  ))

                  return use(hovered) and scaled or normal
                end),
                30,
                1
              ),

              ZIndex = 1,

              [OnEvent "MouseEnter"] = function()
                hovered:set(true)
              end,

              [OnEvent "MouseLeave"] = function()
                hovered:set(false)
              end,

              [OnEvent "MouseButton1Down"] = function()
                task.defer(function()
                  Selection:Set({ attachment })

                  if plugin:GetSelectedRibbonTool() ~= Enum.RibbonTool.Move then
                    plugin:SelectRibbonTool(Enum.RibbonTool.Move, UDim2.new())
                  end
                end)
              end,
            }
          )
        end
      end

      local v = spherePartialVolume

      local prev = nil

      Gizmo.PushProperty("AlwaysOnTop", true)
      Gizmo.PushProperty("Transparency", 0.75)
      Gizmo.PushProperty("Color3", Color3.new(1, 1, 1))

      for i, p in points do
        local a = attachments[i]

        if not a then
          continue
        end

        v[i].CFrame = a.WorldCFrame
        p = root.WorldCFrame * p

        if prev then
          Gizmo.Ray:Draw(prev, p)
        end

        prev = p
      end
    end)
  )

  local function onAttachmentChange(i: number, a: Attachment)
    do
      local pos = root.WorldCFrame:PointToObjectSpace(a.WorldPosition)
      local vec = vector.create(pos.X, pos.Y, pos.Z)

      points[i] = vec
      attachments[i] = a

      attachmentToPointMap[a] = vec
    end

    for _, child in a:GetChildren() do
      local pos = root.WorldCFrame:PointToObjectSpace(child.WorldPosition)
      local vec = vector.create(pos.X, pos.Y, pos.Z)

      local p = attachmentToPointMap[child]
      local j = p and table.find(points, p)

      if not j then
        continue
      end

      points[j] = vec
      attachments[j] = child

      attachmentToPointMap[child] = vec
    end
  end

  for i in points do
    local a = attachments[i]

    table.insert(
      scope,
      a:GetPropertyChangedSignal("CFrame"):Connect(function()
        onAttachmentChange(i, a)
        bezier:setPoints(points)

        render()
      end)
    )
  end

  table.insert(
    scope,
    effect:GetPropertyChangedSignal("CFrame"):Connect(function()
      for i in points do
        local a = attachments[i]

        onAttachmentChange(i, a)
      end

      bezier:setPoints(points)
      render()
    end)
  )

  local function animateTest(arc: boolean?)
    local p = scope:New "Part" {
      Material = "Neon",
      -- red for non arc, blue for arc
      Color = Color3.new(arc and 0 or 1, 0, arc and 1 or 0),

      Size = Vector3.one * 0.5,
      Parent = workspace.Terrain,
      Archivable = false,
    }

    if not arc then
      local c = effect:Clone()

      for _, child in c:GetChildren() do
        if child.Name == "Points" then
          continue
        end

        if child:IsA("ParticleEmitter") then
          child.Enabled = true
        end

        child.Archivable = false
        child.Parent = p
      end

      c:Destroy()
    end

    local elapsed = 0
    local dir = 1

    table.insert(
      scope,
      RunService.RenderStepped:Connect(function(deltaTime)
        local t = elapsed / 5

        p.Position = root.WorldCFrame * (arc and bezier:getPositionArcSpace(t) or bezier:getPosition(t))

        elapsed += deltaTime * dir

        if t >= 1 then
          dir = -1
        elseif t <= 0 then
          dir = 1
        end
      end)
    )
  end

  animateTest()
  animateTest(true)
end

return visualizer
]]></ProtectedString>
