			</Item>
			<Item class="ModuleScript" referent="RBX67DAC89FBA5945CF84D0C874DAF78F84">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local conf = require("../.conf")
local logger = require("../lib/logger")
local ui_conf = require("./ui_conf")
local storage = require("../lib/storage")

type props = {
  id: string?,

  title: Fusion.UsedAs<string>,
  no_title: boolean?,

  global_enabled: Fusion.UsedAs<boolean>?,

  anchor: Fusion.UsedAs<Vector2>?,
  direct_anchor: Fusion.UsedAs<Vector2>?,

  size: Vector2,
  position: Vector2,
  resize_axes: Vector2?,

  focused: boolean?,
  focus_priority: number?,

  disable_resize: boolean?,
  disable_anchor: boolean?,

  close_cleanup: boolean?,

  automatic_width: boolean?,
  automatic_height: boolean?,

  back_active: Fusion.UsedAs<boolean>?,
  back_callback: () -> (),

  button_icon: string?,

  visible: Fusion.Value<boolean>?,
  init_visible: boolean?,

  display_order: Fusion.UsedAs<number>?,

  child: GuiObject,
}

type resize_props = {
  win: props,

  store: storage.storage<{
    position: { number },
    size: { number },
  }>?,

  sides: { Vector2 },

  use_pos: Fusion.Computed<UDim2>,

  save_pos: () -> (),
  set_focus: () -> (),

  size: Fusion.Value<UDim2>,
  position: Fusion.Value<UDim2>,
  window_size: Fusion.Value<Vector2>,
}

local anchorPoints = {
  Vector2.new(0, 0),
  Vector2.new(0.5, 0),
  Vector2.new(1, 0),
  Vector2.new(0, 0.5),
  Vector2.new(0.5, 0.5),
  Vector2.new(1, 0.5),
  Vector2.new(0, 1),
  Vector2.new(0.5, 1),
  Vector2.new(1, 1),
}

local function ResizeHandles(scope: Fusion.Scope, props: resize_props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error(
      `cannot create resize handles for window with id '{props.win.id}' without the ctx contextual set for current thread`
    )
  end

  local resizeSides = {}
  local resizeHov = {}

  local resizeOwner

  return scope:ForValues(props.sides, function(_, scope, side)
    if props.win.resize_axes and side:Abs() ~= props.win.resize_axes then
      return
    end

    local holding = scope:Value(false)
    local hovered = scope:Value(false)

    local initPos = Vector2.zero
    local initMouse = Vector2.zero

    local initSize = UDim2.new()

    scope:Observer(holding):onChange(function()
      local value = peek(holding)

      if value then
        if not resizeOwner then
          table.insert(resizeSides, side)

          resizeOwner = holding

          initPos = peek(props.position)
          initSize = peek(props.size)

          initMouse = UserInputService:GetMouseLocation()

          ctx.ignore_focus = true
        end

        table.insert(resizeHov, holding)
      elseif holding == resizeOwner then
        local s = props.win.child.AbsoluteSize / peek(ui_conf.scale)

        props.size:set(UDim2.fromOffset(s.x, s.y))

        if props.store and not peek(holding) then
          props.store.size = { s.X, s.Y }
        end

        props.save_pos()

        for _, v in resizeHov do
          v:set(false)
        end

        table.clear(resizeHov)
        table.clear(resizeSides)

        resizeOwner = nil

        ctx.ignore_focus = false
      end
    end)

    local handlePos = scope:Computed(function(use)
      local pad = use(ui_conf.padding.resize)
      local round = use(ui_conf.rounding.base)

      local pos = -(Vector2.one - side:Abs()) * pad * 2
        + use(props.window_size) / use(ui_conf.scale) * side:Max(Vector2.zero)
        + side:Min(Vector2.zero) * pad * 2
        - side:Max(Vector2.zero) * round

      return UDim2.fromOffset(pos.X, pos.Y)
    end)

    return scope:New "CanvasGroup" {
      BackgroundTransparency = 1,

      Position = scope:Computed(function(use)
        return use(props.use_pos) + use(handlePos)
      end),

      Size = scope:Computed(function(use)
        local pad = use(ui_conf.padding.resize)
        local round = use(ui_conf.rounding.base)

        local axes = side:Abs()
        local size = (Vector2.one - axes) * (use(props.window_size) / use(ui_conf.scale) + Vector2.one * pad * 4)
          + axes * pad * 2
          + axes * round

        return UDim2.fromOffset(size.X, size.Y)
      end),

      [Children] = {
        scope:New "Frame" {
          BackgroundTransparency = 1,

          Position = scope:Computed(function(use)
            local round = use(ui_conf.rounding.base)
            local pos = side:Max(Vector2.zero) * round

            return UDim2.fromOffset(pos.X, pos.Y)
          end),

          Size = scope:Computed(function(use)
            local round = use(ui_conf.rounding.base)

            local axes = side:Abs()
            local offset = -axes * round

            return UDim2.new(1, offset.X, 1, offset.Y)
          end),

          [OnEvent "MouseEnter"] = function()
            if ctx.ignore_focus then
              return
            end

            props.set_focus()
            hovered:set(true)
          end,

          [OnEvent "MouseLeave"] = function()
            if resizeOwner then
              return
            end

            hovered:set(false)
          end,
        },

        scope:New "Frame" {
          BackgroundTransparency = 1,

          Position = scope:Computed(function(use)
            return -use(handlePos)
          end),

          Size = scope:Computed(function(use)
            local size = use(props.window_size) / use(ui_conf.scale)
            return UDim2.fromOffset(size.X, size.Y)
          end),

          [Children] = {
            scope:Round(ui_conf.rounding.base),

            scope:New "UIStroke" {
              Color = ui_conf.colors.primary,

              Thickness = scope:Spring(
                scope:Computed(function(use)
                  return use(hovered) and use(ui_conf.padding.base) or 0
                end),
                30,
                1
              ),
            },
          },
        },

        scope:OnHold(holding, function(mousePos)
          if holding ~= resizeOwner and #resizeSides ~= 0 then
            table.insert(resizeSides, side)
            return true -- exit
          end

          local mix = Vector2.zero

          for _, side in resizeSides do
            mix += side
          end

          mix = mix:Sign()

          local deltaPos = (mousePos - initMouse) / peek(ui_conf.scale) * mix * (props.win.resize_axes or Vector2.one)

          local size = initSize + UDim2.fromOffset(deltaPos.X, deltaPos.Y)

          local constraint = props.win.child:FindFirstChildOfClass("UISizeConstraint")

          if constraint then
            local min = constraint.MinSize
            local max = constraint.MaxSize

            size = UDim2.fromOffset(math.clamp(size.X.Offset, min.X, max.X), math.clamp(size.Y.Offset, min.Y, max.Y))
          end

          props.size:set(size)
          props.position:set(initPos + deltaPos * mix:Min(Vector2.zero))
        end),
      },
    }
  end)
end

local function Window(scope: Fusion.Scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error(`cannot create window with id '{props.id}' without the ctx contextual set for current thread`)
  end

  -- converts position to how a gui object expects its position input with an anchor point
  -- the title bar size is also added to the position here
  if props.position and props.size and props.anchor then
    props.position -= props.size * props.anchor + props.anchor * Vector2.yAxis * (peek(ui_conf.text_sizes.title_bar) + peek(
      ui_conf.padding.base
    ) * 2)
  end

  local useAnchor = props.anchor or Vector2.zero

  local store = props.id
    and storage.new(scope, `window#{props.id}`, {
      visible = scope:Value(if props.init_visible ~= nil then props.init_visible else true),

      position = { props.position.x, props.position.y, useAnchor.x, useAnchor.y },
      size = props.disable_resize and {} or { props.size.x, props.size.y },
    })

  local visible = props.visible or (store and store.visible or scope:Value(true))

  local holding = scope:Value(false)
  local focused = scope:Value(props.focused or false)

  if workspace.CurrentCamera.ViewportSize.X == 1 then
    local conn: RBXScriptConnection?
    local thread = coroutine.running()

    local function await()
      conn = workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Once(function()
        task.spawn(thread)
      end)
    end

    await()

    local fixup = workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
      conn:Disconnect()
      await()
    end)

    coroutine.yield()

    conn:Disconnect()
    fixup:Disconnect()
  end

  local absoluteSize = props.child.AbsoluteSize

  local savedPos = props.position or Vector2.zero
  local savedAnchor = props.anchor or props.direct_anchor or Vector2.zero
  local savedChildSize = props.size and UDim2.fromOffset(props.size.x, props.size.y)
    or (props.disable_resize and UDim2.fromOffset(absoluteSize.X, absoluteSize.Y) or UDim2.fromOffset(100, 100))

  if store then
    local size = store.size
    local position = store.position

    savedAnchor = Vector2.new(position[3], position[4])
    savedChildSize = UDim2.fromOffset(size[1], size[2])

    savedPos = Vector2.new(position[1], position[2])
  end

  savedPos += workspace.CurrentCamera.ViewportSize * savedAnchor

  local position = scope:Value(savedPos)
  local childSize = scope:Value(savedChildSize)

  local windowSize = scope:Value(Vector2.zero)
  local topbarHeight = scope:Computed(function(use)
    return use(ui_conf.text_sizes.title_bar) + use(ui_conf.padding.base) * 2
  end)

  local anchor = scope:Value(savedAnchor)

  if props.focused and peek(ctx.current_priority) <= (props.focus_priority or 0) then
    if ctx.current_focused then
      ctx.current_focused:set(false)
    end

    ctx.focused_before_priority = ctx.current_focused
    ctx.current_focused = focused

    ctx.current_priority:set(props.focus_priority or 0)
  end

  local holdOffset: Vector2?

  local topbarValue: Fusion.Value<Frame?> = scope:Value(nil)
  local anchorButton: Fusion.Value<ImageButton?> = scope:Value(nil)

  local usePos = scope:Computed(function(use)
    local direct = props.direct_anchor

    local pos = use(position)
    local point = use(direct or anchor)

    local viewport = workspace.CurrentCamera.ViewportSize
    local res = pos - viewport * point

    return UDim2.new(point.X, res.X, point.Y, res.Y)
  end)

  local focusTextColor = scope:Spring(
    scope:Computed(function(use)
      local text = use(ui_conf.colors.text)
      local muted = use(ui_conf.colors.subtle)

      return use(focused) and text or muted
    end),
    30,
    1
  )

  local function savePositionAndAnchor()
    local topbar = peek(topbarValue)

    if not store or not topbar then
      return
    end

    local pos = peek(usePos)

    store.position = { pos.X.Offset, pos.Y.Offset, pos.X.Scale, pos.Y.Scale }
  end

  local viewportChangedReactThread

  table.insert(
    scope,
    workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
      if viewportChangedReactThread then
        task.cancel(viewportChangedReactThread)
      end

      viewportChangedReactThread = task.delay(0.1, function()
        viewportChangedReactThread = nil
        savePositionAndAnchor()
      end)
    end)
  )

  scope:Observer(holding):onChange(function()
    local topbar = peek(topbarValue)

    if not topbar then
      return
    end

    if not holdOffset and peek(holding) then
      holdOffset = UserInputService:GetMouseLocation() - topbar.AbsolutePosition
    else
      holdOffset = nil
      savePositionAndAnchor()
    end
  end)

  scope:Hydrate(props.child) {
    Size = scope:Computed(function(use)
      return UDim2.new(
        props.automatic_width and 0 or 1,
        0,
        props.automatic_height and 0 or 1,
        props.automatic_height and props.size.y or -use(topbarHeight)
      )
    end),
  }

  local sizeConstraint = props.child:FindFirstChildOfClass("UISizeConstraint")

  local maxSize = sizeConstraint and scope:Value(Vector2.one * math.huge)

  -- idek what im doing atp lol :pray:
  if sizeConstraint then
    scope:Hydrate(sizeConstraint) {
      [Out "MaxSize"] = maxSize,
    }
  end

  table.insert(scope, function()
    if ctx.current_focused == focused then
      ctx.current_focused = ctx.focused_before_priority

      if ctx.current_focused then
        ctx.current_focused:set(true)
      end

      ctx.current_priority:set(0)
    end
  end)

  local function setFocus()
    if ctx.ignore_focus or ctx.current_focused == focused or peek(ctx.current_holding) then
      return
    end

    if peek(ctx.current_priority) > (props.focus_priority or 0) then
      return
    end

    focused:set(true)

    local stack = peek(ctx.focus_stack)
    local index = table.find(stack, focused)

    if index then
      table.remove(stack, index)
    end

    table.insert(stack, focused)

    ctx.focus_stack:set(stack)

    if ctx.current_focused then
      ctx.current_focused:set(false)
    end

    ctx.focused_before_priority = ctx.current_focused

    ctx.current_focused = focused
    ctx.current_holding = holding

    ctx.current_priority:set(props.focus_priority or 0)
  end

  local res = {
    if not props.disable_resize
      then {
        ResizeHandles(scope, {
          sides = {
            Vector2.new(1, 0),
            Vector2.new(0, -1),
            Vector2.new(-1, 0),
            Vector2.new(0, 1),
          },

          use_pos = usePos,

          save_pos = savePositionAndAnchor,
          set_focus = setFocus,

          win = props,

          store = store,
          anchor = anchor,

          size = childSize,
          position = position,
          window_size = windowSize,
        }),
      }
      else nil,

    scope:New "ImageButton" {
      BackgroundTransparency = 1,

      Visible = scope:Computed(function(use)
        local f = use(focused)
        local i = use(ctx.current_priority) or 0

        return use(visible) or (props.focus_priority or 0) < i or f
      end),

      Position = usePos,
      ZIndex = 5,

      Size = scope:Computed(function(use)
        local size = use(windowSize) / use(ui_conf.scale)
        return UDim2.fromOffset(size.X, size.Y)
      end),
    },

    scope:New "Frame" {
      AutomaticSize = if props.automatic_height
        then Enum.AutomaticSize.Y
        else if props.automatic_width then Enum.AutomaticSize.X else Enum.AutomaticSize.None,

      BackgroundColor3 = ui_conf.colors.base,

      Position = usePos,

      ZIndex = 10,

      Size = scope:Computed(function(use)
        local s = use(childSize)
        return UDim2.fromOffset(s.X.Offset, if props.automatic_height then 0 else s.Y.Offset + use(topbarHeight))
      end),

      [Out "AbsoluteSize"] = windowSize,

      [OnEvent "MouseEnter"] = setFocus,

      [Children] = {
        if maxSize
          then scope:New "UISizeConstraint" {
            MaxSize = scope:Computed(function(use)
              return use(maxSize) + Vector2.yAxis * use(topbarHeight)
            end),
          }
          else nil,

        scope:New "UIStroke" {
          Thickness = 1,
          Color = ui_conf.colors.primary,

          Transparency = scope:Spring(
            scope:Computed(function(use)
              return use(focused) and 0 or 1
            end),
            30,
            1
          ),
        },

        scope:New "Frame" {
          BackgroundColor3 = ui_conf.colors.surface,

          Size = scope:Computed(function(use)
            return UDim2.fromOffset(use(windowSize).X / use(ui_conf.scale), use(topbarHeight))
          end),

          [Children] = {
            scope:Round(ui_conf.rounding.base),

            scope:New "Frame" {
              BackgroundTransparency = 1,

              Size = UDim2.fromScale(1, 1),

              [Children] = {
                scope:New "Frame" {
                  BackgroundColor3 = ui_conf.colors.surface,

                  AnchorPoint = Vector2.new(0, 1),
                  Position = UDim2.fromScale(0, 1),

                  Size = UDim2.new(1, 0, 0, 4),
                },

                topbarValue:set(scope:New "Frame" {
                  BackgroundTransparency = 1,
                  Size = UDim2.fromScale(1, 1),

                  [Children] = {
                    scope:Padding(ui_conf.padding.side, ui_conf.padding.base),

                    scope:OnHold(holding, function(mousePos)
                      local scale = peek(ui_conf.scale)

                      local viewport = workspace.CurrentCamera.ViewportSize
                      local rel = viewport - viewport / scale

                      position:set(
                        Vector2.new(mousePos.X - holdOffset.X, mousePos.Y - holdOffset.Y) / scale
                          + rel * peek(props.direct_anchor or anchor)
                      )
                    end),

                    if props.back_active
                      then scope:New "ImageButton" {
                        Image = "rbxassetid://83071046448902",

                        AnchorPoint = Vector2.new(0, 0.5),
                        Position = UDim2.fromScale(0, 0.5),

                        BackgroundTransparency = 1,
                        ImageColor3 = focusTextColor,

                        Size = UDim2.fromOffset(14, 14),
                        Visible = props.back_active,

                        ZIndex = 1000,

                        [OnEvent "MouseButton1Click"] = props.back_callback,
                      }
                      else nil,

                    if not props.no_title
                      then scope:New "TextLabel" {
                        AutomaticSize = Enum.AutomaticSize.Y,
                        BackgroundTransparency = 1,

                        Position = scope:Computed(function(use)
                          return UDim2.fromOffset(
                            if props.back_active
                              then use(props.back_active) and 14 + use(ui_conf.padding.side) or 0
                              else 0,
                            0
                          )
                        end),

                        Size = scope:Computed(function(use)
                          local count = 2

                          if props.disable_anchor then
                            count -= 1
                          end

                          return UDim2.new(
                            1,
                            -(
                                use(ui_conf.padding.side)
                                + use(ui_conf.padding.base) * (count - 1)
                                + 14 * count
                                + (
                                  if props.back_active
                                    then use(props.back_active) and 14 + use(ui_conf.padding.side) or 0
                                    else 0
                                )
                              ),
                            0,
                            0
                          )
                        end),

                        FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

                        Text = props.title,

                        TextColor3 = focusTextColor,
                        TextSize = ui_conf.text_sizes.title_bar,

                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextTruncate = Enum.TextTruncate.SplitWord,
                      }
                      else nil,

                    scope:New "Frame" {
                      BackgroundTransparency = 1,

                      AnchorPoint = Vector2.new(1, 0.5),
                      Position = UDim2.fromScale(1, 0.5),

                      Size = UDim2.fromScale(1, 1),

                      ZIndex = 1000,

                      [Children] = {
                        scope:New "UIListLayout" {
                          SortOrder = Enum.SortOrder.LayoutOrder,
                          FillDirection = Enum.FillDirection.Horizontal,

                          VerticalAlignment = Enum.VerticalAlignment.Center,
                          HorizontalAlignment = Enum.HorizontalAlignment.Right,

                          HorizontalFlex = props.no_title and Enum.UIFlexAlignment.SpaceBetween
                            or Enum.UIFlexAlignment.None,

                          Padding = scope:Computed(function(use)
                            return UDim.new(0, use(ui_conf.padding.base))
                          end),
                        },

                        scope:New "ImageButton" {
                          BackgroundTransparency = 1,

                          LayoutOrder = 2,

                          Size = scope:Computed(function(use)
                            local size = use(ui_conf.text_sizes.mini)
                            return UDim2.fromOffset(size, size)
                          end),

                          Image = "rbxassetid://133032633237208",
                          ImageColor3 = focusTextColor,

                          [OnEvent "MouseButton1Click"] = function()
                            if props.close_cleanup then
                              scope:doCleanup()
                            elseif props.id then
                              visible:set(false)
                            end
                          end,

                          [Children] = {
                            scope:Padding(0, 0, 0, 2),
                          },
                        },

                        if not props.disable_anchor
                          then anchorButton:set(scope:New "ImageButton" {
                            Image = "rbxassetid://76168972462643",

                            LayoutOrder = 1,
                            BackgroundTransparency = 1,
                            ImageColor3 = focusTextColor,

                            Size = UDim2.fromOffset(14, 14),

                            [OnEvent "MouseButton1Click"] = function()
                              conf.ctx:is(ctx):during(function()
                                scope:Prompt({
                                  title = "Anchor",

                                  position = coroutine.wrap(function()
                                    local scale = peek(ui_conf.scale)
                                    local pad = peek(ui_conf.padding.side) * scale

                                    local pos = props.child.AbsolutePosition
                                    local size = props.child.AbsoluteSize

                                    return Vector2.new(pos.X + size.X - pad - 100 * scale, pos.Y + pad)
                                  end)(),

                                  size = Vector2.new(100, 100),

                                  child = function(scope)
                                    return scope:New "Frame" {
                                      BackgroundTransparency = 1,

                                      [Children] = {
                                        scope:Padding(ui_conf.padding.side),

                                        scope:New "UIListLayout" {
                                          SortOrder = Enum.SortOrder.LayoutOrder,

                                          Padding = scope:Computed(function(use)
                                            return UDim.new(0, use(ui_conf.padding.side))
                                          end),
                                        },

                                        scope:New "Frame" {
                                          BackgroundTransparency = 1,

                                          Size = UDim2.fromScale(1, 1),
                                          SizeConstraint = Enum.SizeConstraint.RelativeXX,

                                          [Children] = {
                                            scope:New "CanvasGroup" {
                                              BackgroundTransparency = 1,

                                              Size = UDim2.fromScale(1, 1),
                                              SizeConstraint = Enum.SizeConstraint.RelativeXX,

                                              [Children] = {
                                                scope:Round(ui_conf.rounding.base),

                                                scope:New "UIListLayout" {
                                                  SortOrder = Enum.SortOrder.LayoutOrder,

                                                  FillDirection = Enum.FillDirection.Horizontal,

                                                  VerticalFlex = Enum.UIFlexAlignment.Fill,
                                                  HorizontalFlex = Enum.UIFlexAlignment.Fill,

                                                  Wraps = true,

                                                  Padding = scope:Computed(function(use)
                                                    return UDim.new(0, use(ui_conf.padding.prop))
                                                  end),
                                                },

                                                scope:ForValues(anchorPoints, function(_, scope, point)
                                                  return scope:Hover "ImageButton" {
                                                    BackgroundColor3 = scope:Computed(function(use)
                                                      return use(anchor) == point and use(ui_conf.colors.primary)
                                                        or use(ui_conf.colors.surface)
                                                    end),

                                                    Size = scope:Computed(function(use)
                                                      local pad = use(ui_conf.padding.base)

                                                      local rows = #anchorPoints / 3
                                                      local padRows = rows - 1

                                                      return UDim2.new(1 / 3, -pad * padRows, 1 / rows, -pad * padRows)
                                                    end),

                                                    [OnEvent "MouseButton1Click"] = function()
                                                      anchor:set(point)
                                                      savePositionAndAnchor()
                                                    end,

                                                    [Children] = {
                                                      scope:Round(ui_conf.rounding.nano),
                                                    },
                                                  }
                                                end),
                                              },
                                            },
                                          },
                                        },
                                      },
                                    } :: Frame
                                  end,
                                })
                              end)
                            end,
                          } :: ImageButton)
                          else nil,
                      },
                    },
                  },
                } :: Frame),
              },
            },
          },
        },

        scope:Round(ui_conf.rounding.base),

        scope:New "UIListLayout" {
          SortOrder = Enum.SortOrder.LayoutOrder,
        },

        props.child,
      },
    },
  }

  if props.button_icon then
    local btn = scope:Value(nil)
    local hovered = scope:Value(false)

    local tooltipScope = scope:innerScope()

    scope:Observer(hovered):onChange(function()
      if peek(holding) then
        return
      end

      if peek(hovered) then
        conf.ctx:is(ctx):during(function()
          if peek(conf.settings.ui.buttons_direction) == "Vertical" then
            local left = peek(conf.settings.ui.buttons_horizontal) == "Left"

            tooltipScope:Tooltip({
              near_element = peek(btn),

              near_padding = ui_conf.padding.side,
              padding_axes = left and Vector2.xAxis or -Vector2.xAxis,

              float = Vector2.new(left and 1 or 0, 0.5),
              anchor = Vector2.new(left and 0 or -1, -0.5),

              text = props.title:lower(),
            })
          else
            local bottom = peek(conf.settings.ui.buttons_vertical) == "Bottom"

            tooltipScope:Tooltip({
              near_element = peek(btn),

              near_padding = ui_conf.padding.side,
              padding_axes = bottom and -Vector2.yAxis or Vector2.yAxis,

              float = Vector2.new(0.5, bottom and 0 or 1),
              anchor = Vector2.new(-0.5, bottom and -1 or 0),

              text = props.title:lower(),
            })
          end
        end)
      else
        tooltipScope:doCleanup()
        tooltipScope = scope:innerScope()
      end
    end)

    btn:set(scope:Hover("ImageButton", nil, hovered) {
      Parent = ctx.viewport_toolbar,

      BackgroundColor3 = ui_conf.colors.base,

      Size = UDim2.fromOffset(30, 30),

      [OnEvent "MouseButton1Click"] = function()
        visible:set(not peek(visible))
      end,

      [Children] = {
        scope:Round(ui_conf.rounding.mini),

        scope:New "ImageLabel" {
          BackgroundTransparency = 1,

          AnchorPoint = Vector2.one * 0.5,
          Position = UDim2.fromScale(0.5, 0.5),

          Size = scope:Computed(function(use)
            local pad = use(ui_conf.padding.prop)
            return UDim2.new(1, -pad * 2, 1, -pad * 2)
          end),

          Image = props.button_icon,
        },
      },
    })
  end

  local function bind()
    local pos = peek(position)
    local ws = peek(windowSize) / peek(ui_conf.scale)

    local boundPad = peek(ui_conf.padding.side)

    local a = peek(props.direct_anchor) or peek(anchor)

    if a == Vector2.zero then
      a = Vector2.one
    end

    local s = ws * (Vector2.one - a)
    local rs = s * a

    local viewport = workspace.CurrentCamera.ViewportSize / peek(ui_conf.scale)

    local xmin = boundPad + rs.X
    local ymin = boundPad + rs.Y

    local xmax = viewport.X - ws.X - boundPad
    local ymax = viewport.Y - ws.Y - boundPad

    local max = Vector2.new(xmax, ymax)
    local min = Vector2.new(xmin, ymin)

    if peek(holding) then
      holding:set(false)
    end

    position:set(Vector2.new(pos.X, pos.Y):Min(max):Max(min))
  end

  if not props.id then
    RunService.Heartbeat:Once(bind)

    if props.automatic_width or props.automatic_height then
      scope:Observer(windowSize):onChange(bind)
    end
  end

  return scope:New "ScreenGui" {
    Parent = CoreGui,

    Enabled = scope:Computed(function(use)
      return use(visible) and use(props.global_enabled or ctx.global_enabled)
    end),

    ResetOnSpawn = false,
    IgnoreGuiInset = true,

    DisplayOrder = scope:Computed(function(use)
      return use(props.display_order) and use(props.display_order)
        or (use(ui_conf.display_order) - 100 + (table.find(use(ctx.focus_stack), focused) or 0))
    end),

    [Children] = {
      res,

      scope:New "UIScale" {
        Scale = ui_conf.scale,
      },
    },
  }
end

return Window
]]></ProtectedString>
					<string name="ScriptGuid">{939122EE-B4D1-48E6-AB53-890AA7BEE244}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
