							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local types = require("../types")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local RangeInput = require("../../attributes/cmp/RangeInput")

type props = {
  nil_symbol: any,
  padding: Fusion.UsedAs<number>,
  inputs: Fusion.UsedAs<{ types.input }>,
}

local handlers = {}

function handlers.number(scope: ui_types.scope, input: types.input)
  return scope:NumberField({
    value = input.value,

    min = input.min or -math.huge,
    max = input.max or math.huge,
  })
end

function handlers.NumberRange(scope: ui_types.scope, input: types.input)
  local focused = scope:Value(false)

  return scope:Hover "ImageButton" {
    BackgroundColor3 = ui_conf.colors.surface,

    Size = UDim2.fromScale(1, 1),

    [OnEvent "MouseButton1Click"] = function()
      focused:set(true)
    end,

    [Children] = {
      scope:Round(ui_conf.rounding.mini),

      RangeInput(scope, {
        center = true,
        focused = focused,

        value = input.value,

        min = input.min,
        max = input.max,
      }),
    },
  }
end

local function BottomBar(scope: ui_types.scope, props: props)
  return scope:New "Frame" {
    AutomaticSize = Enum.AutomaticSize.Y,

    BackgroundTransparency = 1,
    Size = UDim2.fromScale(1, 0),

    [Children] = {
      scope:New "UIListLayout" {
        SortOrder = Enum.SortOrder.LayoutOrder,
        FillDirection = Enum.FillDirection.Horizontal,

        VerticalAlignment = Enum.VerticalAlignment.Center,

        HorizontalFlex = Enum.UIFlexAlignment.Fill,

        Padding = scope:Computed(function(use)
          return UDim.new(0, use(props.padding))
        end),
      },

      scope:ForValues(props.inputs, function(use, scope, data)
        local value = data.input

        local inputHeight = scope:Computed(function(use)
          return use(ui_conf.text_sizes.mini) + use(ui_conf.padding.base) * 2
        end)

        local res = scope:New "Frame" {
          BackgroundTransparency = 1,
          AutomaticSize = Enum.AutomaticSize.Y,

          Size = UDim2.fromScale(1, 0),

          [Children] = {
            scope:New "UIListLayout" {
              SortOrder = Enum.SortOrder.LayoutOrder,
              VerticalAlignment = Enum.VerticalAlignment.Center,

              Padding = scope:Computed(function(use)
                return UDim.new(0, use(props.padding) / 2)
              end),
            },

            scope:New "TextLabel" {
              BackgroundTransparency = 1,

              Size = scope:Computed(function(use)
                return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.base))
              end),

              FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

              Text = value.name,

              TextColor3 = ui_conf.colors.text,
              TextSize = ui_conf.text_sizes.base,

              TextTruncate = Enum.TextTruncate.SplitWord,
            },

            scope:New "Frame" {
              BackgroundTransparency = 1,

              AnchorPoint = Vector2.new(0, 1),
              Position = UDim2.fromScale(0, 1),

              Size = scope:Computed(function(use)
                return UDim2.new(1, 0, 0, use(inputHeight))
              end),

              [Children] = {
                handlers[data.type](scope, value),
              },
            },
          },
        }

        return res
      end),
    },
  }
end

return BottomBar
]]></ProtectedString>
