							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")

local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local logger = require("../../../lib/logger")
local storage = require("../../../lib/storage")
local utility = require("../../../lib/utility")
local emit_utility = require("../../../lib/emit/mod/utility")

local conf = require("../../../.conf")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local default_presets = require("../presets")

local NamePrompt = require("./NamePrompt")

local EffectBehavior = require("../behavior")

type props = {
  path: Fusion.UsedAs<Path2D>,

  key: Fusion.Value<string?>,
  effects: { [string]: Instance },

  on_change: () -> (),
  replace_points: (points: { Path2DControlPoint }) -> (),
}

local serialize = {}
local deserialize = {}

function serialize.NumberRange(v: NumberRange)
  return { min = v.Min, max = v.Max }
end

function deserialize.NumberRange(v: { min: number, max: number })
  return NumberRange.new(v.min, v.max)
end

local function SideBar(scope: ui_types.scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create curve editor sidebar because the ctx contextual is not set for current thread")
  end

  local store = storage.new(scope, "curve_sidebar", {
    curve_presets = scope:Value({}),
    effect_presets = scope:Value({}),

    --imported = {
    --  curve_presets = scope:Value({}),
    --  effect_presets = scope:Value({}),
    --},
  })

  local searchQuery = scope:Value("")

  local searchBarValue: Fusion.Value<TextBox?> = scope:Value(nil)

  local presetPathZIndex = scope:Value(1)
  local searchFocused = scope:Value(false)

  local scaledPresetContentSize = scope:Value(Vector2.zero)

  local presetContentSize = scope:Computed(function(use)
    return use(scaledPresetContentSize) / use(ui_conf.scale)
  end)

  local function saveEffect(name: string)
    local key = peek(props.key)

    if not key then
      return
    end

    local effects = peek(props.effects)[key]
    local behavior = EffectBehavior[key]

    local obj = effects and effects[1]

    if not obj then
      return
    end

    local data = {}

    local function getEntry(prefix: string, inputs)
      local bundle = {}

      if inputs then
        for _, input in inputs do
          local v = obj:GetAttribute(`{prefix}_{input.name}`)
          local t = typeof(v)

          if t ~= "number" then
            local s = serialize[t]

            if s then
              v = s(v)
              v._szt = t
            else
              continue
            end
          end

          if v then
            bundle[input.name] = v
          end
        end
      end

      local curve = obj:GetAttribute(`{prefix}_Curve`)

      local entry = {
        typeof(curve) == "string" and utility.pointsToArray(emit_utility.deserializePath(buffer.fromstring(curve)))
          or {},
        bundle,
      }

      return entry
    end

    for _, first in behavior do
      if first.expand then
        local pack = {}

        for _, second in first.expand do
          pack[second.name] = getEntry(`{first.name}_{second.name}`, second.inputs)
        end

        data[first.name] = pack
      else
        data[first.name] = getEntry(`{first.name}`, first.inputs)
      end
    end

    local sets = peek(store.effect_presets)
    local list = sets[key]

    if not list then
      list = {}
      sets[key] = list
    end

    return {
      name,
      data,
    }
  end

  local function addEffectPresets(presets, from: number)
    local currentPresets = scope:Computed(function(use)
      local currentKey = use(props.key)
      return currentKey and use(presets)[currentKey] or {}
    end)

    local buttons = scope:ForValues(currentPresets, function(_, scope, set)
      local nameValue = scope:Value(set[1])

      local hovering = scope:Value(false)

      local ctxButton: Fusion.Value<ImageButton?> = scope:Value(nil)

      return scope:Hover("ImageButton", nil, hovering) {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = ui_conf.colors.surface,

        ZIndex = from,

        [OnEvent "MouseButton1Click"] = function()
          local key = peek(props.key)
          local effects = key and peek(props.effects)[key]

          if not effects then
            return
          end

          local behavior = EffectBehavior[key]

          if not behavior then
            return
          end

          local function applyInputs(
            prefix: string,
            data: {},
            handler: (
              (obj: Instance, path: Path2D, inputs: { [string]: number }, cached: any?) -> ()
            )?
          )
            local path
            local tempScope

            if handler and data[1] then
              tempScope = scope:innerScope()

              path = tempScope:New "Path2D" {
                Parent = ctxButton,
                Thickness = 0,
              } :: Path2D

              path:SetControlPoints(utility.arrayToPath(data[1]))
            end

            local cached

            for _, obj in effects do
              print(data)
              for name, value in data[2] do
                local t = typeof(value) == "table" and value._szt

                if t then
                  local ds = deserialize[t]

                  if ds then
                    value = ds(value)
                  else
                    continue
                  end
                end

                obj:SetAttribute(`{prefix}_{name}`, value)
              end

              if path and handler then
                cached = handler(obj, path, data[2], cached)
              end
            end

            if tempScope then
              tempScope:doCleanup()
            end
          end

          utility.record("apply effect preset", function()
            local save = set[2]

            for _, first in behavior do
              local l1 = save[first.name]

              if not l1 then
                continue
              end

              if first.expand then
                for _, second in first.expand do
                  local l2 = l1[second.name]

                  if not l2 then
                    continue
                  end

                  applyInputs(`{first.name}_{second.name}`, l2, second.handler)
                end
              else
                applyInputs(first.name, l1, first.handler)
              end
            end
          end)
        end,

        [Children] = {
          scope:Round(ui_conf.rounding.base),
          scope:New "UIAspectRatioConstraint" {},

          scope:New "TextLabel" {
            BackgroundTransparency = 1,

            Size = UDim2.fromScale(1, 1),

            FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

            Text = nameValue,

            TextColor3 = ui_conf.colors.text,
            TextSize = ui_conf.text_sizes.mini,

            ZIndex = 10,
            TextWrapped = true,

            TextTransparency = scope:Spring(
              scope:Computed(function(use)
                return use(hovering) and 1 or 0
              end),
              30,
              1
            ),

            [Children] = {
              scope:Padding(ui_conf.padding.side),
            },
          },

          scope:New "ImageLabel" {
            BackgroundTransparency = 1,

            AnchorPoint = Vector2.one * 0.5,
            Position = UDim2.fromScale(0.5, 0.5),

            Size = UDim2.fromScale(0.9, 0.9),

            Image = "rbxassetid://101676806007394",
            ImageColor3 = ui_conf.colors.subtle,

            ImageTransparency = 0.8,
          },

          ctxButton:set(scope:Hover "ImageButton" {
            BackgroundTransparency = scope:Spring(
              scope:Computed(function(use)
                return use(hovering) and 0 or 1
              end),
              30,
              1
            ),

            BackgroundColor3 = ui_conf.colors.highlight,

            Position = scope:Computed(function(use)
              local pad = use(ui_conf.padding.prop)
              return UDim2.fromOffset(pad, pad)
            end),

            Size = scope:Computed(function(use)
              local pad = use(ui_conf.padding.prop)
              return UDim2.fromOffset(10 + pad, 10 + pad)
            end),

            ZIndex = 10,

            [OnEvent "MouseButton1Click"] = function()
              conf.ctx:is(ctx):during(function()
                scope:Options({
                  float = Vector2.new(0, 1),

                  near_padding = ui_conf.padding.side,
                  near_element = peek(ctxButton),

                  options = {
                    {
                      name = "Delete",
                      on_click = function()
                        local list = peek(currentPresets)
                        local index = table.find(list, set)

                        if index then
                          table.remove(list, index)
                          presets:set(peek(presets))
                        end
                      end,
                    },
                    {
                      name = "Rename",
                      on_click = function()
                        conf.ctx:is(ctx):during(function()
                          scope:Prompt({
                            title = "Rename preset",

                            float = Vector2.new(0, 1),
                            near_element = peek(ctxButton),

                            child = function(scope)
                              return NamePrompt(scope, set[1], {
                                buttons = {
                                  {
                                    "save",
                                    function(name)
                                      set[1] = name
                                      nameValue:set(name)

                                      store:write("effect_presets")
                                    end,
                                  },
                                },
                              })
                            end,
                          })
                        end)
                      end,
                    },
                    {
                      name = "Update Effect",
                      on_click = function()
                        set[2] = saveEffect(set[1])[2]

                        store.effect_presets:set(peek(presets))
                        store:write("effect_presets")
                      end,
                    },
                  },
                })
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.nano),

              scope:New "ImageLabel" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.one * 0.5,
                Position = UDim2.fromScale(0.5, 0.5),

                Size = UDim2.fromOffset(10, 2),

                Image = "rbxassetid://108937556176877",

                ImageColor3 = ui_conf.colors.subtle,

                ImageTransparency = scope:Spring(
                  scope:Computed(function(use)
                    return use(hovering) and 0 or 1
                  end),
                  30,
                  1
                ),
              },
            },
          } :: ImageButton),
        },
      }
    end)

    local function refresh()
      local current = peek(currentPresets)

      for i, btn in peek(buttons) do
        local set = current[i]
        local start, stop = string.find(set[1]:lower(), peek(searchQuery):lower(), 1, true)

        btn.LayoutOrder = ((start and stop ~= 0) and start ^ 2 or from + i)
      end

      -- roblox: limiting imagination and powering mental breakdowns
      presetPathZIndex:set(0)
      RunService.RenderStepped:Wait()
      presetPathZIndex:set(1)
    end

    scope:Observer(buttons):onChange(refresh)
    scope:Observer(searchQuery):onChange(refresh)

    return buttons
  end

  local function addCurvePresets(presets, from: number)
    local buttons = scope:ForValues(presets, function(_, scope, set)
      local path = scope:New "Path2D" {
        Thickness = scope:Computed(function(use)
          return 2 * use(ui_conf.scale)
        end),

        Color3 = ui_conf.colors.subtle,

        ZIndex = presetPathZIndex,
      } :: Path2D

      local points = utility.arrayToPath(set[2])

      path:SetControlPoints(points)

      local nameValue = scope:Value(set[1])

      local hovering = scope:Value(false)
      local ctxButton: Fusion.Value<ImageButton?> = scope:Value(nil)

      return scope:Hover("ImageButton", nil, hovering) {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = ui_conf.colors.surface,

        ZIndex = from,

        [OnEvent "MouseButton1Click"] = function()
          props.replace_points(points)
          props.on_change()
        end,

        [Children] = {
          scope:Round(ui_conf.rounding.base),
          scope:New "UIAspectRatioConstraint" {},

          scope:New "TextLabel" {
            BackgroundTransparency = 1,

            Size = UDim2.fromScale(1, 1),

            FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

            Text = nameValue,

            TextColor3 = ui_conf.colors.text,
            TextSize = ui_conf.text_sizes.mini,

            ZIndex = 10,
            TextWrapped = true,

            TextTransparency = scope:Spring(
              scope:Computed(function(use)
                return use(hovering) and 1 or 0
              end),
              30,
              1
            ),

            [Children] = {
              scope:Padding(ui_conf.padding.side),
            },
          },

          if presets ~= default_presets
            then ctxButton:set(scope:Hover "ImageButton" {
              BackgroundTransparency = scope:Spring(
                scope:Computed(function(use)
                  return use(hovering) and 0 or 1
                end),
                30,
                1
              ),

              BackgroundColor3 = ui_conf.colors.highlight,

              Position = scope:Computed(function(use)
                local pad = use(ui_conf.padding.prop)
                return UDim2.fromOffset(pad, pad)
              end),

              Size = scope:Computed(function(use)
                local pad = use(ui_conf.padding.prop)
                return UDim2.fromOffset(10 + pad, 10 + pad)
              end),

              ZIndex = 10,

              [OnEvent "MouseButton1Click"] = function()
                conf.ctx:is(ctx):during(function()
                  scope:Options({
                    float = Vector2.new(0, 1),

                    near_padding = ui_conf.padding.side,
                    near_element = peek(ctxButton),

                    options = {
                      {
                        name = "Delete",
                        on_click = function()
                          local list = peek(presets)
                          local index = table.find(list, set)

                          if index then
                            table.remove(list, index)
                            presets:set(list)
                          end
                        end,
                      },
                      {
                        name = "Rename",
                        on_click = function()
                          conf.ctx:is(ctx):during(function()
                            scope:Prompt({
                              title = "Rename preset",

                              float = Vector2.new(0, 1),
                              near_element = peek(ctxButton),

                              child = function(scope)
                                return NamePrompt(scope, set[1], {
                                  buttons = {
                                    {
                                      "save",
                                      function(name)
                                        set[1] = name
                                        nameValue:set(name)

                                        store:write("curve_presets")
                                      end,
                                    },
                                  },
                                })
                              end,
                            })
                          end)
                        end,
                      },
                      {
                        name = "Update Curve",
                        on_click = function()
                          local refpath = peek(props.path)

                          if not refpath then
                            return
                          end

                          local newPoints = refpath:GetControlPoints()

                          path:SetControlPoints(newPoints)

                          points = newPoints
                          set[2] = utility.pathToArray(newPoints)

                          store:write("curve_presets")
                        end,
                      },
                    },
                  })
                end)
              end,

              [Children] = {
                scope:Round(ui_conf.rounding.nano),

                scope:New "ImageLabel" {
                  BackgroundTransparency = 1,

                  AnchorPoint = Vector2.one * 0.5,
                  Position = UDim2.fromScale(0.5, 0.5),

                  Size = UDim2.fromOffset(10, 2),

                  Image = "rbxassetid://108937556176877",

                  ImageColor3 = ui_conf.colors.subtle,

                  ImageTransparency = scope:Spring(
                    scope:Computed(function(use)
                      return use(hovering) and 0 or 1
                    end),
                    30,
                    1
                  ),
                },
              },
            } :: ImageButton)
            else nil,

          scope:New "CanvasGroup" {
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(1, 1),

            [Children] = scope:New "Frame" {
              BackgroundTransparency = 1,

              AnchorPoint = Vector2.new(0.5, 0.5),
              Position = UDim2.fromScale(0.5, 0.5),

              Size = UDim2.fromScale(0.75, 0.75),

              [Children] = {
                path,
              },
            },
          },
        },
      }
    end)

    local function refresh()
      for i, btn in peek(buttons) do
        local set = peek(presets)[i]
        local start, stop = string.find(set[1]:lower(), peek(searchQuery):lower(), 1, true)

        btn.LayoutOrder = ((start and stop ~= 0) and start ^ 2 or from + i)
      end

      -- roblox: limiting imagination and powering mental breakdowns
      presetPathZIndex:set(0)
      RunService.RenderStepped:Wait()
      presetPathZIndex:set(1)
    end

    scope:Observer(buttons):onChange(refresh)
    scope:Observer(searchQuery):onChange(refresh)

    return buttons
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,
    Size = UDim2.fromScale(1, 1),

    [Children] = {
      scope:New "Frame" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop))
        end),

        [Children] = {
          scope:Hover "Frame" {
            BackgroundColor3 = ui_conf.colors.surface,
            ZIndex = 10,

            Size = scope:Spring(
              scope:Computed(function(use)
                return UDim2.new(
                  1,
                  use(searchFocused) and 0
                    or -(use(ui_conf.padding.side) + use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop)),
                  0,
                  use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop)
                )
              end),
              30,
              1
            ),

            [Children] = {
              scope:Round(ui_conf.rounding.mini),

              searchBarValue:set(scope:New "TextBox" {
                BackgroundTransparency = 1,

                AnchorPoint = Vector2.new(0.5, 0),
                Position = UDim2.fromScale(0.5, 0),

                Size = scope:Computed(function(use)
                  return UDim2.new(1, -use(ui_conf.padding.prop) * 2, 1, 0)
                end),

                FontFace = ui_conf.font,

                PlaceholderText = "filter",

                TextColor3 = ui_conf.colors.text,
                PlaceholderColor3 = ui_conf.colors.muted,

                TextSize = ui_conf.text_sizes.mini,

                ClipsDescendants = true,

                TextXAlignment = scope:Computed(function(use)
                  return use(searchFocused) and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
                end),

                [Out "Text"] = searchQuery,

                [OnEvent "Focused"] = function()
                  searchFocused:set(true)

                  local bar = peek(searchBarValue)

                  if bar then
                    bar.CursorPosition = #bar.Text + 1
                    bar.SelectionStart = 0
                  end
                end,

                [OnEvent "FocusLost"] = function()
                  searchFocused:set(false)
                end,
              } :: TextBox),
            },
          },

          scope:Hover "TextButton" {
            Active = scope:Computed(function(use)
              return not use(searchFocused)
            end),

            BackgroundTransparency = scope:Spring(
              scope:Computed(function(use)
                return use(searchFocused) and 1 or 0
              end),
              50,
              1
            ),

            TextTransparency = scope:Spring(
              scope:Computed(function(use)
                return use(searchFocused) and 1 or 0
              end),
              50,
              1
            ),

            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.fromScale(1, 0),

            Size = scope:Computed(function(use)
              return UDim2.fromOffset(
                use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop),
                use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop)
              )
            end),

            FontFace = ui_conf.font,

            BackgroundColor3 = ui_conf.colors.primary,
            TextColor3 = ui_conf.colors.surface,

            Text = "+",

            TextSize = ui_conf.text_sizes.base,

            [OnEvent "MouseButton1Click"] = function()
              conf.ctx:is(ctx):during(function()
                scope:Prompt({
                  title = "New preset",

                  padding = ui_conf.padding.prop,

                  float = Vector2.new(0, 1),
                  near_element = peek(searchBarValue).Parent,

                  child = function(scope)
                    return NamePrompt(scope, "", {
                      buttons = {
                        {
                          "save curve",
                          function(name)
                            local refpath = peek(props.path)

                            if not refpath then
                              return
                            end

                            table.insert(peek(store.curve_presets), {
                              name,
                              utility.pathToArray(refpath:GetControlPoints()),
                            })

                            store.curve_presets:set(peek(store.curve_presets))
                            store:write("curve_presets")
                          end,
                        },
                        {
                          "save effect",
                          function(name)
                            local key = peek(props.key)
                            local sets = peek(store.effect_presets)

                            local list = sets[key]

                            if not list then
                              list = {}
                              sets[key] = list
                            end

                            table.insert(list, saveEffect(name))

                            store.effect_presets:set(sets)
                            store:write("effect_presets")
                          end,
                        },
                      },
                    })
                  end,
                })
              end)
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.mini),
            },
          },
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.fromScale(0, 1),

        Size = scope:Computed(function(use)
          return UDim2.new(
            1,
            0,
            1,
            -(use(ui_conf.padding.prop) + use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop))
          )
        end),

        [Children] = {
          scope:Scrollable({
            content_size = presetContentSize,
            on_canvaspos = function()
              presetPathZIndex:set(0)
              presetPathZIndex:set(1)
            end,
            children = {
              scope:New "UIListLayout" {
                SortOrder = Enum.SortOrder.LayoutOrder,

                Padding = scope:Computed(function(use)
                  return UDim.new(0, use(ui_conf.padding.side))
                end),

                [Out "AbsoluteContentSize"] = scaledPresetContentSize,
              },

              addCurvePresets(default_presets, 5000),
              addCurvePresets(store.curve_presets, 10_000),

              addEffectPresets(store.effect_presets, 15_000),
            },
          }),
        },
      },
    },
  }
end

return SideBar
]]></ProtectedString>
							<string name="ScriptGuid">{8BC2F56B-AC2E-46E5-BCE3-E9C766AD4820}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">SideBar</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX2CB6D21B5A13415C85EBBC5B06668A41">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  tabs: Fusion.UsedAs<{ string }>,
  selected: Fusion.Value<number>,
}

local function TabBar(scope: ui_types.scope, props: props)
  local canvasPos = scope:Value(0)

  local rightScrollAlpha = scope:Value(0)
  local rightScrollAlphaAnim = scope:Spring(rightScrollAlpha, 30, 1.5)

  local leftScrollAlpha = scope:Value(1)
  local leftScrollAlphaAnim = scope:Spring(leftScrollAlpha, 30, 1.5)

  local minTabWidth = scope:Value(0)
  local totalButtonWidth = scope:Value(0)

  local tabSize = scope:Value(Vector2.zero)

  local function handleScrollInput(input: InputObject)
    if input.UserInputType ~= Enum.UserInputType.MouseWheel then
      return
    end

    local scale = peek(ui_conf.scale)

    local maxScroll = math.min(peek(tabSize).X / scale - peek(minTabWidth), 0)

    canvasPos:set(
      math.clamp(peek(canvasPos) + peek(totalButtonWidth) / scale / #peek(props.tabs) * input.Position.Z, maxScroll, 0)
    )

    local alpha = math.clamp(peek(canvasPos) / maxScroll, 0, 1)

    rightScrollAlpha:set(maxScroll ~= 0 and (alpha == 1 and 1 or 0) or 1)
    leftScrollAlpha:set(maxScroll ~= 0 and (alpha == 0 and 1 or 0) or 1)
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,
    AutomaticSize = Enum.AutomaticSize.Y,

    Size = UDim2.fromScale(1, 0),

    ClipsDescendants = true,

    Visible = scope:Computed(function(use)
      return #use(props.tabs) ~= 0
    end),

    [Out "AbsoluteSize"] = tabSize,

    [OnEvent "InputBegan"] = handleScrollInput,
    [OnEvent "InputChanged"] = handleScrollInput,

    [Children] = {
      scope:New "Frame" {
        Size = UDim2.new(0, 20, 1, 0),

        ZIndex = 10,

        [Children] = {
          scope:New "UIGradient" {
            Transparency = scope:Computed(function(use)
              return NumberSequence.new({
                NumberSequenceKeypoint.new(0, use(leftScrollAlphaAnim)),
                NumberSequenceKeypoint.new(1, 1),
              })
            end),

            Color = scope:Computed(function(use)
              return ColorSequence.new({
                ColorSequenceKeypoint.new(0, use(ui_conf.colors.base)),
                ColorSequenceKeypoint.new(1, use(ui_conf.colors.base)),
              })
            end),
          },
        },
      },

      scope:New "Frame" {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),

        Size = UDim2.new(0, 20, 1, 0),

        ZIndex = 10,

        [Children] = {
          scope:New "UIGradient" {
            Transparency = scope:Computed(function(use)
              return NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, use(rightScrollAlphaAnim)),
              })
            end),

            Color = scope:Computed(function(use)
              return ColorSequence.new({
                ColorSequenceKeypoint.new(0, use(ui_conf.colors.base)),
                ColorSequenceKeypoint.new(1, use(ui_conf.colors.base)),
              })
            end),
          },
        },
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,

        Position = scope:Spring(
          scope:Computed(function(use)
            return UDim2.fromOffset(use(canvasPos), 0)
          end),
          30,
          1
        ),

        Size = scope:Computed(function(use)
          local scale = use(ui_conf.scale)
          local width = use(totalButtonWidth) / scale + use(ui_conf.padding.side) * math.max(#use(props.tabs) - 1, 0)

          minTabWidth:set(width)

          local maxScroll = math.min(use(tabSize).X / scale - width, 0)

          canvasPos:set(math.clamp(peek(canvasPos), maxScroll, 0))

          local alpha = math.clamp(peek(canvasPos) / maxScroll, 0, 1)

          rightScrollAlpha:set(maxScroll ~= 0 and (alpha == 1 and 1 or 0) or 1)
          leftScrollAlpha:set(maxScroll ~= 0 and (alpha == 0 and 1 or 0) or 1)

          return (use(tabSize).X / scale) > width and UDim2.fromScale(1, 0) or UDim2.fromOffset(width, 0)
        end),

        [Children] = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,

            HorizontalFlex = Enum.UIFlexAlignment.Fill,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),
          },

          scope:ForPairs(props.tabs, function(_, scope: ui_types.scope, index: number, tab: string)
            local prevWidth = 0
            local bounds = scope:Value(Vector2.zero)

            table.insert(scope, function()
              totalButtonWidth:set(peek(totalButtonWidth) - prevWidth)
            end)

            local isSelected = scope:Computed(function(use)
              return use(props.selected) == index
            end)

            return index,
              scope:Hover "TextButton" {
                LayoutOrder = index,

                TextColor3 = scope:Switch(isSelected, ui_conf.colors.surface, ui_conf.colors.text, 30, 1),
                BackgroundColor3 = scope:Switch(isSelected, ui_conf.colors.primary, ui_conf.colors.surface),

                FontFace = ui_conf.font,

                Text = tab,
                TextSize = ui_conf.text_sizes.mini,

                [Out "TextBounds"] = bounds,
                [OnEvent "MouseButton1Click"] = function()
                  props.selected:set(index)
                end,

                Size = scope:Computed(function(use)
                  local size = use(bounds)

                  local udim = UDim2.fromOffset(
                    use(ui_conf.padding.prop) * 2,
                    use(ui_conf.text_sizes.mini) + use(ui_conf.padding.prop)
                  )

                  local width = udim.X.Offset * use(ui_conf.scale) + size.X

                  totalButtonWidth:set(peek(totalButtonWidth) - prevWidth + width)
                  prevWidth = width

                  return udim + UDim2.fromOffset(size.X, 0)
                end),

                [Children] = {
                  scope:Round(ui_conf.rounding.mini),
                },
              }
          end),
        },
      },
    },
  }
end

return TabBar
]]></ProtectedString>
							<string name="ScriptGuid">{F1D3755E-AE9E-464C-B7E6-8A3AE5203392}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">TabBar</string>
