						<ProtectedString name="Source"><![CDATA[local plugin = script:FindFirstAncestorOfClass("Plugin")

local Fusion = require(script.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local Children = Fusion.Children

local peek = Fusion.peek

local commit = require("../../.build/commit")

local utility = require("../../lib/utility")
local storage = require("../../lib/storage")

local conf = require("../../.conf")
local ui_conf = require("../ui_conf")
local ui_types = require("../ui_types")

local Title = require("./cmp/Title")
local Number = require("./cmp/Number")
local Button = require("./cmp/Button")
local Boolean = require("./cmp/Boolean")
local Keybind = require("./cmp/Keybind")
local Dropdown = require("./cmp/Dropdown")

type props = {
  updlog_visible: Fusion.Value<boolean>,
}

local function Settings(scope: ui_types.scope, props: props)
  local s = conf.settings

  local layout = {
    Title(scope, {
      text = "Emission",
      size = ui_conf.text_sizes.title,
    }),

    Number(scope, {
      name = "Repeat Timer",

      value = s.emission.timer,

      min = 0,
      max = math.huge,
    }),

    Number(scope, {
      name = "Trail Radius",

      value = s.emission.trail_radius,

      min = 0,
      max = math.huge,
    }),

    Number(scope, {
      name = "Trail Lap Duration",

      value = s.emission.trail_lap_duration,

      min = 0,
      max = math.huge,
    }),

    Title(scope, {
      text = "Path Preview",
      size = ui_conf.text_sizes.title,
    }),

    Number(scope, {
      name = "Workers",

      value = s.path_preview.workers,

      min = 1,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Max Points",

      value = s.path_preview.points,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Sample Rate",

      value = s.path_preview.sample_rate,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Transparency",

      value = s.path_preview.transparency,

      min = 0,
      max = 1,
    }),

    Title(scope, {
      text = "Flipbooks",
      size = ui_conf.text_sizes.title,
    }),

    Number(scope, {
      name = "Default FPS",

      value = s.flipbooks.default_fps,

      min = 0.001,
      max = math.huge,
    }),

    Title(scope, {
      text = "Emit Code",
      size = ui_conf.text_sizes.title,
    }),

    Boolean(scope, {
      name = "Import Services",
      value = s.code.import_services,
    }),

    Boolean(scope, {
      name = "Import Workspace",
      value = s.code.import_workspace,
    }),

    Boolean(scope, {
      name = "Use Services' Full Name",
      value = s.code.services_full_name,
    }),

    Title(scope, {
      text = "Notifications",
      size = ui_conf.text_sizes.title,
    }),

    Boolean(scope, {
      name = "Check for Updates",
      value = s.notifs.check_for_updates,
    }),

    Title(scope, {
      text = "Interface",
      size = ui_conf.text_sizes.title,
    }),

    Number(scope, {
      name = "Scale",

      value = s.ui.scale,

      min = 0,
      max = math.huge,
    }),

    Number(scope, {
      name = "Display Order",

      value = s.ui.display_order,

      min = -math.huge,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Font Id",

      value = s.ui.font,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Title(scope, {
      text = "Button Layout",

      size = ui_conf.text_sizes.base,
      weight = Enum.FontWeight.Medium,
    }),

    Dropdown(scope, {
      name = "Horizontal",

      value = s.ui.buttons_horizontal,

      options = {
        "Left",
        "Center",
        "Right",
      },
    }),

    Dropdown(scope, {
      name = "Vertical",

      value = s.ui.buttons_vertical,

      options = {
        "Top",
        "Center",
        "Bottom",
      },
    }),

    Dropdown(scope, {
      name = "Direction",

      value = s.ui.buttons_direction,

      options = {
        "Horizontal",
        "Vertical",
      },
    }),

    Title(scope, {
      text = "Text Sizes",

      size = ui_conf.text_sizes.base,
      weight = Enum.FontWeight.Medium,
    }),

    Number(scope, {
      name = "Base",

      value = s.ui.text_sizes.base,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Mini",

      value = s.ui.text_sizes.mini,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Nano",

      value = s.ui.text_sizes.nano,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Title",

      value = s.ui.text_sizes.title,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Title Bar",

      value = s.ui.text_sizes.title_bar,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Special",

      value = s.ui.text_sizes.special,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Title(scope, {
      text = "Rounding",

      size = ui_conf.text_sizes.base,
      weight = Enum.FontWeight.Medium,
    }),

    Number(scope, {
      name = "Base",

      value = s.ui.rounding.base,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Mini",

      value = s.ui.rounding.mini,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Nano",

      value = s.ui.rounding.nano,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Title(scope, {
      text = "Padding",

      size = ui_conf.text_sizes.base,
      weight = Enum.FontWeight.Medium,
    }),

    Number(scope, {
      name = "Base",

      value = s.ui.padding.base,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Prop",

      value = s.ui.padding.prop,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Side",

      value = s.ui.padding.side,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Number(scope, {
      name = "Resize",

      value = s.ui.padding.resize,

      min = 0,
      max = math.huge,

      int = true,
    }),

    Title(scope, {
      text = "Keybinds",
      size = ui_conf.text_sizes.title,
    }),

    Keybind(scope, {
      name = "Toggle UI",
      value = s.keybinds.toggle_ui,
    }),

    Keybind(scope, {
      name = "Toggle Adder",
      value = s.keybinds.toggle_adder,
    }),

    Keybind(scope, {
      name = "Emit",
      value = s.keybinds.emit,
    }),

    Keybind(scope, {
      name = "Toggle 'Enabled'",
      value = s.keybinds.toggle_enabled,
    }),

    Keybind(scope, {
      name = "Toggle Paths",
      value = s.keybinds.toggle_paths,
    }),

    Title(scope, {
      text = "Misc",
      size = ui_conf.text_sizes.title,
    }),

    Button(scope, {
      text = scope:Computed(function(use)
        return use(props.updlog_visible) and "Close Update Logs" or "Open Update Logs"
      end),

      on_click = function()
        props.updlog_visible:set(not peek(props.updlog_visible))
      end,
    }),

    Title(scope, {
      text = "Reset Options",
      size = ui_conf.text_sizes.title,
    }),

    Button(scope, {
      text = "Reset Settings",
      on_click = function()
        for _, key in storage.getRegisteredKeys("settings") do
          plugin:SetSetting(key, nil)
        end

        storage.syncObjId("settings")
        utility.restart()
      end,
    }),

    Button(scope, {
      text = "Reset Window Layout",
      on_click = function()
        for id, keys in storage.getRegistered() do
          if not id:match("^window#") then
            continue
          end

          for _, key in keys do
            plugin:SetSetting(key, nil)
          end
        end

        utility.restart()
      end,
    }),

    Title(scope, {
      text = "Danger Zone",
      size = ui_conf.text_sizes.title,
    }),

    Button(scope, {
      text = "Reset All Data",
      on_click = function()
        for id, keys in storage.getRegistered() do
          for _, key in keys do
            plugin:SetSetting(key, nil)
          end
        end

        storage.syncObjId("settings")
        utility.restart()
      end,
    }),
  }

  local scaledContentSize = scope:Value(Vector2.zero)

  local contentSize = scope:Computed(function(use)
    return use(scaledContentSize) / use(ui_conf.scale)
  end)

  local timestamp = scope:Value(DateTime.now().UnixTimestamp)

  do
    local active = true

    table.insert(scope, function()
      active = false
    end)

    task.spawn(function()
      while active do
        timestamp:set(DateTime.now().UnixTimestamp)
        task.wait(0.5)
      end
    end)
  end

  return scope:New "Frame" {
    BackgroundTransparency = 1,

    [Children] = {
      scope:Padding(ui_conf.padding.side),

      scope:Scrollable({
        content_size = contentSize,

        offset = 1,
        padding = 1,

        children = {
          scope:New "UIListLayout" {
            SortOrder = Enum.SortOrder.LayoutOrder,

            Padding = scope:Computed(function(use)
              return UDim.new(0, use(ui_conf.padding.side))
            end),

            [Out "AbsoluteContentSize"] = scaledContentSize,
          },

          layout,

          scope:New "TextLabel" {
            AutomaticSize = Enum.AutomaticSize.Y,

            BackgroundTransparency = 1,

            Size = UDim2.fromScale(1, 0),

            Text = scope:Computed(function(use)
              return `{commit.hash} • {utility.getTimeAgo(use(timestamp) - commit.date)}`
            end),

            FontFace = ui_conf.font,
            TextSize = ui_conf.text_sizes.mini,

            TextTruncate = Enum.TextTruncate.SplitWord,

            TextWrapped = true,
            TextColor3 = ui_conf.colors.highlight,
          },
        },
      }),
    },
  }
end

return Settings
]]></ProtectedString>
