							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Children = Fusion.Children

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  options: Fusion.UsedAs<string>,
  selected: Fusion.Value<string>,

  search: Fusion.UsedAs<boolean>?,
}

local function CheckboxInput(scope: ui_types.scope, props: props)
  return scope:New "Frame" {
    BackgroundTransparency = 1,

    AnchorPoint = Vector2.new(0.5, 0),
    Position = UDim2.fromScale(0.5, 0),

    Size = UDim2.fromScale(1, 1),

    [Children] = {
      scope:Dropdown({
        selected = props.value,
        options = props.options,

        search = props.search,

        item_bg = ui_conf.colors.overlay,
        background = ui_conf.colors.surface,
        scrollbar_bg = ui_conf.colors.base,

        background_sel = scope:AlphaBlend(0.2, ui_conf.colors.surface, ui_conf.colors.primary),
      }),
    },
  }
end

return CheckboxInput
