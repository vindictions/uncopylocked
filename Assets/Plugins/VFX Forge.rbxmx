							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")
local symbols = require("../../../.symbols")

type props = {
  int: boolean?,
  center: boolean?,

  focused: Fusion.Value<boolean>?,
  value: Fusion.Value<NumberRange>,

  min: number?,
  max: number?,
}

local NUMBER = "(%-?%d*%.?%d+)"

local function RangeInput(scope: ui_types.scope, props: props)
  local unmodifiedInput = ""

  local inputBox: Fusion.Value<TextBox?> = scope:Value(nil)

  local focused = props.focused or scope:Value(false)

  local res = scope:New "Frame" {
    BackgroundTransparency = 1,

    AnchorPoint = Vector2.new(0.5, 0),
    Position = UDim2.fromScale(0.5, 0),

    Size = scope:Computed(function(use)
      return UDim2.new(1, -use(ui_conf.padding.side) * 2, 1, 0)
    end),

    ClipsDescendants = true,

    [Children] = {
      inputBox:set(scope:New "TextBox" {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),

        FontFace = ui_conf.font,

        Text = scope:Computed(function(use)
          local range = use(props.value)

          if range == symbols.nil_symbol then
            return "-"
          end

          local function fmt(s: number)
            return string.format(`%.3f`, s):gsub("0*$", ""):gsub("%.$", "")
          end

          if props.int then
            return `{tostring(math.round(range.Min))}, {tostring(math.round(range.Max))}`
          else
            return `{fmt(range.Min)}, {fmt(range.Max)}`
          end
        end),

        TextColor3 = ui_conf.colors.text,
        TextSize = ui_conf.text_sizes.mini,

        TextXAlignment = props.center and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left,

        [OnEvent "Focused"] = function()
          focused:set(true)
        end,

        [OnEvent "FocusLost"] = function()
          focused:set(false)
        end,

        [Children] = {
          scope:Padding(1, 0, 0, 0),
        },
      } :: TextBox),
    },
  }

  scope:Observer(focused):onChange(function()
    if peek(focused) then
      local input = peek(inputBox)

      if input then
        unmodifiedInput = input.Text

        input.CursorPosition = #input.Text + 1
        input.SelectionStart = 0
      end
    else
      local input = peek(inputBox)

      local min, max = input.Text:match(`{NUMBER}[,%s]%s*{NUMBER}`)

      if not min and not max then
        min = input.Text:match(`{NUMBER}`)
        max = min
      end

      min, max = tonumber(min), tonumber(max)
      max = math.max(min, max)

      if min and max then
        input.Text = unmodifiedInput

        props.value:set(
          NumberRange.new(
            math.clamp(min, props.min or -math.huge, props.max or math.huge),
            math.clamp(max, props.min or -math.huge, props.max or math.huge)
          )
        )
      else
        input.Text = unmodifiedInput
      end
    end
  end)

  if peek(props.focused) then
    local input = peek(inputBox)
    input:CaptureFocus()
  end

  return res
end

return RangeInput
]]></ProtectedString>
