							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local Children = Fusion.Children

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  index: number,
  depth: number,

  name: string,

  is_last: boolean,

  readonly: boolean?,

  background: Fusion.UsedAs<Color3>?,
  component: (scope: ui_types.scope) -> (),
}

local function Attribute(scope: ui_types.scope, props: props)
  local bgColorSync = scope:Value(Color3.new())

  return scope[props.readonly and "New" or "Hover"](scope, "Frame") {
    BackgroundColor3 = props.background or ui_conf.colors.surface,

    Size = scope:Computed(function(use)
      return UDim2.new(
        1,
        0,
        0,
        use(ui_conf.text_sizes.mini) + use(ui_conf.padding.side) + (props.index == 1 and 0 or 1)
      )
    end),

    [Out "BackgroundColor3"] = bgColorSync,

    [Children] = {
      if props.is_last
        then {
          scope:Round(ui_conf.rounding.base),
          scope:New "Frame" {
            BackgroundColor3 = bgColorSync,

            Size = scope:Computed(function(use)
              return UDim2.new(1, 0, 0, use(ui_conf.rounding.base))
            end),
          },
        }
        else nil,

      if props.index ~= 1
        then scope:New "Frame" {
          BackgroundColor3 = ui_conf.colors.overlay,

          Size = UDim2.new(1, 0, 0, 1),

          ZIndex = 10,
        }
        else nil,

      scope:New "Frame" {
        BackgroundTransparency = 1,

        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.fromScale(1, 0.5),

        Size = UDim2.fromScale(0.5, 1),

        [Children] = {
          props.component,
        },
      },

      scope:New "Frame" {
        BackgroundColor3 = ui_conf.colors.overlay,

        AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.fromScale(0.5, 0),

        Size = UDim2.new(0, 1, 1, 0),

        ZIndex = 10,
      },

      scope:New "TextLabel" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(0.5, -math.ceil(use(ui_conf.padding.prop) / 2), 1, 0)
        end),

        FontFace = ui_conf.font,

        Text = props.name,
        TextWrapped = true,

        TextTruncate = Enum.TextTruncate.SplitWord,

        TextColor3 = props.readonly and ui_conf.colors.muted or ui_conf.colors.text,
        TextSize = ui_conf.text_sizes.mini,

        TextXAlignment = Enum.TextXAlignment.Left,

        [Children] = {
          scope:Padding(
            scope:Computed(function(use)
              local p = use(ui_conf.padding.prop)
              return p + p * (math.max(props.depth - 1, 1) - 1) * 2
            end),
            ui_conf.padding.prop,
            ui_conf.padding.prop,
            ui_conf.padding.prop
          ),
        },
      },
    },
  }
end

return Attribute
]]></ProtectedString>
