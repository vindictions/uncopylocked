							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local conf = require("../../../.conf")
local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

local logger = require("../../../lib/logger")
local utility = require("../../../lib/utility")

local getETA = require("../eta_calculator")

type props = {
  jobs: Fusion.Value<{
    title: Fusion.UsedAs<string>,

    completed: Fusion.Value<number>,
    target: Fusion.Value<number>,

    failed: Fusion.Value<number>,
    retry: () -> (),
  }>,
}
-- you should look at a j*b list instead of looking at this
local function JobList(scope: ui_types.scope, props: props)
  local ctx = conf.ctx:now()

  if not ctx then
    logger.error("cannot create flipbook list because the ctx contextual is not set for current thread")
  end

  return scope:ForValues(props.jobs, function(_, scope, job)
    local eta = getETA(scope, job)

    return scope:New "Frame" {
      AutomaticSize = Enum.AutomaticSize.Y,

      BackgroundColor3 = ui_conf.colors.overlay,

      Size = UDim2.fromScale(1, 0),

      [Children] = {
        scope:Round(ui_conf.rounding.base),
        scope:Padding(ui_conf.padding.side),

        scope:New "UIListLayout" {
          SortOrder = Enum.SortOrder.LayoutOrder,

          Padding = scope:Computed(function(use)
            return UDim.new(0, use(ui_conf.padding.base))
          end),
        },

        scope:New "TextLabel" {
          AutomaticSize = Enum.AutomaticSize.Y,

          BackgroundTransparency = 1,
          Size = UDim2.fromScale(1, 0),

          Text = job.title,
          TextSize = ui_conf.text_sizes.base,

          FontFace = scope:Font(ui_conf.font, Enum.FontWeight.SemiBold),

          TextTruncate = Enum.TextTruncate.SplitWord,
          TextXAlignment = Enum.TextXAlignment.Left,

          TextColor3 = ui_conf.colors.text,
        },

        scope:New "Frame" {
          AutomaticSize = Enum.AutomaticSize.Y,
          BackgroundTransparency = 1,

          Size = UDim2.fromScale(1, 0),

          [Children] = {
            scope:New "UIListLayout" {
              SortOrder = Enum.SortOrder.LayoutOrder,

              Padding = scope:Computed(function(use)
                return UDim.new(0, use(ui_conf.padding.side))
              end),
            },

            scope:New "Frame" {
              AutomaticSize = Enum.AutomaticSize.Y,
              BackgroundTransparency = 1,

              Size = UDim2.fromScale(1, 0),

              [Children] = {
                scope:New "UIListLayout" {
                  SortOrder = Enum.SortOrder.LayoutOrder,
                  FillDirection = Enum.FillDirection.Horizontal,

                  HorizontalFlex = Enum.UIFlexAlignment.Fill,

                  Padding = scope:Computed(function(use)
                    return UDim.new(0, use(ui_conf.padding.side))
                  end),
                },

                scope:New "TextLabel" {
                  AutomaticSize = Enum.AutomaticSize.Y,
                  BackgroundTransparency = 1,

                  Size = UDim2.fromScale(1, 0),

                  Text = scope:Computed(function(use)
                    local seconds = use(eta)
                    return seconds and `{utility.formatTime(seconds)}` or "ETA"
                  end),

                  TextSize = ui_conf.text_sizes.mini,

                  FontFace = ui_conf.font,

                  TextTruncate = Enum.TextTruncate.SplitWord,
                  TextXAlignment = Enum.TextXAlignment.Left,

                  TextColor3 = ui_conf.colors.text,
                },

                scope:New "TextLabel" {
                  AutomaticSize = Enum.AutomaticSize.Y,
                  BackgroundTransparency = 1,

                  Size = UDim2.fromScale(1, 0),

                  Text = scope:Computed(function(use)
                    return `{use(job.completed)}/{use(job.target)}`
                  end),

                  TextSize = ui_conf.text_sizes.mini,

                  FontFace = ui_conf.font,

                  TextTruncate = Enum.TextTruncate.SplitWord,
                  TextXAlignment = Enum.TextXAlignment.Right,

                  TextColor3 = ui_conf.colors.text,
                },
              },
            },

            scope:New "CanvasGroup" {
              BackgroundColor3 = ui_conf.colors.surface,

              Size = UDim2.new(1, 0, 0, 8),

              [Children] = {
                scope:Round(0, 0.5),

                scope:New "Frame" {
                  BackgroundColor3 = ui_conf.colors.primary,

                  Size = scope:Spring(
                    scope:Computed(function(use)
                      return UDim2.fromScale(use(job.completed) / use(job.target), 1)
                    end),
                    30,
                    1
                  ),
                },
              },
            },

            scope:New "TextLabel" {
              AutomaticSize = Enum.AutomaticSize.Y,
              BackgroundTransparency = 1,

              Size = UDim2.fromScale(1, 0),

              Text = scope:Computed(function(use)
                return `{use(job.failed)} uploads failed`
              end),

              Visible = scope:Computed(function(use)
                return use(job.failed) ~= 0
              end),

              FontFace = ui_conf.font,
              TextSize = ui_conf.text_sizes.mini,
              TextColor3 = ui_conf.colors.text,

              TextTruncate = Enum.TextTruncate.SplitWord,
            },

            scope:Hover "TextButton" {
              AutomaticSize = Enum.AutomaticSize.Y,

              Size = scope:Computed(function(use)
                return UDim2.fromScale(1, 0)
              end),

              Visible = scope:Computed(function(use)
                return use(job.failed) ~= 0
              end),

              Text = "retry",

              BackgroundColor3 = ui_conf.colors.primary,

              TextColor3 = ui_conf.colors.base,

              FontFace = ui_conf.font,
              TextSize = ui_conf.text_sizes.mini,

              TextTruncate = Enum.TextTruncate.SplitWord,

              [OnEvent "MouseButton1Click"] = job.retry,

              [Children] = {
                scope:Round(ui_conf.rounding.mini),
                scope:Padding(ui_conf.padding.side, ui_conf.padding.base),
              },
            },
          },
        },
      },
    }
  end)
end

return JobList
]]></ProtectedString>
