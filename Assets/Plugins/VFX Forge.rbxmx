					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("./ui_conf")

type props = {
  value: Fusion.Value<number>,
  background: Fusion.UsedAs<Color3>,

  size: Fusion.UsedAs<UDim2>?,

  min: Fusion.UsedAs<number>,
  max: Fusion.UsedAs<number>,

  no_bar: Fusion.UsedAs<number>?,
  vertical: Fusion.UsedAs<number>?,

  step: number?,

  children: { Fusion.Child }?,
}

local function Slider(scope: Fusion.Scope, props: props)
  local progress = scope:Value(0)
  local dotSize = scope:Value(Vector2.zero)

  local frameValue: Fusion.Value<Frame?> = scope:Value(nil)

  local function updateProgress()
    local min = peek(props.min)
    local max = peek(props.max)

    if min == max then
      return
    end

    progress:set(math.clamp((peek(props.value) - min) / (max - min), 0, 1))
  end

  scope:Observer(props.value):onBind(updateProgress)

  scope:Observer(props.min):onBind(updateProgress)
  scope:Observer(props.max):onBind(updateProgress)

  local function setProgress(value: number)
    local min = peek(props.min)
    local max = peek(props.max)

    if props.step then
      local grid = props.step / math.max(max - min, 1)
      value = math.round(value / grid) * grid
    end

    progress:set(value)
    props.value:set(min + (max - min) * value)
  end

  return frameValue:set(scope:New "Frame" {
    BackgroundColor3 = props.background,

    AnchorPoint = Vector2.new(0.5, 0.5),
    Position = UDim2.fromScale(0.5, 0.5),

    Size = props.size or UDim2.fromScale(1, 1),

    [Children] = {
      props.children,

      scope:Round(0, 0.5),

      scope:OnHold(scope:Value(false), function(mousePos)
        local frame = peek(frameValue)

        if frame then
          if peek(props.vertical) then
            setProgress(1 - math.clamp((mousePos.Y - frame.AbsolutePosition.Y) / frame.AbsoluteSize.Y, 0, 1))
          else
            setProgress(math.clamp((mousePos.X - frame.AbsolutePosition.X) / frame.AbsoluteSize.X, 0, 1))
          end
        end
      end),

      scope:New "Frame" {
        BackgroundColor3 = ui_conf.colors.primary,

        BackgroundTransparency = scope:Computed(function(use)
          return use(props.no_bar) and 1 or 0
        end),

        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.fromScale(0, 1),

        Size = scope:Computed(function(use)
          local p = use(progress)
          local offset = (use(dotSize).X / 2) * (1 - 2 * p)

          return use(props.vertical) and UDim2.new(1, 0, p, offset) or UDim2.new(p, offset, 1, 0)
        end),

        [Children] = {
          scope:Round(0, 0.5),
        },
      },

      scope:New "ImageButton" {
        BackgroundColor3 = ui_conf.colors.primary,
        BackgroundTransparency = props.custom_dot and 0 or 0,

        AnchorPoint = Vector2.new(0.5, 0.5),

        Size = props.dot_size or UDim2.fromScale(1.75, 1.75),

        SizeConstraint = scope:Computed(function(use)
          return use(props.vertical) and Enum.SizeConstraint.RelativeXX or Enum.SizeConstraint.RelativeYY
        end),

        Position = scope:Computed(function(use)
          local v = use(props.vertical)

          local s = use(dotSize)
          local p = use(progress)

          local alpha = if props.no_bar then -1 + 2 * p else (1 - 2 * p)
          local offset = (v and s.Y or s.X) / 2 * alpha

          if not props.no_bar then
            offset -= 1
          end

          return v and UDim2.new(0.5, 0, 1 - p, offset) or UDim2.new(p, offset, 0.5, 0)
        end),

        ZIndex = 1000,

        [Out "AbsoluteSize"] = dotSize,

        [Children] = {
          props.custom_dot,

          scope:OnHold(scope:Value(false), function(mousePos, deltaPos)
            local frame = peek(frameValue)

            if frame then
              local pos = frame.AbsolutePosition.X
              local width = frame.AbsoluteSize.X

              local p = peek(progress)

              if (mousePos.X < pos and p == 0) or (mousePos.X > pos + width and p == 1) then
                return
              end

              if peek(props.vertical) then
                setProgress(math.clamp(p + deltaPos.Y / frame.AbsoluteSize.Y, 0, 1))
              else
                setProgress(math.clamp(p - deltaPos.X / frame.AbsoluteSize.X, 0, 1))
              end
            end
          end),

          scope:Round(0, 0.5),
        },
      },
    },
  } :: Frame)
end

return Slider
]]></ProtectedString>
					<string name="ScriptGuid">{48AE65AA-7788-4998-8B3E-A09412379F15}</string>
