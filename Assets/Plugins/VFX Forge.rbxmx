							<ProtectedString name="Source"><![CDATA[local Fusion = require(script.Parent.Parent.Parent.Parent.pkg.Fusion)

local Out = Fusion.Out
local OnEvent = Fusion.OnEvent
local Children = Fusion.Children

local peek = Fusion.peek

local ui_conf = require("../../ui_conf")
local ui_types = require("../../ui_types")

type props = {
  name: string,
  value: Fusion.Value<boolean?>,
}

local function Boolean(scope: ui_types.scope, props: props)
  local boxSize = scope:Value(Vector2.zero)

  return scope:New "Frame" {
    BackgroundColor3 = ui_conf.colors.surface,

    Size = scope:Computed(function(use)
      return UDim2.new(1, 0, 0, use(ui_conf.text_sizes.base) + use(ui_conf.padding.base) * 3)
    end),

    [Children] = {
      scope:Round(ui_conf.rounding.mini),
      scope:Padding(ui_conf.padding.side, ui_conf.padding.base, ui_conf.padding.base, ui_conf.padding.base),

      scope:New "TextLabel" {
        BackgroundTransparency = 1,

        Size = scope:Computed(function(use)
          return UDim2.new(1, -use(boxSize).X - use(ui_conf.padding.side), 1, 0)
        end),

        Text = props.name,
        TextSize = ui_conf.text_sizes.mini,

        FontFace = ui_conf.font,

        TextTruncate = Enum.TextTruncate.SplitWord,
        TextXAlignment = Enum.TextXAlignment.Left,

        TextColor3 = ui_conf.colors.text,
      },

      scope:New "Frame" {
        BackgroundTransparency = 1,

        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),

        Size = UDim2.fromScale(1, 1),
        SizeConstraint = Enum.SizeConstraint.RelativeYY,

        [Out "AbsoluteSize"] = boxSize,

        [Children] = {
          scope:Padding(ui_conf.padding.base),

          scope:Hover "ImageButton" {
            BackgroundColor3 = scope:Spring(
              scope:Computed(function(use)
                return use(props.value) == true and peek(ui_conf.colors.primary) or peek(ui_conf.colors.overlay)
              end),
              30,
              1
            ),

            Size = UDim2.fromScale(1, 1),

            [OnEvent "MouseButton1Click"] = function()
              props.value:set(not peek(props.value))
            end,

            [Children] = {
              scope:Round(ui_conf.rounding.nano),
            },
          },
        },
      },
    },
  }
end

return Boolean
]]></ProtectedString>
